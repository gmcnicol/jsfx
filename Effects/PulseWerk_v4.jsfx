function queue_note_off(chan_i, note_i, abs_time_i) local(next_tail)
(
  queue_note_off = 0;
  next_tail = queue_tail + 1;
  next_tail >= QUEUE_SIZE ? next_tail = 0;
  next_tail != queue_head ? (
    off_time[queue_tail] = abs_time_i;
    off_chan[queue_tail] = chan_i;
    off_note[queue_tail] = note_i;
    queue_tail = next_tail;
    queue_note_off = 1;
  );
);

function flush_all_note_offs() local(i, repeat_count, note_i, chan_i, guard, repeat_guard)
(
  guard = 0;
  while ((queue_head != queue_tail) && (guard < QUEUE_SIZE)) (
    queue_head += 1;
    queue_head >= QUEUE_SIZE ? queue_head = 0;
    guard += 1;
  );
  queue_head = 0;
  queue_tail = 0;

  i = 0;
  while (i < (16 * 128)) (
    repeat_count = active_note_count[i];
    note_i = i % 128;
    chan_i = floor(i / 128);
    repeat_guard = 0;
    while ((repeat_count > 0) && (repeat_guard < 64)) (
      midisend(0, 128 | chan_i, note_i);
      repeat_count -= 1;
      repeat_guard += 1;
    );
    active_note_count[i] = 0;
    i += 1;
  );
);

function flush_due_note_offs() local(rel_spl, chan_i, note_i, active_idx, guard)
(
  guard = 0;
  while (
    (queue_head != queue_tail) &&
    (off_time[queue_head] < block_abs_end) &&
    (guard < QUEUE_SIZE)
  ) (
    rel_spl = off_time[queue_head] - block_abs_start;
    rel_spl < 0 ? rel_spl = 0;
    rel_spl >= samplesblock ? rel_spl = samplesblock - 1;

    chan_i = off_chan[queue_head];
    note_i = off_note[queue_head];
    midisend(rel_spl, 128 | chan_i, note_i);

    active_idx = active_note_index(chan_i, note_i);
    active_note_count[active_idx] > 0 ? active_note_count[active_idx] -= 1;

    queue_head += 1;
    queue_head >= QUEUE_SIZE ? queue_head = 0;
    guard += 1;
  );
);

function trigger_role(layer_i, role_i, base_vel, rel_offset, bar_i, step_i, cycle_bar_i) local(pad_i, note_i, chan_i, vel_i, note_off_at, active_idx, hit_offset, timing_spl)
(
  base_vel > 0 ? (
    pad_i = get_pad_for_role(layer_i, role_i);
    note_i = get_pad_note(layer_i, pad_i);
    chan_i = layer_channel_zero(layer_i);
    vel_i = scaled_velocity(layer_i, base_vel);
    timing_spl = ms_to_samples(role_timing_ms(layer_i, role_i, bar_i, step_i, cycle_bar_i));
    hit_offset = rel_offset + timing_spl;
    hit_offset < 0 ? hit_offset = 0;
    hit_offset >= samplesblock ? hit_offset = samplesblock - 1;
    note_off_at = block_abs_start + hit_offset + note_len_samples;

    queue_note_off(chan_i, note_i, note_off_at) ? (
      midisend(hit_offset, 144 | chan_i, note_i | (vel_i * 256));
      layer_activity[layer_pad_index(layer_i, pad_i)] = min(1.4, layer_activity[layer_pad_index(layer_i, pad_i)] + 0.65);
      slot_activity[pad_i] = min(1.6, slot_activity[pad_i] + 0.55);
      active_idx = active_note_index(chan_i, note_i);
      active_note_count[active_idx] += 1;
    );
  );
);

