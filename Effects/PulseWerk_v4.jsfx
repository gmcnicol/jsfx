desc:PulseWerk v4 - Seeded MIDI Rhythm Workstation

in_pin:none
out_pin:none

slider1:cycle_bars=8<1,32,1>Cycle Bars
slider2:master_note_length=90<10,100,1>Master Note Length
slider3:ui_scale_pct=115<75,200,1>UI Scale
slider4:seed=1207<0,999999,1>Seed

slider5:mot_enable=1<0,1,1{Off,On}>Motorik Enable
slider6:mot_mute=0<0,1,1{Off,On}>Motorik Mute
slider7:mot_solo=0<0,1,1{Off,On}>Motorik Solo
slider8:mot_channel=1<1,16,1>Motorik Channel
slider9:mot_density=65<0,100,1>Motorik Density
slider10:mot_variation=60<0,100,1>Motorik Variation
slider11:mot_velocity_scale=100<10,150,1>Motorik Velocity Scale

slider12:bb_enable=1<0,1,1{Off,On}>BB Enable
slider13:bb_mute=0<0,1,1{Off,On}>BB Mute
slider14:bb_solo=0<0,1,1{Off,On}>BB Solo
slider15:bb_channel=2<1,16,1>BB Channel
slider16:bb_density=65<0,100,1>BB Density
slider17:bb_variation=60<0,100,1>BB Variation
slider18:bb_velocity_scale=100<10,150,1>BB Velocity Scale

slider19:perc_enable=1<0,1,1{Off,On}>Perc Enable
slider20:perc_mute=0<0,1,1{Off,On}>Perc Mute
slider21:perc_solo=0<0,1,1{Off,On}>Perc Solo
slider22:perc_channel=3<1,16,1>Perc Channel
slider23:perc_density=60<0,100,1>Perc Density
slider24:perc_variation=55<0,100,1>Perc Variation
slider25:perc_velocity_scale=100<10,150,1>Perc Velocity Scale

@init

NUM_LAYERS = 3;
NUM_PADS = 12;
QUEUE_SIZE = 1024;
STEP_BEATS = 0.25;

LAYER_MOTORIK = 0;
LAYER_BREAKBEAT = 1;
LAYER_PERC = 2;

pad_note = 0;
role_to_pad = 64;
layer_activity = 128;
slot_activity = 192;
active_note_count = 256;
off_time = 2304;
off_chan = off_time + QUEUE_SIZE;
off_note = off_chan + QUEUE_SIZE;

queue_head = 0;
queue_tail = 0;

ui_audition_pending = 0;
ui_audition_layer = 0;
ui_audition_pad = 0;

last_mouse_down = 0;

transport_is_playing = 0;
current_cycle_step = 0;
current_bar = 0;
current_step_in_bar = 0;
cycle_steps = 128;

last_transport_is_playing = 0;
last_beat_position = 0;
last_block_beats = 0;

abs_sample_clock = 0;
block_abs_start = 0;
block_abs_end = 0;
step_samples = 0;
note_len_samples = 0;
layer_row_drag_active = 0;
layer_row_drag_layer = 0;
layer_row_drag_row = 0;
layer_row_drag_start_y = 0;
layer_row_drag_origin = 0;
global_drag_active = 0;
global_drag_control = 0;
global_drag_start_y = 0;
global_drag_origin = 0;

function clampi(v, lo, hi)
(
  v < lo ? lo : v > hi ? hi : v;
);

function frac(x)
(
  x - floor(x);
);

function layer_pad_index(layer_i, pad_i)
(
  layer_i * NUM_PADS + pad_i;
);

function active_note_index(chan_i, note_i)
(
  chan_i * 128 + note_i;
);

function layer_name(layer_i)
(
  layer_i == LAYER_MOTORIK ? sprintf(#layer_txt, "Motorik");
  layer_i == LAYER_BREAKBEAT ? sprintf(#layer_txt, "BB");
  layer_i == LAYER_PERC ? sprintf(#layer_txt, "Perc");
);

function layer_full_name(layer_i)
(
  layer_i == LAYER_MOTORIK ? sprintf(#layer_full_txt, "Motorik");
  layer_i == LAYER_BREAKBEAT ? sprintf(#layer_full_txt, "Breakbeat");
  layer_i == LAYER_PERC ? sprintf(#layer_full_txt, "Percussion");
);

function role_name(layer_i, role_i)
(
  layer_i == LAYER_MOTORIK ? (
    role_i == 0 ? sprintf(#role_txt, "Kick");
    role_i == 1 ? sprintf(#role_txt, "Snare");
    role_i == 2 ? sprintf(#role_txt, "ClosedHat");
    role_i == 3 ? sprintf(#role_txt, "OpenHat");
    role_i == 4 ? sprintf(#role_txt, "GhostSnare");
    role_i == 5 ? sprintf(#role_txt, "Tambourine");
    role_i == 6 ? sprintf(#role_txt, "Crash");
    role_i == 7 ? sprintf(#role_txt, "Perc1");
    role_i == 8 ? sprintf(#role_txt, "Perc2");
    role_i == 9 ? sprintf(#role_txt, "Clap");
    role_i == 10 ? sprintf(#role_txt, "TomLow");
    role_i == 11 ? sprintf(#role_txt, "TomHigh");
  ) :
  layer_i == LAYER_BREAKBEAT ? (
    role_i == 0 ? sprintf(#role_txt, "Kick");
    role_i == 1 ? sprintf(#role_txt, "Snare");
    role_i == 2 ? sprintf(#role_txt, "ClosedHat");
    role_i == 3 ? sprintf(#role_txt, "OpenHat");
    role_i == 4 ? sprintf(#role_txt, "GhostSnare");
    role_i == 5 ? sprintf(#role_txt, "Clap");
    role_i == 6 ? sprintf(#role_txt, "Ride");
    role_i == 7 ? sprintf(#role_txt, "TomLow");
    role_i == 8 ? sprintf(#role_txt, "TomHigh");
    role_i == 9 ? sprintf(#role_txt, "Rim");
    role_i == 10 ? sprintf(#role_txt, "Shaker");
    role_i == 11 ? sprintf(#role_txt, "FX");
  ) :
  (
    role_i == 0 ? sprintf(#role_txt, "Shaker");
    role_i == 1 ? sprintf(#role_txt, "Tambourine");
    role_i == 2 ? sprintf(#role_txt, "Clap");
    role_i == 3 ? sprintf(#role_txt, "Rim");
    role_i == 4 ? sprintf(#role_txt, "Cowbell");
    role_i == 5 ? sprintf(#role_txt, "CongaLow");
    role_i == 6 ? sprintf(#role_txt, "CongaHigh");
    role_i == 7 ? sprintf(#role_txt, "BongoLow");
    role_i == 8 ? sprintf(#role_txt, "BongoHigh");
    role_i == 9 ? sprintf(#role_txt, "Woodblock");
    role_i == 10 ? sprintf(#role_txt, "ClosedHat");
    role_i == 11 ? sprintf(#role_txt, "OpenHat");
  );
);

function default_note(layer_i, pad_i)
(
  layer_i == LAYER_MOTORIK ? (
    pad_i == 0 ? 36 :
    pad_i == 1 ? 38 :
    pad_i == 2 ? 42 :
    pad_i == 3 ? 46 :
    pad_i == 4 ? 37 :
    pad_i == 5 ? 54 :
    pad_i == 6 ? 49 :
    pad_i == 7 ? 50 :
    pad_i == 8 ? 51 :
    pad_i == 9 ? 39 :
    pad_i == 10 ? 45 :
    47
  ) :
  layer_i == LAYER_BREAKBEAT ? (
    pad_i == 0 ? 36 :
    pad_i == 1 ? 38 :
    pad_i == 2 ? 42 :
    pad_i == 3 ? 46 :
    pad_i == 4 ? 37 :
    pad_i == 5 ? 39 :
    pad_i == 6 ? 51 :
    pad_i == 7 ? 45 :
    pad_i == 8 ? 47 :
    pad_i == 9 ? 37 :
    pad_i == 10 ? 82 :
    83
  ) :
  (
    pad_i == 0 ? 82 :
    pad_i == 1 ? 54 :
    pad_i == 2 ? 39 :
    pad_i == 3 ? 37 :
    pad_i == 4 ? 56 :
    pad_i == 5 ? 64 :
    pad_i == 6 ? 63 :
    pad_i == 7 ? 60 :
    pad_i == 8 ? 61 :
    pad_i == 9 ? 76 :
    pad_i == 10 ? 42 :
    46
  );
);

function layer_enabled(layer_i)
(
  layer_i == LAYER_MOTORIK ? floor(mot_enable + 0.5) :
  layer_i == LAYER_BREAKBEAT ? floor(bb_enable + 0.5) :
  floor(perc_enable + 0.5);
);

function layer_muted(layer_i)
(
  layer_i == LAYER_MOTORIK ? floor(mot_mute + 0.5) :
  layer_i == LAYER_BREAKBEAT ? floor(bb_mute + 0.5) :
  floor(perc_mute + 0.5);
);

function layer_soloed(layer_i)
(
  layer_i == LAYER_MOTORIK ? floor(mot_solo + 0.5) :
  layer_i == LAYER_BREAKBEAT ? floor(bb_solo + 0.5) :
  floor(perc_solo + 0.5);
);

function layer_channel_display(layer_i)
(
  layer_i == LAYER_MOTORIK ? floor(mot_channel + 0.5) :
  layer_i == LAYER_BREAKBEAT ? floor(bb_channel + 0.5) :
  floor(perc_channel + 0.5);
);

function layer_channel_zero(layer_i)
(
  clampi(layer_channel_display(layer_i), 1, 16) - 1;
);

function layer_density(layer_i)
(
  layer_i == LAYER_MOTORIK ? floor(mot_density + 0.5) :
  layer_i == LAYER_BREAKBEAT ? floor(bb_density + 0.5) :
  floor(perc_density + 0.5);
);

function layer_variation(layer_i)
(
  layer_i == LAYER_MOTORIK ? floor(mot_variation + 0.5) :
  layer_i == LAYER_BREAKBEAT ? floor(bb_variation + 0.5) :
  floor(perc_variation + 0.5);
);

function layer_velocity_scale(layer_i)
(
  layer_i == LAYER_MOTORIK ? floor(mot_velocity_scale + 0.5) :
  layer_i == LAYER_BREAKBEAT ? floor(bb_velocity_scale + 0.5) :
  floor(perc_velocity_scale + 0.5);
);

function any_layer_soloed()
(
  layer_soloed(LAYER_MOTORIK) || layer_soloed(LAYER_BREAKBEAT) || layer_soloed(LAYER_PERC);
);

function layer_can_emit(layer_i) local(any_solo)
(
  any_solo = any_layer_soloed();
  layer_enabled(layer_i) && !layer_muted(layer_i) && (!any_solo || layer_soloed(layer_i));
);

function get_pad_note(layer_i, pad_i)
(
  pad_note[layer_pad_index(layer_i, pad_i)];
);

function set_pad_note(layer_i, pad_i, note_val)
(
  pad_note[layer_pad_index(layer_i, pad_i)] = clampi(note_val, 0, 127);
);

function get_pad_for_role(layer_i, role_i)
(
  role_to_pad[layer_pad_index(layer_i, role_i)];
);

function role_for_pad(layer_i, pad_i) local(role_i, found_role)
(
  found_role = 0;
  role_i = 0;
  while ((role_i < NUM_PADS) && (get_pad_for_role(layer_i, role_i) != pad_i)) (
    role_i += 1;
  );
  role_i < NUM_PADS ? found_role = role_i;
  found_role;
);

function set_layer_enabled(layer_i, value_i)
(
  value_i = clampi(value_i, 0, 1);
  layer_i == LAYER_MOTORIK ? (mot_enable = value_i; slider5 = value_i;) :
  layer_i == LAYER_BREAKBEAT ? (bb_enable = value_i; slider12 = value_i;) :
  (perc_enable = value_i; slider19 = value_i;);
);

function set_layer_muted(layer_i, value_i)
(
  value_i = clampi(value_i, 0, 1);
  layer_i == LAYER_MOTORIK ? (mot_mute = value_i; slider6 = value_i;) :
  layer_i == LAYER_BREAKBEAT ? (bb_mute = value_i; slider13 = value_i;) :
  (perc_mute = value_i; slider20 = value_i;);
);

function set_layer_soloed(layer_i, value_i)
(
  value_i = clampi(value_i, 0, 1);
  layer_i == LAYER_MOTORIK ? (mot_solo = value_i; slider7 = value_i;) :
  layer_i == LAYER_BREAKBEAT ? (bb_solo = value_i; slider14 = value_i;) :
  (perc_solo = value_i; slider21 = value_i;);
);

function set_layer_channel(layer_i, value_i)
(
  value_i = clampi(value_i, 1, 16);
  layer_i == LAYER_MOTORIK ? (mot_channel = value_i; slider8 = value_i;) :
  layer_i == LAYER_BREAKBEAT ? (bb_channel = value_i; slider15 = value_i;) :
  (perc_channel = value_i; slider22 = value_i;);
);

function set_layer_density(layer_i, value_i)
(
  value_i = clampi(value_i, 0, 100);
  layer_i == LAYER_MOTORIK ? (mot_density = value_i; slider9 = value_i;) :
  layer_i == LAYER_BREAKBEAT ? (bb_density = value_i; slider16 = value_i;) :
  (perc_density = value_i; slider23 = value_i;);
);

function set_layer_variation(layer_i, value_i)
(
  value_i = clampi(value_i, 0, 100);
  layer_i == LAYER_MOTORIK ? (mot_variation = value_i; slider10 = value_i;) :
  layer_i == LAYER_BREAKBEAT ? (bb_variation = value_i; slider17 = value_i;) :
  (perc_variation = value_i; slider24 = value_i;);
);

function set_layer_velocity_scale(layer_i, value_i)
(
  value_i = clampi(value_i, 10, 150);
  layer_i == LAYER_MOTORIK ? (mot_velocity_scale = value_i; slider11 = value_i;) :
  layer_i == LAYER_BREAKBEAT ? (bb_velocity_scale = value_i; slider18 = value_i;) :
  (perc_velocity_scale = value_i; slider25 = value_i;);
);

function set_cycle_bars(value_i)
(
  value_i = clampi(value_i, 1, 32);
  cycle_bars = value_i;
  slider1 = value_i;
);

function set_master_note_length(value_i)
(
  value_i = clampi(value_i, 10, 100);
  master_note_length = value_i;
  slider2 = value_i;
);

function set_seed_value(value_i)
(
  value_i = clampi(value_i, 0, 999999);
  seed = value_i;
  slider4 = value_i;
);

function get_layer_row_value(layer_i, row_i)
(
  row_i == 0 ? layer_channel_display(layer_i) :
  row_i == 1 ? layer_density(layer_i) :
  row_i == 2 ? layer_variation(layer_i) :
  layer_velocity_scale(layer_i);
);

function set_layer_row_value(layer_i, row_i, value_i)
(
  row_i == 0 ? set_layer_channel(layer_i, value_i) :
  row_i == 1 ? set_layer_density(layer_i, value_i) :
  row_i == 2 ? set_layer_variation(layer_i, value_i) :
  set_layer_velocity_scale(layer_i, value_i);
);

function adjust_global_control(control_i, delta_i)
(
  control_i == 0 ? set_seed_value(seed + delta_i) :
  control_i == 1 ? set_layer_variation(LAYER_MOTORIK, layer_variation(LAYER_MOTORIK) + delta_i) :
  control_i == 2 ? set_layer_variation(LAYER_BREAKBEAT, layer_variation(LAYER_BREAKBEAT) + delta_i) :
  set_layer_variation(LAYER_PERC, layer_variation(LAYER_PERC) + delta_i);
);

function global_control_label(control_i)
(
  control_i == 0 ? sprintf(#global_label_txt, "Seed") :
  control_i == 1 ? sprintf(#global_label_txt, "Motorik Var") :
  control_i == 2 ? sprintf(#global_label_txt, "Breakbeat Var") :
  sprintf(#global_label_txt, "Percussion Var");
);

function global_control_value_text(control_i)
(
  control_i == 0 ? sprintf(#global_val_txt, "%06d", floor(seed + 0.5)) :
  control_i == 1 ? sprintf(#global_val_txt, "%d", layer_variation(LAYER_MOTORIK)) :
  control_i == 2 ? sprintf(#global_val_txt, "%d", layer_variation(LAYER_BREAKBEAT)) :
  sprintf(#global_val_txt, "%d", layer_variation(LAYER_PERC));
);

function get_global_control_value(control_i)
(
  control_i == 0 ? floor(seed + 0.5) :
  control_i == 1 ? layer_variation(LAYER_MOTORIK) :
  control_i == 2 ? layer_variation(LAYER_BREAKBEAT) :
  layer_variation(LAYER_PERC);
);

function set_global_control_value(control_i, value_i)
(
  control_i == 0 ? set_seed_value(value_i) :
  control_i == 1 ? set_layer_variation(LAYER_MOTORIK, value_i) :
  control_i == 2 ? set_layer_variation(LAYER_BREAKBEAT, value_i) :
  set_layer_variation(LAYER_PERC, value_i);
);

function hash01(a, b, c, d, e) local(v)
(
  v = sin((seed + 1) * 0.071 + a * 12.989 + b * 78.233 + c * 37.719 + d * 19.913 + e * 7.133) * 43758.545;
  frac(v < 0 ? -v : v);
);

function hash_pick(max_count, a, b, c, d, e)
(
  max_count <= 1 ? 0 : floor(hash01(a, b, c, d, e) * max_count);
);

function hash_hit(percent_i, a, b, c, d, e)
(
  hash01(a, b, c, d, e) * 100 < percent_i;
);

function scaled_velocity(layer_i, base_vel)
(
  clampi(floor(base_vel * layer_velocity_scale(layer_i) * 0.01 + 0.5), 1, 127);
);

function tempo_human_ms() local(t)
(
  t = max(tempo, 1);
  t < 78 ? 16 :
  t < 92 ? 14 :
  t < 108 ? 12 :
  t < 124 ? 10 :
  t < 138 ? 8 :
  t < 152 ? 7 :
  6;
);

function ms_to_samples(ms_val)
(
  floor(srate * ms_val * 0.001 + 0.5);
);

function motorik_family(bar_i, variation_i)
(
  variation_i < 34 ? 0 :
  variation_i < 67 ? ((bar_i + 1 + hash_pick(3, 11, bar_i, variation_i, LAYER_MOTORIK, 0)) % 3) :
  ((bar_i + hash_pick(4, 12, bar_i, variation_i, LAYER_MOTORIK, clampi(floor(cycle_bars + 0.5), 1, 32))) % 4);
);

function breakbeat_family(bar_i, variation_i)
(
  variation_i < 34 ? 0 :
  variation_i < 67 ? ((bar_i + 2 + hash_pick(3, 21, bar_i, variation_i, LAYER_BREAKBEAT, 0)) % 3) :
  ((bar_i + hash_pick(4, 22, bar_i, variation_i, LAYER_BREAKBEAT, clampi(floor(cycle_bars + 0.5), 1, 32))) % 4);
);

function perc_family(bar_i, variation_i)
(
  variation_i < 34 ? 0 :
  variation_i < 67 ? ((bar_i + 1 + hash_pick(3, 31, bar_i, variation_i, LAYER_PERC, 0)) % 3) :
  ((bar_i + hash_pick(4, 32, bar_i, variation_i, LAYER_PERC, clampi(floor(cycle_bars + 0.5), 1, 32))) % 4);
);

function role_timing_ms(layer_i, role_i, bar_i, step_i, cycle_bar_i) local(base_ms, timing_ms, fam_i, variation_i, density_i, phrase_turn_bar, cycle_turn_bar, cycle_bar_count, jitter_ms)
(
  base_ms = tempo_human_ms();
  timing_ms = 0;

  layer_i == LAYER_MOTORIK ? (
    variation_i = layer_variation(LAYER_MOTORIK);
    density_i = layer_density(LAYER_MOTORIK);
    fam_i = (bar_i >= 0) ? motorik_family(bar_i, variation_i) : 0;
    cycle_bar_count = clampi(floor(cycle_bars + 0.5), 1, 32);
    phrase_turn_bar = (cycle_bar_i >= 0) && (((cycle_bar_i + 1) % 4) == 0) && (cycle_bar_i != (cycle_bar_count - 1));
    cycle_turn_bar = (cycle_bar_i >= 0) && (cycle_bar_i == (cycle_bar_count - 1));

    role_i == 0 ? (
      timing_ms = ((step_i == 0) || (step_i == 8)) ? 0 : base_ms * 0.12;
      ((step_i == 10) || (step_i == 14)) ? timing_ms += base_ms * 0.08;
    );
    role_i == 1 ? timing_ms = base_ms * 0.26;
    role_i == 2 ? timing_ms = ((step_i % 4) == 2) ? (base_ms * 0.40) : (base_ms * 0.22);
    role_i == 3 ? timing_ms = base_ms * 0.46;
    role_i == 4 ? timing_ms = base_ms * 0.58;
    role_i == 5 ? timing_ms = base_ms * 0.34;
    role_i == 6 ? timing_ms = base_ms * 0.10;
    role_i == 7 ? timing_ms = base_ms * 0.30;
    role_i == 8 ? timing_ms = base_ms * 0.36;
    role_i == 9 ? timing_ms = base_ms * 0.32;
    role_i == 10 ? timing_ms = base_ms * 0.44;
    role_i == 11 ? timing_ms = base_ms * 0.48;

    density_i >= 67 && (role_i == 2) && ((step_i % 2) == 1) ? timing_ms += base_ms * 0.06;
    fam_i >= 2 && ((role_i == 4) || (role_i == 10) || (role_i == 11)) ? timing_ms += base_ms * 0.08;
    phrase_turn_bar && (step_i >= 8) && (role_i != 0) ? timing_ms += base_ms * 0.10;
    cycle_turn_bar && (step_i >= 8) && (role_i != 0) ? timing_ms += base_ms * 0.16;
  ) :
  layer_i == LAYER_BREAKBEAT ? (
    variation_i = layer_variation(LAYER_BREAKBEAT);
    density_i = layer_density(LAYER_BREAKBEAT);
    fam_i = (bar_i >= 0) ? breakbeat_family(bar_i, variation_i) : 0;

    role_i == 0 ? (
      timing_ms = ((step_i == 0) || (step_i == 8)) ? (base_ms * 0.04) : (base_ms * 0.14);
      ((step_i == 6) || (step_i == 7) || (step_i == 10) || (step_i == 11) || (step_i == 15)) ? timing_ms += base_ms * 0.08;
    );
    role_i == 1 ? timing_ms = base_ms * 0.40;
    role_i == 2 ? timing_ms = ((step_i % 4) == 2) ? (base_ms * 0.52) : (base_ms * 0.28);
    role_i == 3 ? timing_ms = base_ms * 0.60;
    role_i == 4 ? timing_ms = base_ms * 0.70;
    role_i == 5 ? timing_ms = base_ms * 0.46;
    role_i == 6 ? timing_ms = base_ms * 0.42;
    role_i == 7 ? timing_ms = base_ms * 0.48;
    role_i == 8 ? timing_ms = base_ms * 0.54;
    role_i == 9 ? timing_ms = base_ms * 0.58;
    role_i == 10 ? timing_ms = base_ms * 0.64;
    role_i == 11 ? timing_ms = base_ms * 0.50;

    fam_i >= 2 && ((role_i == 4) || (role_i == 9) || (role_i == 10)) ? timing_ms += base_ms * 0.08;
    variation_i >= 67 && (step_i >= 12) && (role_i != 0) ? timing_ms += base_ms * 0.12;
    density_i >= 67 && ((role_i == 2) || (role_i == 10) || (role_i == 6)) ? timing_ms += base_ms * 0.06;
  ) :
  (
    variation_i = layer_variation(LAYER_PERC);
    density_i = layer_density(LAYER_PERC);
    fam_i = (bar_i >= 0) ? perc_family(bar_i, variation_i) : 0;

    role_i == 0 ? timing_ms = ((step_i % 2) == 0) ? (base_ms * 0.54) : (base_ms * 0.66);
    role_i == 1 ? timing_ms = base_ms * 0.42;
    role_i == 2 ? timing_ms = base_ms * 0.50;
    role_i == 3 ? timing_ms = base_ms * 0.52;
    role_i == 4 ? timing_ms = base_ms * 0.32;
    role_i == 5 ? timing_ms = base_ms * 0.40;
    role_i == 6 ? timing_ms = base_ms * 0.48;
    role_i == 7 ? timing_ms = base_ms * 0.44;
    role_i == 8 ? timing_ms = base_ms * 0.52;
    role_i == 9 ? timing_ms = base_ms * 0.30;
    role_i == 10 ? timing_ms = ((step_i % 4) == 2) ? (base_ms * 0.44) : (base_ms * 0.24);
    role_i == 11 ? timing_ms = base_ms * 0.50;

    density_i >= 67 && ((role_i == 0) || (role_i == 5) || (role_i == 6) || (role_i == 7) || (role_i == 8)) ? timing_ms += base_ms * 0.08;
    fam_i >= 2 && (step_i >= 12) ? timing_ms += base_ms * 0.08;
    variation_i >= 67 && ((role_i == 3) || (role_i == 4) || (role_i == 9) || (role_i == 11)) ? timing_ms += base_ms * 0.10;
  );

  cycle_bar_i >= 0 ? (
    jitter_ms = (hash01(41 + layer_i, role_i, bar_i, step_i, cycle_bar_i) - 0.5) * base_ms * variation_i * 0.004;
    timing_ms += jitter_ms;
