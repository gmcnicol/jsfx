desc:LifeGrain (16x16) - POP-SAFE v3 (headroom + wet slew + hard ceiling)

////////////////////////////////////////////////////////////////////////////////
// SLIDERS
////////////////////////////////////////////////////////////////////////////////

slider1:step_idx=4<0,5,1{1/1,1/2,1/4,1/8,1/16,1/32}>Rate
slider2:grain_ms=90<10,350,1>Grain shape
slider3:mix=70<0,100,1>Wet level (%)
slider4:freeze=0<0,1,1{Off,On}>Freeze buffer

slider5:buf_sec=4<1,12,1>Buffer
slider6:scan_pct=35<1,100,1>Scan depth (%)

slider7:wrap=1<0,1,1{Off,On}>Wrap edges
slider8:density=25<0,100,1>Seed density (%)
slider9:reseed=0<0,1,1{No,Yes}>Reseed now

slider10:mojo=55<0,100,1>Shape / Pan
slider11:cap=24<1,120,1>Grain cap
slider12:hp=20<0,200,1>Cutoff Hz
slider13:dry=30<0,100,1>Dry level (%)

// NEW safety (master-bus friendly)
slider14:slew=0.020<0.000,0.200,0.001>Wet slew limit (0=off)
slider15:autohead=1<0,1,1{Off,On}>Auto headroom

////////////////////////////////////////////////////////////////////////////////
// CONSTANTS / STATE
////////////////////////////////////////////////////////////////////////////////

@init
  GRID_W = 16;
  GRID_H = 16;
  GRID_N = GRID_W*GRID_H;

  cur_base    = 0;
  nxt_base    = cur_base + GRID_N;
  energy_base = nxt_base + GRID_N;
  age_base    = energy_base + GRID_N;
  cell_voice_base = age_base + GRID_N;

  MAX_VOICES = 128;
  v_active_base = cell_voice_base + GRID_N;   // 0=off, 1=looping, 2=releasing
  v_pos_base    = v_active_base + MAX_VOICES;
  v_step_base   = v_pos_base + MAX_VOICES;
  v_age_base    = v_step_base + MAX_VOICES;
  v_amp_base    = v_age_base + MAX_VOICES;
  v_pan_base    = v_amp_base + MAX_VOICES;
  v_loop_start_base = v_pan_base + MAX_VOICES;
  v_loop_len_base   = v_loop_start_base + MAX_VOICES;
  v_rel_pos_base    = v_loop_len_base + MAX_VOICES;
  v_rel_len_base    = v_rel_pos_base + MAX_VOICES;
  v_cell_base       = v_rel_len_base + MAX_VOICES;
  v_att_len_base    = v_cell_base + MAX_VOICES;
  v_rel_pow_base    = v_att_len_base + MAX_VOICES;

  buf_baseL = 4000;
  buf_baseR = 4000 + 200000;

  write_pos = 0;
  buf_len = 0;
  safety = 1024;
  last_buf_sec = -1;
  last_srate = -1;

  buf_written = 0;

  next_step_beat = 0;
  last_play_state = -1;

  lp_yL = 0;
  lp_yR = 0;

  // NEW: wet safety state
  wet_prevL = 0;
  wet_prevR = 0;
  head_gain = 1.0; // smoothed
  bal_envL = 0;
  bal_envR = 0;
  out_ceiling = 0.89; // ~ -1 dBFS ceiling to avoid full-scale pops
  mix_s = mix/100.0;
  dry_s = dry/100.0;
  lp_s = hp;
  slew_s = slew;

  pi2 = 2*$pi;
  pi_half = 0.5*$pi;

  function clamp(v, lo, hi) (v < lo ? lo : (v > hi ? hi : v));
  function absf(x) (x < 0 ? -x : x);

  // softer than the cubic clip I used before, and never does harsh “edge crack”
  // x/(1+|x|) saturator
  function softsat(x) local(a)
  (
    a = absf(x);
    x / (1 + a);
  );

  function lp_slider_to_hz(lp_i) local(norm_i)
  (
    lp_i <= 0 ? 0 : (
      norm_i = clamp(lp_i / 200, 0, 1);
      exp(log(20000) + norm_i * (log(20) - log(20000)));
    );
  );

  function step_beats_from_idx(i) local(sb)
  (
    i == 0 ? sb = 4 :
    i == 1 ? sb = 2 :
    i == 2 ? sb = 1 :
    i == 3 ? sb = 0.5 :
    i == 4 ? sb = 0.25 :
             sb = 0.125;
    sb;
  );

  function idx_xy(x,y) (y*GRID_W + x);

  function wrapi(v, m) local(r)
  (
    r = v % m;
    r < 0 ? (r += m);
    r;
  );

  function get_cell(base, x, y) local(xx, yy)
  (
    wrap ? (
      xx = wrapi(x, GRID_W);
      yy = wrapi(y, GRID_H);
      mem[base + idx_xy(xx,yy)];
    ) : (
      (x < 0 || x >= GRID_W || y < 0 || y >= GRID_H) ? 0 : mem[base + idx_xy(x,y)];
    );
  );

  function count_neighbors(base, x, y) local(n)
  (
    n = 0;
    n += get_cell(base, x-1, y-1);
    n += get_cell(base, x,   y-1);
    n += get_cell(base, x+1, y-1);
    n += get_cell(base, x-1, y);
    n += get_cell(base, x+1, y);
    n += get_cell(base, x-1, y+1);
    n += get_cell(base, x,   y+1);
    n += get_cell(base, x+1, y+1);
    n;
  );

  function rand_index(n) local(r)
  (
    r = floor(rand(1) * n);
    clamp(r, 0, n-1);
  );

  function seed_world() local(i, r)
  (
    i=0; loop(GRID_N,
      r = rand(1);
      mem[cur_base+i] = (r < density/100) ? 1 : 0;
      mem[energy_base+i] = 0;
      mem[age_base+i] = 0;
      i+=1;
    );
  );

  function reset_cell_voices() local(i)
  (
    i=0; loop(GRID_N,
      mem[cell_voice_base+i] = -1;
      i+=1;
    );
  );

  function reset_voices() local(v)
  (
    v=0; loop(MAX_VOICES,
      mem[v_active_base+v]=0;
      mem[v_cell_base+v]=-1;
      v+=1;
    );
    reset_cell_voices();
  );

  function count_live_cells(base) local(i, n)
  (
    n = 0;
    i = 0;
    loop(GRID_N,
      n += (mem[base+i] > 0) ? 1 : 0;
      i += 1;
    );
    n;
  );

  function clear_audio_safety_state()
  (
    lp_yL = 0;
    lp_yR = 0;
    wet_prevL = 0;
    wet_prevR = 0;
    head_gain = 1.0;
    bal_envL = 0;
    bal_envR = 0;
  );

  function reset_buffer_state()
  (
    write_pos = 0;
    buf_written = 0;
    reset_voices();
    clear_audio_safety_state();
    next_step_beat = beat_position;
  );

  function update_buf_len() local(want, should_check)
  (
    should_check = (buf_len <= 0) || (buf_sec != last_buf_sec) || (srate != last_srate);
    should_check ? (
      want = floor(buf_sec*srate);
      want < 4410 ? want = 4410;
      want > 180000 ? want = 180000;
      last_buf_sec = buf_sec;
      last_srate = srate;

      (want != buf_len) ? (
        buf_len = want;
        reset_buffer_state();
      );
    );
  );

  function alloc_voice() local(voice_idx, found)
  (
    found = -1;
    voice_idx = 0;
    loop(MAX_VOICES,
      (found < 0 && mem[v_active_base+voice_idx] == 0) ? found = voice_idx;
      voice_idx += 1;
    );
    found;
  );

  function spawn_voice(cell_i, voice_pos, voice_step, loop_samps, att_samps, rel_samps, rel_pow, voice_amp, voice_pan) local(voice_idx)
  (
    voice_idx = alloc_voice();
    voice_idx >= 0 ? (
      mem[v_active_base+voice_idx] = 1;
      mem[v_pos_base+voice_idx] = voice_pos;
      mem[v_step_base+voice_idx] = voice_step;
      mem[v_age_base+voice_idx] = 0;
      mem[v_amp_base+voice_idx] = voice_amp;
      mem[v_pan_base+voice_idx] = voice_pan;
      mem[v_loop_start_base+voice_idx] = voice_pos;
      mem[v_loop_len_base+voice_idx] = loop_samps;
      mem[v_rel_pos_base+voice_idx] = 0;
      mem[v_rel_len_base+voice_idx] = rel_samps;
      mem[v_att_len_base+voice_idx] = att_samps;
      mem[v_rel_pow_base+voice_idx] = rel_pow;
      mem[v_cell_base+voice_idx] = cell_i;
      mem[cell_voice_base+cell_i] = voice_idx;
    );
  );

  function release_voice_for_cell(cell_i) local(voice_idx)
  (
    voice_idx = mem[cell_voice_base+cell_i];
    (voice_idx >= 0) ? (
      mem[cell_voice_base+cell_i] = -1;
      mem[v_active_base+voice_idx] == 1 ? (
        mem[v_active_base+voice_idx] = 2;
        mem[v_rel_pos_base+voice_idx] = 0;
      );
    );
  );

  function process_block_scheduler()
  local(step_beats, m, scan, gmax, loop_samps_base, max_loop, att_ms,
        att_samps_base, rel_samps_base, rel_pow_base, width, step_cap,
        primed, play_now, was_playing, cur_beat, max_steps, spawned,
        grid_x, grid_y, cell_i, alive, nei, next_alive, was_alive, is_alive,
        emit, base_semi, row_semi, pitch_semi, rate, voice_amp, fracx, fracy,
        grid_mid_x, grid_mid_y, grid_den_x, grid_den_y, depth, span, off,
        voice_start, voice_pan)
  (
    update_buf_len();

    step_beats = step_beats_from_idx(step_idx);
    m = mojo/100.0;

    scan = (scan_pct/100.0) * buf_len;
    scan < safety ? scan = safety;

    gmax = grain_ms/1000.0;
    loop_samps_base = floor(gmax * srate);
    loop_samps_base < 64 ? loop_samps_base = 64;

    max_loop = buf_len - safety - 1;
    max_loop < 64 ? max_loop = 64;
    loop_samps_base > max_loop ? loop_samps_base = max_loop;

    att_ms = 2 + 22*m*m;
    att_samps_base = floor(att_ms*0.001*srate);
    att_samps_base < 1 ? att_samps_base = 1;

    rel_samps_base = floor(loop_samps_base * (0.45 + 1.55*m));
    rel_samps_base < 16 ? rel_samps_base = 16;

    rel_pow_base = 1.0 + 1.8*m;

    width = 0.20 + 0.70*m;
    step_cap = clamp(cap, 1, MAX_VOICES);
    grid_mid_x = (GRID_W - 1) * 0.5;
    grid_mid_y = (GRID_H - 1) * 0.5;
    grid_den_x = GRID_W - 1;
    grid_den_y = GRID_H - 1;

    primed = (buf_written >= (safety + loop_samps_base + 2));

    play_now = play_state & 1;
    was_playing = (last_play_state & 1);

    (last_play_state != -1) ? (
      (was_playing && !play_now) ? (
        reset_voices();
        clear_audio_safety_state();
      );
      (!was_playing && play_now) ? (
        next_step_beat = beat_position;
      );
    );

    cur_beat = beat_position;
    last_play_state = play_state;

    // Re-sync on timeline jumps/rewinds so scheduling can't stall silent.
    (play_now && (cur_beat + step_beats < next_step_beat)) ? (
      next_step_beat = cur_beat;
    );

    play_now && primed ? (
      max_steps = 8;
      loop(max_steps,
        (cur_beat < next_step_beat) ? break;

        spawned = 0;

        grid_y = 0;
        loop(GRID_H,
          grid_x = 0;
          loop(GRID_W,
            cell_i = idx_xy(grid_x, grid_y);
            alive = mem[cur_base+cell_i];
            nei = count_neighbors(cur_base, grid_x, grid_y);

            next_alive = 0;
            alive ? (
              (nei == 2 || nei == 3) ? next_alive = 1;
            ) : (
              (nei == 3) ? next_alive = 1;
            );

            mem[nxt_base+cell_i] = next_alive;

            was_alive = alive;
            is_alive = next_alive;

            was_alive && is_alive ? (
              mem[age_base+cell_i] += 1;
              mem[energy_base+cell_i] = 1.0;
            ) :
            (!was_alive && is_alive) ? (
              mem[age_base+cell_i] = 0;
              mem[energy_base+cell_i] = 1.0;
            ) :
            (was_alive && !is_alive) ? (
              mem[age_base+cell_i] = 0;
              mem[energy_base+cell_i] = 0.0;
              release_voice_for_cell(cell_i);
            );

            emit = 0;
            (!was_alive && is_alive) ? emit = 1;

            (is_alive && emit && (spawned < step_cap) && (mem[cell_voice_base+cell_i] < 0)) ? (
              base_semi = (grid_x - grid_mid_x);
              row_semi  = (grid_y - grid_mid_y) * 1.0;
              pitch_semi = (base_semi + 0.6*row_semi) * (0.55 + 0.45*m);
              rate = 2^(pitch_semi/12.0);

              voice_amp = 0.24 * (0.85 + 0.25*(nei/8.0));

              fracx = grid_x/grid_den_x;
              fracy = grid_y/grid_den_y;
              depth = (0.15 + 0.85*m);
              span = scan * depth;

              off = safety + fracx*span + fracy*(0.25*span);

              voice_start = write_pos - off;
              while (voice_start < 0) ( voice_start += buf_len; );
              (voice_start + loop_samps_base >= buf_len) ? ( voice_start = buf_len - loop_samps_base - 2; );
              voice_start < 0 ? voice_start = 0;

              voice_pan = clamp(0.5 + (fracx - 0.5)*width, 0, 1);

              spawn_voice(cell_i, voice_start, rate, loop_samps_base, att_samps_base,
                          rel_samps_base, rel_pow_base, voice_amp, voice_pan);
              spawned += 1;
            );

            grid_x += 1;
          );
          grid_y += 1;
        );

        cell_i = 0;
        loop(GRID_N,
          mem[cur_base+cell_i] = mem[nxt_base+cell_i];
          cell_i += 1;
        );

        next_step_beat += step_beats;

        // True extinction reseeds the Life world, but does not force immediate grains.
        (density > 0 && (count_live_cells(cur_base) == 0)) ? (
          seed_world();
          reset_cell_voices();
        );
      );
    );
  );

  function process_audio_sample()
  local(inL, inR, ctl_a, wetL, wetR, active_cnt, voice_idx, voice_state,
        voice_pos, voice_step, voice_age, loop_samps, loop_start, loop_end,
        rel_pos, rel_len, att_len, rel_pow, voice_amp, voice_pan, att_d, ph,
        env, rel_d, rp, rel_env, ip, fr, ip1, aL, bL, sL, aR, bR, sR, sm,
        gL, gR, loop_fade_samps, dist_start, dist_end, loop_win, target_gain,
        head_a, bal_a, bal_mid, bal_trimL, bal_trimR, lp_hz, lp_a, dL, dR,
        wetMix, dryMix, outL, outR, cid)
  (
    inL = spl0;
    inR = spl1;

    // Safety against NaN/Inf or extreme receive sums entering the grain buffer.
    (inL == inL) ? (inL = clamp(inL, -8, 8);) : (inL = 0;);
    (inR == inR) ? (inR = clamp(inR, -8, 8);) : (inR = 0;);

    ctl_a = exp(-pi2*35/srate);
    mix_s = ctl_a*mix_s + (1.0-ctl_a)*clamp(mix/100.0, 0, 1);
    dry_s = ctl_a*dry_s + (1.0-ctl_a)*clamp(dry/100.0, 0, 1);
    lp_s = ctl_a*lp_s + (1.0-ctl_a)*clamp(hp, 0, 200);
    slew_s = ctl_a*slew_s + (1.0-ctl_a)*clamp(slew, 0, 0.2);

    (!freeze) ? (
      mem[buf_baseL + write_pos] = inL;
      mem[buf_baseR + write_pos] = inR;
      write_pos += 1;
      (write_pos >= buf_len) ? write_pos = 0;
      buf_written < buf_len ? buf_written += 1;
    );

    wetL = 0;
    wetR = 0;
    active_cnt = 0;

    voice_idx = 0;
    loop(MAX_VOICES,
      voice_state = mem[v_active_base+voice_idx];
      voice_state ? (
        active_cnt += 1;

        voice_pos = mem[v_pos_base+voice_idx];
        voice_step = mem[v_step_base+voice_idx];
        voice_age = mem[v_age_base+voice_idx];

        loop_samps = mem[v_loop_len_base+voice_idx];
        loop_start = mem[v_loop_start_base+voice_idx];
        loop_end = loop_start + loop_samps;

        rel_pos = mem[v_rel_pos_base+voice_idx];
        rel_len = mem[v_rel_len_base+voice_idx];
        att_len = mem[v_att_len_base+voice_idx];
        rel_pow = mem[v_rel_pow_base+voice_idx];
        voice_amp = mem[v_amp_base+voice_idx];
        voice_pan = mem[v_pan_base+voice_idx];

        att_d = (att_len > 1) ? att_len : 1;
        ph = voice_age / att_d;
        ph > 1 ? ph = 1;
        env = ph;
        rel_env = 1.0;

        (voice_state == 2) ? (
          rel_d = (rel_len > 1) ? rel_len : 1;
          rp = rel_pos / rel_d;
          rp > 1 ? rp = 1;
          rel_env = 1.0 - rp;
          rel_env < 0 ? rel_env = 0;
          env *= rel_env^rel_pow;
        );

        loop_fade_samps = loop_samps * 0.02;
        loop_fade_samps > 128 ? loop_fade_samps = 128;
        loop_fade_samps < 8 ? loop_fade_samps = 8;
        (loop_fade_samps*2 >= loop_samps) ? loop_fade_samps = loop_samps*0.25;

        dist_start = voice_pos - loop_start;
        dist_end = loop_end - voice_pos;
        loop_win = 1.0;
        dist_start < loop_fade_samps ? (
          loop_win *= 0.5 - 0.5*cos($pi*dist_start/loop_fade_samps);
        );
        dist_end < loop_fade_samps ? (
          loop_win *= 0.5 - 0.5*cos($pi*dist_end/loop_fade_samps);
        );
        env *= loop_win;

        ip = floor(voice_pos);
        fr = voice_pos - ip;

        while (ip >= loop_end) ( ip -= loop_samps; );
        while (ip <  loop_start) ( ip += loop_samps; );

        ip1 = ip + 1;
        (ip1 >= loop_end) ? (ip1 -= loop_samps;);

        ip  >= buf_len ? (ip  -= buf_len;);
        ip1 >= buf_len ? (ip1 -= buf_len;);
        ip  < 0 ? (ip  += buf_len;);
        ip1 < 0 ? (ip1 += buf_len;);

        aL = mem[buf_baseL + ip];
        bL = mem[buf_baseL + ip1];
        sL = aL + (bL - aL)*fr;

        aR = mem[buf_baseR + ip];
        bR = mem[buf_baseR + ip1];
        sR = aR + (bR - aR)*fr;

        sm = 0.70710678*(sL + sR);
        gL = cos(voice_pan*pi_half);
        gR = sin(voice_pan*pi_half);

        wetL += sm * (voice_amp*env) * gL;
        wetR += sm * (voice_amp*env) * gR;

        voice_pos += voice_step;
        while (voice_pos >= loop_end) ( voice_pos -= loop_samps; );
        while (voice_pos <  loop_start) ( voice_pos += loop_samps; );

        voice_age += 1;
        mem[v_pos_base+voice_idx] = voice_pos;
        mem[v_age_base+voice_idx] = voice_age;

        (voice_state == 2) ? (
          rel_pos += 1;
          mem[v_rel_pos_base+voice_idx] = rel_pos;
          (rel_pos >= rel_len || rel_env <= 0.0001) ? (
            mem[v_active_base+voice_idx] = 0;
            cid = mem[v_cell_base+voice_idx];
            (cid >= 0 && (mem[cell_voice_base+cid] == voice_idx)) ? ( mem[cell_voice_base+cid] = -1; );
            mem[v_cell_base+voice_idx] = -1;
          );
        );
      );
      voice_idx += 1;
    );

    target_gain = autohead ? (1.0 / sqrt(1.0 + 0.035*active_cnt)) : 0.55;
    autohead && target_gain < 0.50 ? target_gain = 0.50;
    head_a = exp(-pi2*50/srate);
    head_gain = head_a*head_gain + (1.0-head_a)*target_gain;
    wetL *= head_gain;
    wetR *= head_gain;

    // Keep wide/high-mojo clusters from parking the wet bus on one side.
    bal_a = exp(-pi2*3/srate);
    bal_envL = bal_a*bal_envL + (1.0-bal_a)*absf(wetL);
    bal_envR = bal_a*bal_envR + (1.0-bal_a)*absf(wetR);
    bal_mid = 0.5*(bal_envL + bal_envR);
    bal_mid > 0.000001 ? (
      bal_trimL = sqrt(bal_mid / (bal_envL + 0.000001));
      bal_trimR = sqrt(bal_mid / (bal_envR + 0.000001));
      bal_trimL = clamp(bal_trimL, 0.82, 1.12);
      bal_trimR = clamp(bal_trimR, 0.82, 1.12);
      wetL *= bal_trimL;
      wetR *= bal_trimR;
    );

    // Optional low-pass on wet output, reverse-log amount: 0=open, 200=20 Hz.
    lp_hz = lp_slider_to_hz(lp_s);
    (lp_hz > 0.01) ? (
      lp_a = 1.0 - exp(-pi2*lp_hz/srate);
      lp_yL += lp_a*(wetL - lp_yL);
      lp_yR += lp_a*(wetR - lp_yR);
      wetL = lp_yL;
      wetR = lp_yR;
    ) : (
      lp_yL = wetL;
      lp_yR = wetR;
    );

    // Wet slew limiter: final de-click safety, after the loop-edge window.
    (slew_s > 0.000001) ? (
      dL = wetL - wet_prevL;
      dR = wetR - wet_prevR;

      dL >  slew_s ? wetL = wet_prevL + slew_s;
      dL < -slew_s ? wetL = wet_prevL - slew_s;

      dR >  slew_s ? wetR = wet_prevR + slew_s;
      dR < -slew_s ? wetR = wet_prevR - slew_s;
    );
    wet_prevL = wetL;
    wet_prevR = wetR;

    wetMix = mix_s;
    dryMix = dry_s;

    outL = inL*dryMix + wetL*wetMix;
    outR = inR*dryMix + wetR*wetMix;

    // Safety against any invalid math in edge cases.
    (outL == outL) ? (outL = clamp(outL, -64, 64);) : (outL = 0;);
    (outR == outR) ? (outR = clamp(outR, -64, 64);) : (outR = 0;);

    // Gentle safety saturation and ceiling are final protection, not the click fix.
    outL = softsat(outL);
    outR = softsat(outR);
    outL = clamp(outL, -out_ceiling, out_ceiling);
    outR = clamp(outR, -out_ceiling, out_ceiling);

    spl0 = outL;
    spl1 = outR;
  );

  update_buf_len();
  seed_world();
  reset_voices();
  next_step_beat = beat_position;

////////////////////////////////////////////////////////////////////////////////
// SLIDERS
////////////////////////////////////////////////////////////////////////////////

@slider
  reseed ? (
    seed_world();
    reset_voices();
    reseed=0; slider9=0;
    next_step_beat = beat_position;
  );

