function scaled_velocity(layer_i, base_vel)
(
  clampi(floor(base_vel * layer_velocity_scale(layer_i) * 0.01 + 0.5), 1, 127);
);

function layer_amount(layer_i)
(
  layer_i == LAYER_PRECISION ? precision_amount :
  layer_i == LAYER_RIFF ? riff_amount :
  weight_amount;
);

function frac(x)
(
  x - floor(x);
);

function hash01(a, b, c, d, e) local(v)
(
  v = sin((seed + 1) * 0.071 + a * 12.989 + b * 78.233 + c * 37.719 + d * 19.913 + e * 7.133) * 43758.545;
  frac(v < 0 ? -v : v);
);

function hash_pick(max_count, a, b, c, d, e)
(
  max_count <= 1 ? 0 : floor(hash01(a, b, c, d, e) * max_count);
);

function hash_hit(percent_i, a, b, c, d, e)
(
  hash01(a, b, c, d, e) * 100 < percent_i;
);

function tempo_band_for_bpm(bpm_i)
(
  bpm_i <= 69 ? BAND_A1 :
  bpm_i <= 79 ? BAND_A2 :
  bpm_i <= 89 ? BAND_B1 :
  bpm_i <= 104 ? BAND_B2 :
  bpm_i <= 119 ? BAND_C :
  bpm_i <= 139 ? BAND_D :
  BAND_E;
);

function ms_to_samples(ms_val)
(
  floor(srate * ms_val * 0.001 + 0.5);
);

function bar_class_name(class_i)
(
  class_i == CLASS_MAIN ? sprintf(#class_txt, "main");
  class_i == CLASS_VARIATION ? sprintf(#class_txt, "variation");
  class_i == CLASS_PRE_FILL ? sprintf(#class_txt, "pre_fill");
  class_i == CLASS_FILL ? sprintf(#class_txt, "fill");
  class_i == CLASS_POI_MAIN ? sprintf(#class_txt, "poi_main");
  class_i == CLASS_POI_VARIATION ? sprintf(#class_txt, "poi_variation");
  class_i == CLASS_TURNAROUND ? sprintf(#class_txt, "turnaround");
  class_i == CLASS_LANDING ? sprintf(#class_txt, "landing");
);

function bar_class_legend_name(class_i)
(
  class_i == CLASS_MAIN ? sprintf(#class_txt, "Main");
  class_i == CLASS_VARIATION ? sprintf(#class_txt, "Variation");
  class_i == CLASS_PRE_FILL ? sprintf(#class_txt, "Pre-Fill");
  class_i == CLASS_FILL ? sprintf(#class_txt, "Fill");
  class_i == CLASS_POI_MAIN ? sprintf(#class_txt, "POI Start");
  class_i == CLASS_POI_VARIATION ? sprintf(#class_txt, "POI Flow");
  class_i == CLASS_TURNAROUND ? sprintf(#class_txt, "Turn");
  class_i == CLASS_LANDING ? sprintf(#class_txt, "Landing");
);

function set_bar_class_color(class_i)
(
  class_i == CLASS_MAIN ? gfx_set(0.24, 0.27, 0.33, 1);
  class_i == CLASS_VARIATION ? gfx_set(0.29, 0.32, 0.39, 1);
  class_i == CLASS_PRE_FILL ? gfx_set(0.36, 0.31, 0.18, 1);
  class_i == CLASS_FILL ? gfx_set(0.55, 0.31, 0.17, 1);
  class_i == CLASS_POI_MAIN ? gfx_set(0.18, 0.44, 0.35, 1);
  class_i == CLASS_POI_VARIATION ? gfx_set(0.22, 0.38, 0.32, 1);
  class_i == CLASS_TURNAROUND ? gfx_set(0.63, 0.22, 0.18, 1);
  class_i == CLASS_LANDING ? gfx_set(0.44, 0.45, 0.18, 1);
);

