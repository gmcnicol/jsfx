(
  bar_class[clampi(bar_i, 0, MAX_BARS - 1)];
);

function bar_lead_value(bar_i)
(
  bar_lead_layer[clampi(bar_i, 0, MAX_BARS - 1)];
);

function bar_support_value(bar_i)
(
  bar_support_layer[clampi(bar_i, 0, MAX_BARS - 1)];
);

