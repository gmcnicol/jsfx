(
  bar_cymbal_mode[clampi(bar_i, 0, MAX_BARS - 1)];
);

function bar_halftime_value(bar_i)
(
  bar_halftime[clampi(bar_i, 0, MAX_BARS - 1)];
);

function bar_fill_owner_value(bar_i)
(
  bar_fill_owner[clampi(bar_i, 0, MAX_BARS - 1)];
);

function macro_section_name(section_i)
(
  section_i == MACRO_ESTABLISH ? sprintf(#macro_txt, "establish");
  section_i == MACRO_DEEPEN ? sprintf(#macro_txt, "deepen");
  section_i == MACRO_LIFT ? sprintf(#macro_txt, "lift");
  section_i == MACRO_CREST ? sprintf(#macro_txt, "crest");
  section_i == MACRO_RELEASE ? sprintf(#macro_txt, "release");
  section_i == MACRO_TURNAROUND_ZONE ? sprintf(#macro_txt, "turnaround_zone");
  section_i == MACRO_LANDING ? sprintf(#macro_txt, "landing");
);

function macro_section_intensity(section_i)
(
  section_i == MACRO_ESTABLISH ? 0.22 :
  section_i == MACRO_DEEPEN ? 0.38 :
  section_i == MACRO_LIFT ? 0.58 :
  section_i == MACRO_CREST ? 0.84 :
  section_i == MACRO_RELEASE ? 0.44 :
  section_i == MACRO_TURNAROUND_ZONE ? 0.70 :
  0.56;
);

function macro_section_value(bar_i)
(
  bar_macro_section[clampi(bar_i, 0, MAX_BARS - 1)];
);

function recurrence_window_for_bars(total_bars_i)
(
  total_bars_i <= 8 ? 4 :
  total_bars_i <= 16 ? 8 :
  total_bars_i <= 32 ? 16 :
  total_bars_i <= 64 ? 32 :
  total_bars_i <= 128 ? 64 :
  128;
);

function choose_poi_lead(tempo_band_i) local(score_procession, score_weight, score_patient)
(
  score_patient = precision_amount + (tempo_band_i <= BAND_A2 ? 10 : 2) + hash01(80, tempo_band_i, planned_total_bars, 0, 0) * 8;
  score_procession = riff_amount + (tempo_band_i <= BAND_B1 ? 20 : tempo_band_i == BAND_B2 ? 10 : 2) + hash01(81, tempo_band_i, planned_total_bars, 0, 0) * 10;
  score_weight = weight_amount + (tempo_band_i >= BAND_B2 ? 14 : -6) + tom_motion * 0.22 + hash01(82, tempo_band_i, planned_total_bars, 0, 0) * 10;

  tempo_band_i <= BAND_A2 ? (
    score_procession >= score_patient ? LAYER_PROCESSION : LAYER_PATIENT;
  ) :
  tempo_band_i == BAND_B1 ? (
    score_weight > (score_procession + 10) ? LAYER_WEIGHT : LAYER_PROCESSION;
  ) :
  tempo_band_i == BAND_B2 || tempo_band_i == BAND_C ? (
    score_weight > score_procession ? LAYER_WEIGHT : LAYER_PROCESSION;
  ) : (
    score_weight > (score_patient - 6) ? LAYER_WEIGHT : LAYER_PATIENT;
  );
);

function choose_primary_lead(class_i, macro_i, tempo_band_i, bar_i) local(score_p, score_r, score_w, best_layer, best_score)
(
  score_p = precision_amount + layer_density(LAYER_PATIENT) * 0.30 + repetition_bias * 0.18 + 18;
  score_r = riff_amount + layer_density(LAYER_PROCESSION) * 0.26 + poi_intensity * 0.12;
  score_w = weight_amount + layer_density(LAYER_WEIGHT) * 0.28 + tom_motion * 0.20;

  macro_i == MACRO_ESTABLISH ? (score_p += 16; score_r -= 4; score_w -= 10;);
  macro_i == MACRO_DEEPEN ? (score_p += 8; score_r += 8; score_w += (tempo_band_i >= BAND_B1 ? 4 : -6););
  macro_i == MACRO_LIFT ? (score_r += 8; score_w += 10;);
  macro_i == MACRO_CREST ? (score_r += (tempo_band_i <= BAND_B1 ? 16 : 4); score_w += (tempo_band_i >= BAND_B2 ? 18 : 8););
  macro_i == MACRO_RELEASE ? (score_p += 10; score_r -= 2; score_w -= 6;);
  macro_i == MACRO_TURNAROUND_ZONE ? (score_p += 6; score_r += 2; score_w += 4;);

  class_i == CLASS_POI_MAIN || class_i == CLASS_POI_VARIATION ? (
    best_layer = planned_poi_lead;
  ) : (
    class_i == CLASS_LANDING ? (
      best_layer = planned_landing_mode == LANDING_LOW_TOM ? LAYER_WEIGHT : LAYER_PATIENT;
    ) : (
      class_i == CLASS_TURNAROUND ? (
        best_layer =
          tempo_band_i <= BAND_A2 ? (hash_hit(58, bar_i, 55, 1, 0, 0) ? LAYER_PROCESSION : LAYER_PATIENT) :
          tempo_band_i <= BAND_B1 ? (hash_hit(56, bar_i, 56, 1, 0, 0) ? LAYER_PROCESSION : LAYER_WEIGHT) :
          tempo_band_i <= BAND_C ? (tom_motion + weight_amount > riff_amount + 12 ? LAYER_WEIGHT : planned_poi_lead) :
          (hash_hit(58, bar_i, 57, 1, 0, 0) ? LAYER_WEIGHT : LAYER_PATIENT);
      ) : (
        tempo_band_i <= BAND_A2 ? score_r -= 6;
        tempo_band_i >= BAND_D ? score_r -= 3;
        tempo_band_i >= BAND_E ? score_w += 10;

        best_layer = LAYER_PATIENT;
        best_score = score_p;
        score_r > best_score ? (best_layer = LAYER_PROCESSION; best_score = score_r;);
        score_w > best_score ? (best_layer = LAYER_WEIGHT; best_score = score_w;);
      );
    );
  );
  best_layer;
);

function choose_support_layer(lead_layer_i, tempo_band_i, macro_i) local(score_p, score_r, score_w, best_layer, best_score)
(
  score_p = precision_amount + 12;
  score_r = riff_amount + 8 + (tempo_band_i <= BAND_B1 ? 8 : 0);
  score_w = weight_amount + 8 + (tempo_band_i >= BAND_B2 ? 8 : -6);

  macro_i == MACRO_ESTABLISH ? (score_p += 6; score_r += 4; score_w -= 8;);
  macro_i == MACRO_DEEPEN ? (score_r += 6; score_w += 2;);
  macro_i == MACRO_LIFT ? (score_r += 2; score_w += 8;);
  macro_i == MACRO_CREST ? (score_r += 6; score_w += 10;);
  macro_i == MACRO_RELEASE ? (score_p += 8; score_r -= 2; score_w -= 6;);

  lead_layer_i == LAYER_PRECISION ? score_p = -999;
  lead_layer_i == LAYER_RIFF ? score_r = -999;
  lead_layer_i == LAYER_WEIGHT ? score_w = -999;

  best_layer = LAYER_PRECISION;
  best_score = score_p;
  score_r > best_score ? (best_layer = LAYER_RIFF; best_score = score_r;);
  score_w > best_score ? (best_layer = LAYER_WEIGHT; best_score = score_w;);
  best_layer;
);

function bar_uses_poi_lead(bar_i) local(i, start_i, hit_i)
(
  hit_i = 0;
  i = 0;
  while ((i < planned_poi_count) && !hit_i) (
    start_i = poi_start_bar[i];
    start_i >= 0 && bar_i >= start_i && bar_i < (start_i + poi_span_bars[i]) ? hit_i = 1;
    i += 1;
  );
  hit_i;
);

function choose_fill_owner(class_i, tempo_band_i, bar_i) local(fill_owner_i)
(
  class_i == CLASS_TURNAROUND ? (
    fill_owner_i =
      tempo_band_i <= BAND_A2 ? (hash_hit(58, bar_i, 55, 1, 0, 0) ? LAYER_PROCESSION : LAYER_PATIENT) :
      tempo_band_i <= BAND_B1 ? (hash_hit(56, bar_i, 56, 1, 0, 0) ? LAYER_PROCESSION : LAYER_WEIGHT) :
      tempo_band_i <= BAND_C ? (tom_motion + weight_amount > riff_amount + 12 ? LAYER_WEIGHT : planned_poi_lead) :
      (hash_hit(58, bar_i, 57, 1, 0, 0) ? LAYER_WEIGHT : LAYER_PATIENT);
  ) : (
    class_i == CLASS_FILL ? (
      fill_owner_i = bar_uses_poi_lead(bar_i) ? planned_poi_lead :
        tempo_band_i <= BAND_B1 ? LAYER_PROCESSION :
        (tom_motion + percussion_amount > repetition_bias + 5 ? LAYER_WEIGHT : LAYER_PATIENT);
    ) : (
      fill_owner_i = -1;
    );
  );
  fill_owner_i;
);

function choose_cymbal_mode(class_i, lead_layer_i, tempo_band_i, bar_i) local(mode_i)
(
  force_cymbal_mode == 1 ? mode_i = CLOCK_HAT :
  force_cymbal_mode == 2 ? mode_i = CLOCK_OPEN :
  force_cymbal_mode == 3 ? mode_i = CLOCK_RIDE :
  force_cymbal_mode == 4 ? mode_i = CLOCK_TOM :
  (
    class_i == CLASS_LANDING ? (
      mode_i = planned_landing_mode == LANDING_LOW_TOM ? CLOCK_TOM : CLOCK_RIDE;
    ) :
    class_i == CLASS_TURNAROUND ? (
      mode_i = planned_landing_mode == LANDING_LOW_TOM ? CLOCK_TOM : CLOCK_OPEN;
    ) :
    class_i == CLASS_POI_MAIN ? (
      lead_layer_i == LAYER_PATIENT ? mode_i = cymbal_wash > 56 ? CLOCK_RIDE : CLOCK_OPEN;
      lead_layer_i == LAYER_PROCESSION ? mode_i = tempo_band_i <= BAND_B1 ? CLOCK_SPARSE : CLOCK_RIDE;
      lead_layer_i == LAYER_WEIGHT ? mode_i = tempo_band_i <= BAND_B1 ? CLOCK_TOM : (cymbal_wash > 58 ? CLOCK_RIDE : CLOCK_TOM);
    ) : (
      tempo_band_i == BAND_A1 ? mode_i = cymbal_wash > 64 ? CLOCK_SPARSE : CLOCK_HAT :
      tempo_band_i == BAND_A2 ? mode_i = cymbal_wash > 58 ? CLOCK_OPEN : CLOCK_HAT :
      tempo_band_i == BAND_B1 ? mode_i = lead_layer_i == LAYER_WEIGHT ? CLOCK_TOM : (cymbal_wash > 52 ? CLOCK_RIDE : CLOCK_HAT) :
      tempo_band_i == BAND_B2 ? mode_i = lead_layer_i == LAYER_WEIGHT ? CLOCK_TOM : (cymbal_wash > 58 ? CLOCK_RIDE : CLOCK_OPEN) :
      tempo_band_i == BAND_C ? mode_i = lead_layer_i == LAYER_WEIGHT ? CLOCK_TOM : (cymbal_wash > 62 ? CLOCK_RIDE : CLOCK_OPEN) :
      tempo_band_i == BAND_D ? mode_i = lead_layer_i == LAYER_WEIGHT ? CLOCK_TOM : CLOCK_RIDE :
      mode_i = lead_layer_i == LAYER_WEIGHT ? CLOCK_TOM : CLOCK_RIDE;
    );
  );
  mode_i;
);

function default_poi_start_for_total(total_i)
(
  total_i == 8 ? 4 :
  total_i == 16 ? 11 :
  total_i == 32 ? 21 :
  total_i == 64 ? 45 :
  total_i == 128 ? 93 :
  total_i == 256 ? 189 :
  0;
);

function plan_poi_starts() local(i, default_start_i, span_start_i, span_end_i, min_gap_i, total_span_i, slack_i, slack_prev_i, slack_now_i, current_i, total_required_i)
(
  i = 0;
  while (i < MAX_POIS) (
    poi_start_bar[i] = -1;
    poi_span_bars[i] = 0;
    i += 1;
  );

  planned_poi_count <= 0 ? (
    planned_poi_start = 0;
  ) : (
    total_required_i = 0;
    i = 0;
    while (i < planned_poi_count) (
      poi_span_bars[i] = poi_length_for_slot(i);
      total_required_i += poi_span_bars[i];
      i += 1;
    );

    default_start_i = default_poi_start_for_total(planned_total_bars);
    default_start_i + poi_span_bars[0] > planned_turnaround_bar ? default_start_i = max(0, planned_turnaround_bar - poi_span_bars[0]);

    planned_poi_count == 1 ? (
      poi_start_bar[0] = default_start_i;
      planned_poi_start = default_start_i;
    ) : (
      span_start_i = planned_total_bars <= 16 ? max(1, floor(planned_total_bars * 0.25)) : max(2, floor(planned_total_bars * 0.18));
      span_end_i = planned_turnaround_bar;
      min_gap_i = 2;
      total_required_i += min_gap_i * max(planned_poi_count - 1, 0);
      total_span_i = max(0, span_end_i - span_start_i);
      slack_i = max(0, total_span_i - total_required_i);
      current_i = span_start_i;
      slack_prev_i = 0;
      i = 0;
      while (i < planned_poi_count) (
        slack_now_i = floor(slack_i * (i + 1) / (planned_poi_count + 1));
        current_i += slack_now_i - slack_prev_i;
        poi_start_bar[i] = current_i;
        current_i += poi_span_bars[i] + min_gap_i;
        slack_prev_i = slack_now_i;
        i += 1;
      );
      planned_poi_start = poi_start_bar[0];
    );
    planned_poi_bars = poi_span_bars[0];
  );
);

function poi_class_for_bar(bar_i) local(i, start_i, class_i)
(
  class_i = -1;
  i = 0;
  while ((i < planned_poi_count) && (class_i < 0)) (
    start_i = poi_start_bar[i];
    start_i >= 0 && bar_i >= start_i && bar_i < (start_i + poi_span_bars[i]) ? (
      class_i = bar_i == start_i ? CLASS_POI_MAIN : CLASS_POI_VARIATION;
    );
    i += 1;
  );
  class_i;
);

function bar_builds_to_poi(bar_i) local(i, start_i, hit_i)
(
  hit_i = 0;
  i = 0;
  while ((i < planned_poi_count) && !hit_i) (
    start_i = poi_start_bar[i];
    start_i > 0 && bar_i == (start_i - 1) ? hit_i = 1;
    i += 1;
  );
  hit_i;
);

function class_is_poi_area(class_i)
(
  class_i == CLASS_PRE_FILL || class_i == CLASS_POI_MAIN || class_i == CLASS_POI_VARIATION;
);

function class_is_special_entry_target(class_i)
(
  class_i == CLASS_FILL || class_is_poi_area(class_i);
);

function class_is_special_exit_source(class_i)
(
  class_i == CLASS_FILL || class_is_poi_area(class_i);
);

function bar_needs_transition_opening_hit(bar_i) local(class_i, prev_class_i, hit_i)
(
  hit_i = 0;
  bar_i > 0 ? (
    class_i = bar_class_value(bar_i);
    prev_class_i = bar_class_value(bar_i - 1);
    ((prev_class_i == CLASS_MAIN || prev_class_i == CLASS_VARIATION) && class_is_special_entry_target(class_i)) ? hit_i = 1;
    !hit_i && class_i == CLASS_MAIN && class_is_special_exit_source(prev_class_i) ? hit_i = 1;
  );
  hit_i;
);

function pick_transition_opening_layer(primary_i, secondary_i) local(owner_i)
(
  owner_i = primary_i;
  layer_can_emit(primary_i) ? owner_i = primary_i :
  layer_can_emit(secondary_i) ? owner_i = secondary_i :
  layer_can_emit(LAYER_PATIENT) ? owner_i = LAYER_PATIENT :
  layer_can_emit(LAYER_PROCESSION) ? owner_i = LAYER_PROCESSION :
  owner_i = LAYER_WEIGHT;
  owner_i;
);

function transition_opening_owner(bar_i) local(class_i, prev_class_i, lead_i, support_i, fill_owner_i, prev_fill_owner_i, owner_i)
(
  class_i = bar_class_value(bar_i);
  prev_class_i = bar_i > 0 ? bar_class_value(bar_i - 1) : CLASS_MAIN;
  lead_i = bar_lead_value(bar_i);
  support_i = bar_support_value(bar_i);
  fill_owner_i = bar_fill_owner_value(bar_i);
  prev_fill_owner_i = bar_i > 0 ? bar_fill_owner_value(bar_i - 1) : -1;

  owner_i = lead_i;

  class_i == CLASS_FILL ? (
    owner_i = fill_owner_i >= 0 ? fill_owner_i : lead_i;
    owner_i = pick_transition_opening_layer(owner_i, support_i);
  ) :
  class_is_poi_area(class_i) ? (
    owner_i = fill_owner_i >= 0 ? fill_owner_i : planned_poi_lead;
    owner_i = pick_transition_opening_layer(owner_i, lead_i == owner_i ? support_i : lead_i);
  ) :
  class_i == CLASS_MAIN && class_is_special_exit_source(prev_class_i) ? (
    owner_i = prev_fill_owner_i >= 0 ? prev_fill_owner_i : lead_i;
    owner_i = pick_transition_opening_layer(lead_i, owner_i);
  ) :
  owner_i = pick_transition_opening_layer(lead_i, support_i);

  owner_i;
);

function ride_uses_normal_time_override(bar_i) local(last_poi_i, last_poi_end_i)
(
  planned_total_bars >= 64 && planned_poi_count > 0 ? (
    last_poi_i = planned_poi_count - 1;
    last_poi_end_i = poi_start_bar[last_poi_i] + poi_span_bars[last_poi_i];
    bar_i >= last_poi_end_i;
  ) : 0;
);

function class_halftime_value(class_i)
(
  class_i == CLASS_MAIN ? main_halftime :
  class_i == CLASS_VARIATION ? variation_halftime :
  class_i == CLASS_PRE_FILL ? poi_halftime :
  class_i == CLASS_FILL ? poi_halftime :
  class_i == CLASS_POI_MAIN ? poi_halftime :
  class_i == CLASS_POI_VARIATION ? poi_halftime :
  class_i == CLASS_TURNAROUND ? poi_halftime :
  0;
);

function plan_halftime_section() local(bar_i)
(
  bar_i = 0;
  while (bar_i < planned_total_bars) (
    bar_halftime[bar_i] = class_halftime_value(bar_class[bar_i]);
    bar_i += 1;
  );
);

function choose_loop_pickup() local(score_i)
(
  score_i = 0;
  bar_lead_layer[0] == LAYER_PRECISION ? score_i += 1;
  bar_cymbal_mode[0] == CLOCK_RIDE ? score_i += 1;
  planned_tempo_band >= BAND_C ? score_i += 1;
  score_i >= 2 ? 1 : 0;
);

function choose_envelope_shape(layer_i, total_bars_i) local(shape_i)
(
  layer_i == LAYER_PATIENT ? (
    shape_i = total_bars_i >= 64 && dynamic_lift > 62 ? ENV_RISE_HOLD : ENV_FLAT_ANCHOR;
  ) :
  layer_i == LAYER_PROCESSION ? (
    shape_i = total_bars_i >= 128 && hash_hit(50, total_bars_i, layer_i, 84, 0, 0) ? ENV_RISE_FALL_RISE : ENV_SLOW_RISE;
  ) : (
    shape_i = total_bars_i >= 64 ? (late_bloom_bias >= 50 ? ENV_LATE_BLOOM : ENV_CREST_RELEASE) : ENV_SLOW_RISE;
  );
  shape_i;
);

function macro_section_for_bar(bar_i) local(sec_i)
(
  sec_i = MACRO_ESTABLISH;
  planned_total_bars == 4 ? (
    bar_i < 2 ? sec_i = MACRO_ESTABLISH :
    bar_i == 2 ? sec_i = MACRO_LIFT :
    sec_i = MACRO_TURNAROUND_ZONE;
  ) :
  planned_total_bars == 8 ? (
    bar_i < 4 ? sec_i = MACRO_ESTABLISH :
    bar_i < 6 ? sec_i = MACRO_LIFT :
    bar_i < 7 ? sec_i = MACRO_RELEASE :
    sec_i = MACRO_TURNAROUND_ZONE;
  ) :
  planned_total_bars == 16 ? (
    bar_i < 4 ? sec_i = MACRO_ESTABLISH :
    bar_i < 8 ? sec_i = MACRO_DEEPEN :
    bar_i < 12 ? sec_i = MACRO_CREST :
    bar_i < 15 ? sec_i = MACRO_RELEASE :
    sec_i = MACRO_TURNAROUND_ZONE;
  ) :
  planned_total_bars == 32 ? (
    bar_i < 8 ? sec_i = MACRO_ESTABLISH :
    bar_i < 16 ? sec_i = MACRO_DEEPEN :
    bar_i < 24 ? sec_i = MACRO_CREST :
    bar_i < 30 ? sec_i = MACRO_RELEASE :
    bar_i < 31 ? sec_i = MACRO_TURNAROUND_ZONE :
    sec_i = MACRO_LANDING;
  ) :
  planned_total_bars == 64 ? (
    bar_i < 16 ? sec_i = MACRO_ESTABLISH :
    bar_i < 32 ? sec_i = MACRO_DEEPEN :
    bar_i < 48 ? sec_i = MACRO_LIFT :
    bar_i < 62 ? sec_i = MACRO_RELEASE :
    bar_i < 63 ? sec_i = MACRO_TURNAROUND_ZONE :
    sec_i = MACRO_LANDING;
  ) :
  planned_total_bars == 128 ? (
    bar_i < 32 ? sec_i = MACRO_ESTABLISH :
    bar_i < 64 ? sec_i = MACRO_DEEPEN :
    bar_i < 96 ? sec_i = MACRO_LIFT :
    bar_i < 120 ? sec_i = MACRO_CREST :
    bar_i < 127 ? sec_i = MACRO_TURNAROUND_ZONE :
    sec_i = MACRO_LANDING;
  ) : (
    bar_i < 64 ? sec_i = MACRO_ESTABLISH :
    bar_i < 128 ? sec_i = MACRO_DEEPEN :
    bar_i < 192 ? sec_i = MACRO_LIFT :
    bar_i < 240 ? sec_i = MACRO_CREST :
    bar_i < 255 ? sec_i = MACRO_TURNAROUND_ZONE :
    sec_i = MACRO_LANDING;
  );
  sec_i;
);

function plan_form() local(bar_i, macro_i, phrase_i, class_i, is_long_form, variation_chance_i, fill_chance_i, poi_class_i, builds_to_poi_i)
(
  planned_total_bars = snap_total_bars(total_bars);
  planned_effective_tempo = tempo_reference > 0 ? tempo_reference : max(tempo, 1);
  planned_tempo_band = tempo_band_for_bpm(planned_effective_tempo);
  planned_recurrence_window = recurrence_window_for_bars(planned_total_bars);
  planned_turnaround_zone_bars = snap_turnaround_zone_length(turnaround_zone_length);
  is_long_form = planned_total_bars >= 32;
  is_long_form ? (
    planned_turnaround_bar = planned_total_bars - 2;
    planned_landing_bar = planned_total_bars - 1;
    planned_turnaround_zone_bars > (planned_total_bars - 1) ? planned_turnaround_zone_bars = planned_total_bars - 1;
  ) : (
    planned_turnaround_bar = planned_total_bars - 1;
    planned_landing_bar = -1;
    planned_turnaround_zone_bars = 1;
  );

  planned_poi_bars = planned_total_bars >= 8 ? snap_poi_length(poi_length, planned_total_bars) : 0;
  planned_total_bars == 8 && planned_poi_bars > 4 ? planned_poi_bars = 4;
  planned_poi_count = planned_poi_bars > 0 ? snap_poi_count(poi_count, planned_total_bars, planned_poi_bars) : 0;
  planned_landing_mode = (planned_tempo_band <= BAND_B1 || hash_hit(46, planned_total_bars, planned_tempo_band, 89, 0, 0)) ? LANDING_LOW_TOM : LANDING_KICK_CRASH;
  planned_poi_lead = planned_poi_bars > 0 ? choose_poi_lead(planned_tempo_band) : LAYER_PATIENT;
  plan_poi_starts();

  layer_envelope_shape[LAYER_PATIENT] = choose_envelope_shape(LAYER_PATIENT, planned_total_bars);
  layer_envelope_shape[LAYER_PROCESSION] = choose_envelope_shape(LAYER_PROCESSION, planned_total_bars);
  layer_envelope_shape[LAYER_WEIGHT] = choose_envelope_shape(LAYER_WEIGHT, planned_total_bars);

  bar_i = 0;
  while (bar_i < MAX_BARS) (
    bar_class[bar_i] = CLASS_MAIN;
    bar_lead_layer[bar_i] = LAYER_PATIENT;
    bar_support_layer[bar_i] = LAYER_PROCESSION;
    bar_cymbal_mode[bar_i] = CLOCK_HAT;
    bar_halftime[bar_i] = 0;
    bar_fill_owner[bar_i] = -1;
    bar_turn_pickup[bar_i] = 0;
    bar_macro_section[bar_i] = MACRO_ESTABLISH;
    bar_i += 1;
  );

  bar_i = 0;
  while (bar_i < planned_total_bars) (
    macro_i = macro_section_for_bar(bar_i);
    bar_macro_section[bar_i] = macro_i;
    phrase_i = bar_i % 4;
    class_i = CLASS_MAIN;
    poi_class_i = poi_class_for_bar(bar_i);
    builds_to_poi_i = bar_builds_to_poi(bar_i);
    variation_chance_i = planned_total_bars <= 16 ? min(5, max(1, floor((100 - repetition_bias) * 0.08))) :
      min(16, max(4, floor((100 - repetition_bias) * 0.20)));
    fill_chance_i = planned_total_bars <= 16 ? fill_frequency * 0.08 :
      fill_frequency * 0.22;

    is_long_form && bar_i == planned_landing_bar ? class_i = CLASS_LANDING :
    bar_i == planned_turnaround_bar ? class_i = CLASS_TURNAROUND :
    poi_class_i >= 0 ? class_i = poi_class_i :
    builds_to_poi_i ? class_i = CLASS_PRE_FILL :
    is_long_form && bar_i >= (planned_turnaround_bar - planned_turnaround_zone_bars + 1) && bar_i < planned_turnaround_bar ? (
      class_i = (planned_turnaround_bar - bar_i) <= 1 ? CLASS_PRE_FILL : CLASS_VARIATION;
    ) :
    planned_total_bars == 4 ? (
      bar_i == 1 ? class_i = CLASS_VARIATION;
      bar_i == 2 ? class_i = CLASS_PRE_FILL;
    ) :
    planned_total_bars == 8 ? (
      bar_i == 1 || bar_i == 3 ? class_i = CLASS_VARIATION;
      bar_i == 6 ? class_i = CLASS_FILL;
    ) :
    planned_total_bars == 16 ? (
      bar_i == 3 || bar_i == 13 ? class_i = CLASS_VARIATION;
    ) :
    (
      phrase_i == 3 ? class_i = CLASS_VARIATION;
      hash_hit(variation_chance_i, bar_i, planned_total_bars, 96, 0, 0) && phrase_i != 0 ? class_i = CLASS_VARIATION;
      class_i == CLASS_VARIATION && hash_hit(fill_chance_i, bar_i, 97, 0, 0, 0) && phrase_i == 3 ? class_i = CLASS_FILL;
    );

    bar_class[bar_i] = class_i;
    bar_lead_layer[bar_i] = choose_primary_lead(class_i, macro_i, planned_tempo_band, bar_i);
    bar_support_layer[bar_i] = choose_support_layer(bar_lead_layer[bar_i], planned_tempo_band, macro_i);
    bar_halftime[bar_i] = 0;
    bar_cymbal_mode[bar_i] = choose_cymbal_mode(class_i, bar_lead_layer[bar_i], planned_tempo_band, bar_i);

    class_i == CLASS_FILL || class_i == CLASS_TURNAROUND ? (
      bar_fill_owner[bar_i] = choose_fill_owner(class_i, planned_tempo_band, bar_i);
    );
    class_i == CLASS_PRE_FILL ? (
      builds_to_poi_i ? bar_fill_owner[bar_i] = planned_poi_lead :
        hash_hit(fill_frequency * 0.45, bar_i, 98, 0, 0, 0) ? bar_fill_owner[bar_i] = choose_fill_owner(CLASS_FILL, planned_tempo_band, bar_i);
    );
    class_i == CLASS_POI_VARIATION && hash_hit(poi_intensity * 0.35, bar_i, 99, planned_poi_lead, 0, 0) ? bar_fill_owner[bar_i] = planned_poi_lead;

    (class_i == CLASS_TURNAROUND || class_i == CLASS_LANDING) ? bar_turn_pickup[bar_i] = choose_loop_pickup();
    bar_i += 1;
  );

  plan_halftime_section();
  planned_turnaround_type = choose_fill_owner(CLASS_TURNAROUND, planned_tempo_band, planned_turnaround_bar);
  form_dirty = 0;
);

function role_timing_ms(layer_i, role_i, bar_i, step_i, cycle_bar_i, sub_i) local(base_ms, lag_ms, class_i, tight_amt)
(
  base_ms = planned_tempo_band >= BAND_D ? 4 :
    planned_tempo_band >= BAND_B2 ? 6 :
    planned_tempo_band >= BAND_A2 ? 8 :
    10;
  tight_amt = clampi(groove_tightness, 0, 100);
  lag_ms = base_ms * (100 - tight_amt) * 0.008;
  cycle_bar_i >= 0 ? class_i = bar_class_value(cycle_bar_i) : class_i = CLASS_MAIN;

  layer_i == LAYER_PATIENT ? lag_ms *= 0.40;
  layer_i == LAYER_PROCESSION ? lag_ms *= 0.82;
  layer_i == LAYER_WEIGHT ? lag_ms *= 1.08;

  role_i == 0 ? lag_ms *= 0.55;
  role_i == 1 ? lag_ms *= 0.70;
  role_i >= 7 && role_i <= 10 ? lag_ms *= 1.18;

  class_i == CLASS_TURNAROUND && step_i >= 12 ? lag_ms *= 0.62;
  class_i == CLASS_POI_MAIN && layer_i == bar_lead_value(cycle_bar_i) ? lag_ms *= 0.80;
  sub_i ? lag_ms += base_ms * 0.15;

  max(0, lag_ms);
);

function queue_note_off(chan_i, note_i, abs_time_i) local(next_tail)
(
  queue_note_off = 0;
  next_tail = queue_tail + 1;
  next_tail >= QUEUE_SIZE ? next_tail = 0;
  next_tail != queue_head ? (
    off_time[queue_tail] = abs_time_i;
    off_chan[queue_tail] = chan_i;
    off_note[queue_tail] = note_i;
    queue_tail = next_tail;
    queue_note_off = 1;
  );
);

function flush_all_note_offs() local(i, repeat_count, note_i, chan_i, guard, repeat_guard)
(
  guard = 0;
  while ((queue_head != queue_tail) && (guard < QUEUE_SIZE)) (
    queue_head += 1;
    queue_head >= QUEUE_SIZE ? queue_head = 0;
    guard += 1;
  );
  queue_head = 0;
  queue_tail = 0;

  i = 0;
  while (i < (16 * 128)) (
    repeat_count = active_note_count[i];
    note_i = i % 128;
    chan_i = floor(i / 128);
    repeat_guard = 0;
    while ((repeat_count > 0) && (repeat_guard < 64)) (
      midisend(0, 128 | chan_i, note_i);
      repeat_count -= 1;
      repeat_guard += 1;
    );
    active_note_count[i] = 0;
    i += 1;
  );
);

function flush_due_note_offs() local(rel_spl, chan_i, note_i, active_idx, guard)
(
  guard = 0;
  while (
    (queue_head != queue_tail) &&
    (off_time[queue_head] < block_abs_end) &&
    (guard < QUEUE_SIZE)
  ) (
    rel_spl = off_time[queue_head] - block_abs_start;
    rel_spl < 0 ? rel_spl = 0;
    rel_spl >= samplesblock ? rel_spl = samplesblock - 1;

    chan_i = off_chan[queue_head];
    note_i = off_note[queue_head];
    midisend(rel_spl, 128 | chan_i, note_i);

    active_idx = active_note_index(chan_i, note_i);
    active_note_count[active_idx] > 0 ? active_note_count[active_idx] -= 1;

    queue_head += 1;
    queue_head >= QUEUE_SIZE ? queue_head = 0;
    guard += 1;
  );
);

function trigger_role(layer_i, role_i, base_vel, rel_offset, bar_i, step_i, cycle_bar_i, sub_i) local(pad_i, note_i, chan_i, vel_i, note_off_at, active_idx, hit_offset, timing_spl, sub_offset)
(
  base_vel > 0 ? (
    pad_i = get_pad_for_role(layer_i, role_i);
    note_i = get_pad_note(layer_i, pad_i);
    chan_i = layer_channel_zero(layer_i);
    vel_i = scaled_velocity(layer_i, base_vel);
    timing_spl = ms_to_samples(role_timing_ms(layer_i, role_i, bar_i, step_i, cycle_bar_i, sub_i));
    sub_offset = sub_i ? floor(step_samples * 0.5 + 0.5) : 0;
    hit_offset = rel_offset + sub_offset + timing_spl;
    hit_offset < 0 ? hit_offset = 0;
    hit_offset >= samplesblock ? hit_offset = samplesblock - 1;
    note_off_at = block_abs_start + hit_offset + note_len_samples;

    queue_note_off(chan_i, note_i, note_off_at) ? (
      midisend(hit_offset, 144 | chan_i, note_i | (vel_i * 256));
      layer_activity[layer_pad_index(layer_i, pad_i)] = min(1.4, layer_activity[layer_pad_index(layer_i, pad_i)] + 0.65);
      slot_activity[pad_i] = min(1.6, slot_activity[pad_i] + 0.55);
      active_idx = active_note_index(chan_i, note_i);
      active_note_count[active_idx] += 1;
    );
  );
);

function queue_ui_audition(layer_i, pad_i)
(
  ui_audition_pending = 1;
  ui_audition_layer = layer_i;
  ui_audition_pad = pad_i;
);

function is_downbeat_step(step_i)
(
  (step_i % 4) == 0;
);

function is_eighth_step(step_i)
(
  (step_i % 2) == 0;
);

function ride_clock_halftime_value(bar_i, halftime_i)
(
  ride_uses_normal_time_override(bar_i) ? 0 : halftime_i;
);

function is_ride_clock_step(bar_i, step_i, halftime_i)
(
  ride_clock_halftime_value(bar_i, halftime_i) ? is_downbeat_step(step_i) : is_eighth_step(step_i);
);

function is_backbeat_step(step_i, halftime_i)
(
  halftime_i ? (step_i == 8) : ((step_i == 4) || (step_i == 12));
);

function anchor_backbeat_step(halftime_i)
(
  halftime_i ? 8 : 12;
);

function patient_motif_step(motif_i, step_i)
(
  motif_i == 0 ? ((step_i == 0) || (step_i == 8)) :
  motif_i == 1 ? ((step_i == 0) || (step_i == 7) || (step_i == 8)) :
  motif_i == 2 ? ((step_i == 0) || (step_i == 6) || (step_i == 8) || (step_i == 10)) :
  ((step_i == 0) || (step_i == 8) || (step_i == 11) || (step_i == 14));
);

function procession_motif_step(motif_i, step_i)
(
  motif_i == 0 ? ((step_i == 4) || (step_i == 12)) :
  motif_i == 1 ? ((step_i == 0) || (step_i == 4) || (step_i == 8) || (step_i == 12)) :
  motif_i == 2 ? ((step_i == 2) || (step_i == 6) || (step_i == 10) || (step_i == 14)) :
  ((step_i == 0) || (step_i == 3) || (step_i == 8) || (step_i == 11) || (step_i == 15));
);

function weight_motif_step(motif_i, step_i)
(
  motif_i == 0 ? ((step_i == 0) || (step_i == 8)) :
  motif_i == 1 ? ((step_i == 0) || (step_i == 4) || (step_i == 8) || (step_i == 12)) :
  motif_i == 2 ? ((step_i == 2) || (step_i == 6) || (step_i == 10) || (step_i == 14)) :
  ((step_i == 0) || (step_i == 3) || (step_i == 8) || (step_i == 11) || (step_i == 15));
);

function shifted_progress(layer_i, bar_i) local(x, arc_amt)
(
  x = planned_total_bars <= 1 ? 0 : bar_i / max(planned_total_bars - 1, 1);
  arc_amt = (layer_arc_offset - 50) * 0.0035;
  layer_i == LAYER_PATIENT ? x -= arc_amt :
  layer_i == LAYER_WEIGHT ? x += arc_amt;
  clamp01(x);
);

function envelope_value(shape_i, x) local(y)
(
  shape_i == ENV_FLAT_ANCHOR ? (0.62 + x * 0.10) :
  shape_i == ENV_SLOW_RISE ? (0.30 + x * x * 0.56) :
  shape_i == ENV_LATE_BLOOM ? (
    y = clamp01((x - (0.18 + late_bloom_bias * 0.0015)) / max(0.18, 0.82 - late_bloom_bias * 0.0015));
    0.18 + y * y * 0.78;
  ) :
  shape_i == ENV_RISE_HOLD ? (
    x < 0.55 ? (0.30 + x * 0.92) : (0.80 + (x - 0.55) * 0.12);
  ) :
  shape_i == ENV_RISE_FALL_RISE ? (
    x < 0.45 ? (0.28 + x * 0.88) :
    x < 0.72 ? (0.68 - (x - 0.45) * 0.42) :
    (0.56 + (x - 0.72) * 0.72);
  ) :
  shape_i == ENV_CREST_RELEASE ? (
    x < 0.78 ? (0.24 + x * 0.84) : (0.90 - (x - 0.78) * 1.05);
  ) :
  (0.54 + sin(x * 6.28318) * 0.14 + x * 0.10);
);

function layer_macro_energy(layer_i, bar_i) local(x, base_i, macro_amt)
(
  x = shifted_progress(layer_i, bar_i);
  base_i = envelope_value(layer_envelope_shape[layer_i], x);
  planned_total_bars <= 32 ? base_i = 0.60 + (base_i - 0.60) * 0.35;
  macro_amt = planned_total_bars <= 32 ? (0.30 + macro_dynamics * 0.004) : (0.58 + macro_dynamics * 0.003);
  base_i = 0.60 + (base_i - 0.60) * macro_amt;
  base_i += (dynamic_lift - 50) * 0.0016;
  clamp01(base_i);
);

function macro_density_bias(macro_i)
(
  macro_i == MACRO_ESTABLISH ? -0.10 :
  macro_i == MACRO_DEEPEN ? 0.00 :
  macro_i == MACRO_LIFT ? 0.08 :
  macro_i == MACRO_CREST ? 0.14 :
  macro_i == MACRO_RELEASE ? -0.04 :
  macro_i == MACRO_TURNAROUND_ZONE ? -0.02 :
  -0.08;
);

function density_drift_bias(layer_i, bar_i) local(progress_i, drift_i)
(
  progress_i = shifted_progress(layer_i, bar_i) * 2 - 1;
  drift_i = density_drift - 50;
  drift_i * progress_i * 0.18;
);

function tension_backbeat_velocity(macro_i, class_i, energy_i) local(base_i)
(
  base_i =
    macro_i == MACRO_ESTABLISH ? 62 :
    macro_i == MACRO_DEEPEN ? 70 :
    macro_i == MACRO_LIFT ? 78 :
    macro_i == MACRO_CREST ? 86 :
    macro_i == MACRO_RELEASE ? 66 :
    macro_i == MACRO_TURNAROUND_ZONE ? 74 :
    64;
  class_i == CLASS_POI_MAIN ? base_i += 10;
  class_i == CLASS_POI_VARIATION ? base_i += 6;
  class_i == CLASS_TURNAROUND ? base_i += 10;
  class_i == CLASS_LANDING ? base_i -= 8;
  clampi(floor(base_i + energy_i * 10 + 0.5), 1, 127);
);

function tension_backbeat_probability(macro_i, class_i, lead_i, support_i) local(prob_i)
(
  prob_i =
    macro_i == MACRO_ESTABLISH ? 58 :
    macro_i == MACRO_DEEPEN ? 72 :
    macro_i == MACRO_LIFT ? 84 :
    macro_i == MACRO_CREST ? 92 :
    macro_i == MACRO_RELEASE ? 68 :
    macro_i == MACRO_TURNAROUND_ZONE ? 80 :
    62;
  class_i == CLASS_POI_MAIN ? prob_i += 10;
  class_i == CLASS_POI_VARIATION ? prob_i += 6;
  class_i == CLASS_TURNAROUND ? prob_i += 12;
  lead_i == LAYER_PROCESSION ? prob_i += 8;
  support_i == LAYER_PROCESSION ? prob_i += 5;
  planned_total_bars <= 16 ? (
    prob_i -= 18;
    macro_i == MACRO_ESTABLISH ? prob_i -= 10;
    macro_i == MACRO_DEEPEN ? prob_i -= 6;
    class_i == CLASS_POI_MAIN ? prob_i += 6;
    class_i == CLASS_TURNAROUND ? prob_i += 4;
  );
  clampi(prob_i, 0, 100);
);

function patient_backbeat_velocity(macro_i, class_i, energy_i) local(base_i)
(
  base_i =
    macro_i == MACRO_ESTABLISH ? 102 :
    macro_i == MACRO_DEEPEN ? 106 :
    macro_i == MACRO_LIFT ? 110 :
    macro_i == MACRO_CREST ? 114 :
    macro_i == MACRO_RELEASE ? 104 :
    macro_i == MACRO_TURNAROUND_ZONE ? 108 :
    100;
  class_i == CLASS_POI_MAIN ? base_i += 6;
  class_i == CLASS_POI_VARIATION ? base_i += 3;
  class_i == CLASS_TURNAROUND ? base_i += 4;
  class_i == CLASS_LANDING ? base_i -= 6;
  clampi(floor(base_i + energy_i * 9 + 0.5), 1, 127);
);

function patient_rim_backbeat_velocity(macro_i, class_i, energy_i) local(base_i)
(
  base_i =
    macro_i == MACRO_ESTABLISH ? 68 :
    macro_i == MACRO_DEEPEN ? 72 :
    macro_i == MACRO_LIFT ? 76 :
    macro_i == MACRO_CREST ? 80 :
    macro_i == MACRO_RELEASE ? 70 :
    macro_i == MACRO_TURNAROUND_ZONE ? 74 :
    66;
  class_i == CLASS_POI_MAIN ? base_i += 4;
  class_i == CLASS_TURNAROUND ? base_i += 4;
  class_i == CLASS_LANDING ? base_i -= 4;
  clampi(floor(base_i + energy_i * 8 + 0.5), 1, 127);
);

function patient_role_velocity(role_i, bar_i, step_i, cycle_bar_i, sub_i) local(density_i, variation_i, class_i, macro_i, lead_i, support_i, clock_i, halftime_i, fill_owner_i, major_fill_i, simplify_i, energy_i, motif_i, prob_i, vel_i, accent_i, anchor_vel_i, rim_anchor_vel_i, transition_hit_i, transition_owner_i)
(
  density_i = layer_density(LAYER_PATIENT);
  variation_i = layer_variation(LAYER_PATIENT);
  class_i = bar_class_value(cycle_bar_i);
  macro_i = macro_section_value(cycle_bar_i);
  lead_i = bar_lead_value(cycle_bar_i);
  support_i = bar_support_value(cycle_bar_i);
  clock_i = bar_cymbal_value(cycle_bar_i);
  halftime_i = bar_halftime_value(cycle_bar_i);
  fill_owner_i = bar_fill_owner_value(cycle_bar_i);
  major_fill_i = (fill_owner_i == LAYER_PATIENT) && ((class_i == CLASS_FILL) || (class_i == CLASS_TURNAROUND));
  simplify_i = (fill_owner_i >= 0) && (fill_owner_i != LAYER_PATIENT) && ((class_i == CLASS_FILL) || (class_i == CLASS_TURNAROUND));
  energy_i = layer_macro_energy(LAYER_PATIENT, cycle_bar_i) + macro_density_bias(macro_i) * 0.35;
  motif_i = hash_pick(4, floor(cycle_bar_i / max(4, planned_recurrence_window)), variation_i, class_i, 201, 0);
  prob_i = density_i * 0.45 + precision_amount * 0.35 + repetition_bias * 0.20 + energy_i * 25;
  prob_i += density_drift_bias(LAYER_PATIENT, cycle_bar_i);
  halftime_i ? prob_i -= 10;
  anchor_vel_i = patient_backbeat_velocity(macro_i, class_i, energy_i);
  rim_anchor_vel_i = patient_rim_backbeat_velocity(macro_i, class_i, energy_i);
  transition_hit_i = bar_needs_transition_opening_hit(cycle_bar_i);
  transition_owner_i = transition_hit_i ? transition_opening_owner(cycle_bar_i) : -1;
  vel_i = 0;

  role_i == 0 ? (
    !sub_i ? (
      step_i == 0 ? vel_i = 112 + energy_i * 10;
      !halftime_i && step_i == 8 ? vel_i = max(vel_i, 102 + energy_i * 8);
      halftime_i && step_i == 8 ? vel_i = max(vel_i, 104 + energy_i * 6);
      patient_motif_step(motif_i, step_i) && step_i != 0 && step_i != 8 && hash_hit(prob_i - repetition_bias * 0.10, cycle_bar_i, step_i, role_i, 1, 0) ? vel_i = max(vel_i, 88 + energy_i * 8);
      class_i == CLASS_LANDING && planned_landing_mode == LANDING_KICK_CRASH && step_i == 0 ? vel_i = 118;
      class_i == CLASS_TURNAROUND && major_fill_i && step_i >= 12 ? vel_i = max(vel_i, 96 + energy_i * 8);
    ) : (
      major_fill_i && (step_i >= 13) ? vel_i = 84 + energy_i * 8;
      doubletime_bias > 62 && !halftime_i && step_i == 15 ? vel_i = max(vel_i, 72);
    );
  );

  role_i == 1 ? (
    !sub_i ? (
      is_backbeat_step(step_i, halftime_i) ? vel_i = max(vel_i, anchor_vel_i);
      class_i == CLASS_POI_MAIN && step_i == anchor_backbeat_step(halftime_i) ? vel_i = max(vel_i, 112);
      class_i == CLASS_TURNAROUND && major_fill_i && step_i == 15 ? vel_i = max(vel_i, 98);
      class_i == CLASS_LANDING && planned_landing_mode == LANDING_KICK_CRASH && step_i == 4 ? vel_i = max(vel_i, 88);
    ) : (
      major_fill_i && (step_i == 14 || step_i == 15) ? vel_i = 78 + energy_i * 8;
    );
  );

  role_i == 2 ? (
    !sub_i && is_backbeat_step(step_i, halftime_i) && (class_i == CLASS_VARIATION || class_i == CLASS_PRE_FILL || class_i == CLASS_TURNAROUND || macro_i >= MACRO_DEEPEN) && hash_hit(44 + variation_i * 0.18 + energy_i * 10, cycle_bar_i, step_i, 202, 0, 0) ? vel_i = max(vel_i, rim_anchor_vel_i);
    !halftime_i && !sub_i && !simplify_i && planned_tempo_band <= BAND_B1 && hash_hit(variation_i * 0.55 + energy_i * 14, cycle_bar_i, step_i, 203, 0, 0) && (step_i == 3 || step_i == 11) ? vel_i = max(vel_i, 62 + energy_i * 8);
  );

  role_i == 3 ? (
    !simplify_i && !sub_i && clock_i == CLOCK_HAT ? (
      !halftime_i && (density_i + energy_i * 26 + doubletime_bias) > 72 ? (
        is_eighth_step(step_i) ? vel_i = (step_i % 4 == 0 ? 78 : 70) :
        ((density_i + doubletime_bias) > 84 && hash_hit(density_i * 0.55 + energy_i * 24, cycle_bar_i, step_i, 203, 0, 0) ? vel_i = 62 : 0);
      ) : (
        is_downbeat_step(step_i) ? vel_i = 74 : 0;
      );
    );
  );

  role_i == 4 ? (
    !simplify_i && !sub_i && (clock_i == CLOCK_OPEN || clock_i == CLOCK_HAT) && ((step_i == 6) || (step_i == 14)) && hash_hit(cymbal_wash * 0.55 + energy_i * 20, cycle_bar_i, step_i, 204, 0, 0) ? vel_i = 84 + energy_i * 8;
  );

  role_i == 5 ? (
    !simplify_i && !sub_i && clock_i == CLOCK_RIDE && is_ride_clock_step(cycle_bar_i, step_i, halftime_i) ? vel_i = (step_i % 4 == 0 ? 80 : 72) + energy_i * 6;
  );

  role_i == 6 ? (
    !sub_i && step_i == 0 && (cycle_bar_i == 0 || class_i == CLASS_POI_MAIN || class_i == CLASS_TURNAROUND || (class_i == CLASS_LANDING && planned_landing_mode == LANDING_KICK_CRASH)) ? vel_i = 114;
    !sub_i && step_i == 0 && transition_hit_i && transition_owner_i == LAYER_PATIENT ? vel_i = max(vel_i, 114);
    major_fill_i && sub_i && step_i >= 14 ? vel_i = max(vel_i, 92);
  );

  role_i == 7 ? (
    !sub_i && !simplify_i && class_i == CLASS_POI_MAIN && cymbal_wash > 54 && step_i == 0 ? vel_i = 88 + energy_i * 8;
    !sub_i && !simplify_i && macro_i == MACRO_CREST && step_i == 8 && hash_hit(cymbal_wash * 0.40, cycle_bar_i, step_i, 205, 0, 0) ? vel_i = max(vel_i, 72);
  );

  role_i == 8 ? (
    major_fill_i ? (
      (!sub_i && step_i == 12) || (sub_i && step_i == 13) ? vel_i = 84 + energy_i * 8;
    ) :
    !simplify_i && class_i == CLASS_POI_VARIATION && lead_i == LAYER_PATIENT && !sub_i && step_i == 10 ? vel_i = 80;
  );

  role_i == 9 ? (
    major_fill_i ? (
      (!sub_i && step_i == 13) || (sub_i && step_i == 14) ? vel_i = 88 + energy_i * 8;
    ) :
    !simplify_i && class_i == CLASS_POI_VARIATION && !sub_i && step_i == 14 ? vel_i = 84;
  );

  role_i == 10 ? (
    major_fill_i ? (
      (!sub_i && step_i == 14) || (sub_i && step_i == 15) ? vel_i = 96 + energy_i * 8;
    ) :
    class_i == CLASS_LANDING && planned_landing_mode == LANDING_LOW_TOM && !sub_i && step_i == 0 ? vel_i = 92;
  );

  role_i == 11 ? (
    !sub_i && !simplify_i && percussion_amount > 56 && (step_i == 7 || step_i == 15) && hash_hit(percussion_amount * 0.45 + energy_i * 18, cycle_bar_i, step_i, 206, 0, 0) ? vel_i = 70;
  );

  vel_i > 0 ? vel_i = clampi(floor(vel_i + (velocity_drift - 50) * 0.08), 1, 127);
  vel_i;
);

function procession_role_velocity(role_i, bar_i, step_i, cycle_bar_i, sub_i) local(density_i, variation_i, class_i, macro_i, lead_i, support_i, clock_i, halftime_i, fill_owner_i, major_fill_i, simplify_i, patient_missing_i, compact_form_i, energy_i, motif_i, prob_i, backbeat_prob_i, backbeat_vel_i, vel_i, transition_hit_i, transition_owner_i)
(
  density_i = layer_density(LAYER_PROCESSION);
  variation_i = layer_variation(LAYER_PROCESSION);
  class_i = bar_class_value(cycle_bar_i);
  macro_i = macro_section_value(cycle_bar_i);
  lead_i = bar_lead_value(cycle_bar_i);
  support_i = bar_support_value(cycle_bar_i);
  clock_i = bar_cymbal_value(cycle_bar_i);
  halftime_i = bar_halftime_value(cycle_bar_i);
  fill_owner_i = bar_fill_owner_value(cycle_bar_i);
  major_fill_i = (fill_owner_i == LAYER_PROCESSION) && ((class_i == CLASS_FILL) || (class_i == CLASS_TURNAROUND));
  simplify_i = (fill_owner_i >= 0) && (fill_owner_i != LAYER_PROCESSION) && ((class_i == CLASS_FILL) || (class_i == CLASS_TURNAROUND));
  patient_missing_i = !layer_can_emit(LAYER_PATIENT);
  compact_form_i = planned_total_bars <= 16;
  energy_i = layer_macro_energy(LAYER_PROCESSION, cycle_bar_i) + macro_density_bias(macro_i) * 0.45;
  motif_i = hash_pick(4, floor(cycle_bar_i / max(4, planned_recurrence_window * 0.5)), variation_i, class_i, 207, 0);
  prob_i = density_i * 0.40 + riff_amount * 0.34 + percussion_amount * 0.22 + energy_i * 28;
  prob_i += density_drift_bias(LAYER_PROCESSION, cycle_bar_i);
  halftime_i ? prob_i -= 18;
  compact_form_i ? (
    prob_i -= 18;
    macro_i == MACRO_ESTABLISH ? prob_i -= 12;
    macro_i == MACRO_DEEPEN ? prob_i -= 8;
    class_i == CLASS_POI_MAIN ? prob_i += 10;
    class_i == CLASS_POI_VARIATION ? prob_i += 4;
    class_i == CLASS_TURNAROUND ? prob_i += 8;
  );
  backbeat_prob_i = tension_backbeat_probability(macro_i, class_i, lead_i, support_i);
  halftime_i ? backbeat_prob_i -= 12;
  backbeat_vel_i = tension_backbeat_velocity(macro_i, class_i, energy_i);
  compact_form_i ? backbeat_vel_i = max(1, backbeat_vel_i - 10);
  transition_hit_i = bar_needs_transition_opening_hit(cycle_bar_i);
  transition_owner_i = transition_hit_i ? transition_opening_owner(cycle_bar_i) : -1;
  vel_i = 0;

  role_i == 0 ? (
    !sub_i && !simplify_i && (support_i == LAYER_PROCESSION || lead_i == LAYER_PROCESSION) && (step_i == 0 || (class_i == CLASS_POI_MAIN && step_i == 10)) ? vel_i = 84 + energy_i * 10;
  );

  role_i == 1 ? (
    !sub_i ? (
      patient_missing_i && is_backbeat_step(step_i, halftime_i) && hash_hit(backbeat_prob_i, cycle_bar_i, step_i, 307, 0, 0) ? vel_i = max(vel_i, backbeat_vel_i);
      (!compact_form_i || class_i == CLASS_POI_MAIN || class_i == CLASS_POI_VARIATION || class_i == CLASS_TURNAROUND || macro_i >= MACRO_LIFT) && procession_motif_step(motif_i, step_i) && (macro_i >= MACRO_DEEPEN || class_i == CLASS_POI_MAIN || class_i == CLASS_POI_VARIATION) && hash_hit(compact_form_i ? (prob_i - 12) : prob_i, cycle_bar_i, step_i, 309, 0, 0) ? vel_i = max(vel_i, (compact_form_i ? 72 : 82) + energy_i * 12);
      class_i == CLASS_POI_MAIN && is_backbeat_step(step_i, halftime_i) ? vel_i = max(vel_i, 96 + energy_i * 10);
      class_i == CLASS_TURNAROUND && major_fill_i && step_i >= 14 ? vel_i = max(vel_i, 94);
    ) : (
      major_fill_i && (step_i == 14 || step_i == 15) ? vel_i = 76 + energy_i * 8;
    );
  );

  role_i == 2 ? (
    !sub_i && patient_missing_i && macro_i >= MACRO_DEEPEN && (step_i == anchor_backbeat_step(halftime_i)) && hash_hit(backbeat_prob_i - 10, cycle_bar_i, step_i, 308, 0, 0) ? vel_i = max(vel_i, backbeat_vel_i - 16);
    (!compact_form_i || class_i == CLASS_POI_MAIN || class_i == CLASS_TURNAROUND || macro_i >= MACRO_LIFT) && !sub_i && !simplify_i && procession_motif_step((motif_i + 1) % 4, step_i) && hash_hit(compact_form_i ? (prob_i - 14) : prob_i, cycle_bar_i, step_i, 208, 0, 0) ? vel_i = max(vel_i, (compact_form_i ? 56 : 64) + energy_i * 8);
  );

  role_i == 3 ? (
    !sub_i && !simplify_i && lead_i == LAYER_PROCESSION && clock_i == CLOCK_HAT && is_downbeat_step(step_i) ? vel_i = 70 + energy_i * 6;
  );

  role_i == 4 ? (
    !sub_i && !simplify_i && lead_i == LAYER_PROCESSION && clock_i == CLOCK_OPEN && (step_i == 6 || step_i == 14) ? vel_i = 80;
  );

  role_i == 5 ? (
    !sub_i && !simplify_i && lead_i == LAYER_PROCESSION && clock_i == CLOCK_RIDE && is_ride_clock_step(cycle_bar_i, step_i, halftime_i) ? vel_i = (step_i % 4 == 0 ? 74 : 66) + energy_i * 6;
  );

  role_i == 6 ? (
    !sub_i && step_i == 0 && (class_i == CLASS_POI_MAIN || class_i == CLASS_TURNAROUND || cycle_bar_i == planned_poi_start) ? vel_i = 108;
    !sub_i && step_i == 0 && transition_hit_i && transition_owner_i == LAYER_PROCESSION ? vel_i = max(vel_i, 108);
  );

  role_i == 7 ? (
    !sub_i && !simplify_i && (class_i == CLASS_POI_MAIN || macro_i == MACRO_CREST) && step_i == 0 && hash_hit(cymbal_wash * 0.45 + prob_i * 0.10, cycle_bar_i, 209, 0, 0, 0) ? vel_i = 80;
  );

  role_i == 8 ? (
    major_fill_i ? (
      (!sub_i && step_i == 12) || (sub_i && step_i == 13) ? vel_i = 86;
    ) :
    !simplify_i && class_i == CLASS_POI_VARIATION && step_i == 10 ? vel_i = 78;
  );

  role_i == 9 ? (
    major_fill_i ? (
      (!sub_i && step_i == 13) || (sub_i && step_i == 14) ? vel_i = 90;
    ) :
    !simplify_i && class_i == CLASS_POI_VARIATION && step_i == 14 ? vel_i = 82;
  );

  role_i == 10 ? (
    major_fill_i ? (
      (!sub_i && step_i == 14) || (sub_i && step_i == 15) ? vel_i = 94;
    ) :
    !simplify_i && macro_i == MACRO_TURNAROUND_ZONE && step_i == 15 && hash_hit(percussion_amount * 0.50, cycle_bar_i, step_i, 210, 0, 0) ? vel_i = 80;
  );

  role_i == 11 ? (
    !sub_i && !simplify_i && procession_motif_step(motif_i, step_i) && percussion_amount > 48 && hash_hit(prob_i + 10, cycle_bar_i, step_i, 211, 0, 0) ? vel_i = 72 + energy_i * 8;
  );

  vel_i > 0 ? vel_i = clampi(floor(vel_i + (velocity_drift - 50) * 0.10), 1, 127);
  vel_i;
);

function weight_role_velocity(role_i, bar_i, step_i, cycle_bar_i, sub_i) local(density_i, variation_i, class_i, macro_i, lead_i, support_i, clock_i, halftime_i, fill_owner_i, major_fill_i, simplify_i, energy_i, motif_i, prob_i, vel_i, transition_hit_i, transition_owner_i)
(
  density_i = layer_density(LAYER_WEIGHT);
  variation_i = layer_variation(LAYER_WEIGHT);
  class_i = bar_class_value(cycle_bar_i);
  macro_i = macro_section_value(cycle_bar_i);
  lead_i = bar_lead_value(cycle_bar_i);
  support_i = bar_support_value(cycle_bar_i);
  clock_i = bar_cymbal_value(cycle_bar_i);
  halftime_i = bar_halftime_value(cycle_bar_i);
  fill_owner_i = bar_fill_owner_value(cycle_bar_i);
  major_fill_i = (fill_owner_i == LAYER_WEIGHT) && ((class_i == CLASS_FILL) || (class_i == CLASS_TURNAROUND));
  simplify_i = (fill_owner_i >= 0) && (fill_owner_i != LAYER_WEIGHT) && ((class_i == CLASS_FILL) || (class_i == CLASS_TURNAROUND));
  energy_i = layer_macro_energy(LAYER_WEIGHT, cycle_bar_i) + macro_density_bias(macro_i) * 0.55;
  motif_i = hash_pick(4, floor(cycle_bar_i / max(4, planned_recurrence_window * 0.5)), variation_i, class_i, 212, 0);
  prob_i = density_i * 0.34 + weight_amount * 0.34 + tom_motion * 0.28 + percussion_amount * 0.12 + energy_i * 30;
  prob_i += density_drift_bias(LAYER_WEIGHT, cycle_bar_i);
  planned_tempo_band <= BAND_A2 ? prob_i -= 20;
  halftime_i ? prob_i -= 18;
  transition_hit_i = bar_needs_transition_opening_hit(cycle_bar_i);
  transition_owner_i = transition_hit_i ? transition_opening_owner(cycle_bar_i) : -1;
  vel_i = 0;

  role_i == 0 ? (
    !sub_i && !simplify_i && (support_i == LAYER_WEIGHT || lead_i == LAYER_WEIGHT) && (step_i == 0 || (!bar_halftime_value(cycle_bar_i) && step_i == 8)) ? vel_i = 84 + energy_i * 10;
  );

  role_i == 1 ? (
    !sub_i && !simplify_i && lead_i == LAYER_WEIGHT && class_i == CLASS_POI_VARIATION && step_i == 12 ? vel_i = 80 + energy_i * 8;
  );

  role_i == 2 ? (
    !sub_i && !simplify_i && clock_i == CLOCK_TOM && planned_tempo_band >= BAND_D && is_downbeat_step(step_i) ? vel_i = 58 + energy_i * 6;
  );

  role_i == 3 ? (
    !sub_i && !simplify_i && lead_i == LAYER_WEIGHT && clock_i == CLOCK_HAT && is_downbeat_step(step_i) ? vel_i = 62;
  );

  role_i == 4 ? (
    !sub_i && !simplify_i && lead_i == LAYER_WEIGHT && clock_i == CLOCK_OPEN && (step_i == 6 || step_i == 14) ? vel_i = 76;
  );

  role_i == 5 ? (
    !sub_i && !simplify_i && lead_i == LAYER_WEIGHT && clock_i == CLOCK_RIDE && is_ride_clock_step(cycle_bar_i, step_i, halftime_i) ? vel_i = (step_i % 4 == 0 ? 72 : 64) + energy_i * 6;
  );

  role_i == 6 ? (
    !sub_i && step_i == 0 && (class_i == CLASS_POI_MAIN || class_i == CLASS_TURNAROUND || (class_i == CLASS_LANDING && planned_landing_mode == LANDING_LOW_TOM)) ? vel_i = 106 + energy_i * 8;
    !sub_i && step_i == 0 && transition_hit_i && transition_owner_i == LAYER_WEIGHT ? vel_i = max(vel_i, 106 + energy_i * 8);
  );

  role_i == 7 ? (
    major_fill_i ? (
      (!sub_i && step_i == 12) || (sub_i && step_i == 13) ? vel_i = 84 + energy_i * 8;
    ) :
    !simplify_i && weight_motif_step(motif_i, step_i) && !sub_i && (lead_i == LAYER_WEIGHT || macro_i >= MACRO_LIFT) && hash_hit(prob_i, cycle_bar_i, step_i, 213, 0, 0) ? vel_i = 78 + energy_i * 10;
  );

  role_i == 8 ? (
    major_fill_i ? (
      (!sub_i && step_i == 13) || (sub_i && step_i == 14) ? vel_i = 90 + energy_i * 8;
    ) :
    !simplify_i && weight_motif_step(motif_i, step_i) && !sub_i && (step_i == 4 || step_i == 8 || step_i == 11) && hash_hit(prob_i + 8, cycle_bar_i, step_i, 214, 0, 0) ? vel_i = 86 + energy_i * 10;
  );

  role_i == 9 ? (
    major_fill_i ? (
      (!sub_i && step_i == 14) || (sub_i && step_i == 15) ? vel_i = 98 + energy_i * 8;
    ) :
    !simplify_i && weight_motif_step(motif_i, step_i) && !sub_i && hash_hit(prob_i + 14, cycle_bar_i, step_i, 215, 0, 0) ? vel_i = ((step_i == 0) || (step_i == 8)) ? 96 + energy_i * 10 : 90 + energy_i * 8;
  );

  role_i == 10 ? (
    class_i == CLASS_LANDING && planned_landing_mode == LANDING_LOW_TOM && !sub_i && step_i == 0 ? vel_i = 110 :
    major_fill_i ? (
      (!sub_i && step_i == 15) || (sub_i && step_i == 15) ? vel_i = 104 + energy_i * 8;
    ) :
    !simplify_i && (lead_i == LAYER_WEIGHT || macro_i >= MACRO_CREST) && !sub_i && (step_i == 0 || step_i == 8) && hash_hit(prob_i + 18, cycle_bar_i, step_i, 216, 0, 0) ? vel_i = 100 + energy_i * 8;
  );

  role_i == 11 ? (
    !sub_i && !simplify_i && percussion_amount > 54 && (step_i == 3 || step_i == 11 || step_i == 15) && hash_hit(prob_i * 0.75, cycle_bar_i, step_i, 217, 0, 0) ? vel_i = 70 + energy_i * 8;
  );

  vel_i > 0 ? vel_i = clampi(floor(vel_i + (velocity_drift - 50) * 0.12), 1, 127);
  vel_i;
);

function layer_role_velocity(layer_i, role_i, bar_i, step_i, cycle_bar_i, sub_i)
(
  layer_i == LAYER_PATIENT ? patient_role_velocity(role_i, bar_i, step_i, cycle_bar_i, sub_i) :
  layer_i == LAYER_PROCESSION ? procession_role_velocity(role_i, bar_i, step_i, cycle_bar_i, sub_i) :
  weight_role_velocity(role_i, bar_i, step_i, cycle_bar_i, sub_i);
);

function fire_step_for_layer(layer_i, bar_i, step_i, cycle_bar_i, rel_offset) local(role_i, vel_i)
(
  layer_can_emit(layer_i) ? (
    role_i = 0;
    while (role_i < NUM_PADS) (
      vel_i = layer_role_velocity(layer_i, role_i, bar_i, step_i, cycle_bar_i, 0);
      vel_i > 0 ? trigger_role(layer_i, role_i, vel_i, rel_offset, bar_i, step_i, cycle_bar_i, 0);
      vel_i = layer_role_velocity(layer_i, role_i, bar_i, step_i, cycle_bar_i, 1);
      vel_i > 0 ? trigger_role(layer_i, role_i, vel_i, rel_offset, bar_i, step_i, cycle_bar_i, 1);
      role_i += 1;
    );
  );
);

function in_rect(mx, my, x, y, w, h)
(
  (mx >= x) && (mx < (x + w)) && (my >= y) && (my < (y + h));
);

function init_persistent_state() local(layer_i, pad_i)
(
  layer_i = 0;
  while (layer_i < NUM_LAYERS) (
    pad_i = 0;
    while (pad_i < NUM_PADS) (
      role_to_pad[layer_pad_index(layer_i, pad_i)] = pad_i;
      pad_i += 1;
    );
    layer_i += 1;
  );

  persistent_magic != 778812 ? (
    selected_pad = 0;
    edit_layer = 0;
    preview_mode = 0;
    host_sliders_visible = 0;
    last_host_sliders_visible = -1;
    layer_i = 0;
    while (layer_i < NUM_LAYERS) (
      pad_i = 0;
      while (pad_i < NUM_PADS) (
        set_pad_note(layer_i, pad_i, default_note(layer_i, pad_i));
        pad_i += 1;
      );
      layer_i += 1;
    );

    persistent_magic = 778812;
  );
);

function reset_runtime_state() local(layer_i, pad_i, i)
(
  i = 0;
  while (i < NUM_PADS) (
    slot_activity[i] = 0;
    i += 1;
  );

  i = 0;
  while (i < (16 * 128)) (
    active_note_count[i] = 0;
    i += 1;
  );

  layer_i = 0;
  while (layer_i < NUM_LAYERS) (
    pad_i = 0;
    while (pad_i < NUM_PADS) (
      layer_activity[layer_pad_index(layer_i, pad_i)] = 0;
      pad_i += 1;
    );
    layer_i += 1;
  );

  queue_head = 0;
  queue_tail = 0;
  ui_audition_pending = 0;
  ui_audition_layer = 0;
  ui_audition_pad = 0;
  last_mouse_down = 0;
  note_drag_active = 0;
  note_drag_layer = 0;
  note_drag_pad = 0;
  note_drag_start_y = 0;
  note_drag_origin = 0;
  layer_row_drag_active = 0;
  layer_row_drag_layer = 0;
  layer_row_drag_row = 0;
  layer_row_drag_start_y = 0;
  layer_row_drag_origin = 0;
  header_drag_active = 0;
  header_drag_control = 0;
  header_drag_start_y = 0;
  header_drag_origin = 0;
  global_drag_active = 0;
  global_drag_control = 0;
  global_drag_start_y = 0;
  global_drag_origin = 0;
  last_host_sliders_visible = -1;
  transport_is_playing = 0;
  current_cycle_step = 0;
  current_bar = 0;
  current_step_in_bar = 0;
  current_substep = 0;
  cycle_steps = 128;
  last_transport_is_playing = 0;
  last_beat_position = 0;
  last_block_beats = 0;
  abs_sample_clock = 0;
  block_abs_start = 0;
  block_abs_end = 0;
  step_samples = 0;
  note_len_samples = 0;
  form_dirty = 1;
  planned_total_bars = 0;
  planned_poi_start = 0;
  planned_poi_bars = 0;
  planned_poi_count = 1;
  planned_poi_lead = 0;
  planned_tempo_band = 0;
  planned_turnaround_type = 0;
  planned_turnaround_bar = 0;
  planned_landing_bar = 0;
  planned_landing_mode = 0;
  planned_turnaround_zone_bars = 1;
  planned_recurrence_window = 4;
  planned_effective_tempo = 0;
);

init_persistent_state();
reset_runtime_state();

@serialize

file_var(0, persistent_magic);
file_var(0, selected_pad);
file_var(0, edit_layer);
file_var(0, preview_mode);
file_var(0, host_sliders_visible);

layer_i = 0;
while (layer_i < NUM_LAYERS) (
  pad_i = 0;
  while (pad_i < NUM_PADS) (
    note_tmp = pad_note[layer_pad_index(layer_i, pad_i)];
    file_var(0, note_tmp);
    pad_note[layer_pad_index(layer_i, pad_i)] = note_tmp;
    pad_i += 1;
  );
  layer_i += 1;
);

@block

while (midirecv(offset, msg1, msg23)) (
  midisend(offset, msg1, msg23);
);

transport_is_playing = play_state & 1;
effective_tempo_now = tempo_reference > 0 ? tempo_reference : max(tempo, 1);
snapped_total_now = snap_total_bars(total_bars);
snapped_poi_now = snapped_total_now >= 8 ? snap_poi_length(poi_length, snapped_total_now) : 0;
snapped_poi_count_now = snapped_poi_now > 0 ? snap_poi_count(poi_count, snapped_total_now, snapped_poi_now) : 0;
expected_turn_zone_now = snapped_total_now >= 32 ? min(snap_turnaround_zone_length(turnaround_zone_length), snapped_total_now - 1) : 1;
form_dirty ||
  (planned_total_bars != snapped_total_now) ||
  (planned_effective_tempo != effective_tempo_now) ||
  (planned_tempo_band != tempo_band_for_bpm(effective_tempo_now)) ||
  (planned_poi_bars != snapped_poi_now) ||
  (planned_poi_count != snapped_poi_count_now) ||
  (planned_turnaround_zone_bars != expected_turn_zone_now) ? plan_form();

cycle_steps = planned_total_bars * 16;
step_samples = srate * 60 / max(tempo, 1) / 4;
note_len_samples = floor(step_samples * master_note_length * 0.01 + 0.5);
note_len_samples < 1 ? note_len_samples = 1;

block_abs_start = abs_sample_clock;
block_abs_end = block_abs_start + samplesblock;

transport_step_abs = floor((beat_position / STEP_BEATS) + 0.000001);
current_cycle_step = transport_step_abs % cycle_steps;
current_cycle_step < 0 ? current_cycle_step += cycle_steps;
current_bar = floor(current_cycle_step / 16);
current_step_in_bar = current_cycle_step % 16;
current_substep = 0;

transport_jump = 0;
!transport_is_playing && last_transport_is_playing ? transport_jump = 1;
transport_is_playing && last_transport_is_playing ? (
  expected_beat_position = last_beat_position + last_block_beats;
  abs(beat_position - expected_beat_position) > (STEP_BEATS * 0.5) ? transport_jump = 1;
  beat_position + 0.000001 < last_beat_position ? transport_jump = 1;
);

transport_jump ? flush_all_note_offs();
flush_due_note_offs();

ui_audition_pending ? (
  audition_role = role_for_pad(ui_audition_layer, ui_audition_pad);
  trigger_role(ui_audition_layer, audition_role, 100, 0, -1, -1, -1, 0);
  ui_audition_pending = 0;
);

transport_is_playing ? (
  block_beats = samplesblock * tempo / 60 / srate;
  block_start_beats = beat_position;
  block_end_beats = beat_position + block_beats;

  step_index = floor((block_start_beats / STEP_BEATS) + 0.000001);
  step_time = step_index * STEP_BEATS;
  step_time < (block_start_beats - 0.000001) ? (
    step_index += 1;
    step_time += STEP_BEATS;
  );

  step_guard = 0;
  while ((step_time < (block_end_beats - 0.000001)) && (step_guard < 512)) (
    cycle_step = step_index % cycle_steps;
    cycle_step < 0 ? cycle_step += cycle_steps;

    cycle_bar_i = floor(cycle_step / 16);
    bar_i = cycle_bar_i;
    step_i = cycle_step % 16;

    rel_offset = floor(((step_time - block_start_beats) * 60 / max(tempo, 1) * srate) + 0.5);
    rel_offset < 0 ? rel_offset = 0;
    rel_offset >= samplesblock ? rel_offset = samplesblock - 1;

    fire_step_for_layer(LAYER_MOTORIK, bar_i, step_i, cycle_bar_i, rel_offset);
    fire_step_for_layer(LAYER_BREAKBEAT, bar_i, step_i, cycle_bar_i, rel_offset);
    fire_step_for_layer(LAYER_PERC, bar_i, step_i, cycle_bar_i, rel_offset);

    step_index += 1;
    step_time += STEP_BEATS;
    step_guard += 1;
  );
  last_block_beats = block_beats;
) : (
  last_block_beats = 0;
);

last_transport_is_playing = transport_is_playing;
last_beat_position = beat_position;
abs_sample_clock = block_abs_end;

@gfx 1500 1100

ui_scale = ui_scale_pct * 0.01;

gfx_clear = 0x101418;
gfx_setfont(1, "Verdana", floor(21 * ui_scale));
gfx_setfont(2, "Verdana", floor(15 * ui_scale));
gfx_setfont(3, "Verdana", floor(12 * ui_scale));

mouse_down = mouse_cap & 1;
click = mouse_down && !last_mouse_down;
mouse_shift = mouse_cap & 8;

host_sliders_visible = floor(host_sliders_visible + 0.5);
host_sliders_visible = clampi(host_sliders_visible, 0, 1);
host_sliders_visible != last_host_sliders_visible ? (
  slider_show(HOST_SLIDER_MASK, host_sliders_visible);
  slider_show(GFX_ONLY_SLIDER_MASK, 0);
  last_host_sliders_visible = host_sliders_visible;
);

margin = 16 * ui_scale;
gap = 12 * ui_scale;
header_h = 56 * ui_scale;
strip_h = 188 * ui_scale;
tabs_h = 40 * ui_scale;
globals_h = 274 * ui_scale;

top_y = margin;
header_y = top_y;
strip_y = header_y + header_h + gap;
tabs_y = strip_y + strip_h + gap;
globals_y = tabs_y + tabs_h + gap;
content_y = globals_y + globals_h + gap;
content_h = gfx_h - content_y - margin;
content_h < (260 * ui_scale) ? content_h = 260 * ui_scale;

right_col_w = max(320 * ui_scale, (gfx_w - margin * 2) * 0.34);
right_col_w > (gfx_w * 0.48) ? right_col_w = gfx_w * 0.48;
grid_w = gfx_w - margin * 2 - gap - right_col_w;
grid_w < (380 * ui_scale) ? (
  right_col_w = max(280 * ui_scale, gfx_w * 0.30);
  grid_w = gfx_w - margin * 2 - gap - right_col_w;
);

grid_x = margin;
grid_y = content_y;
grid_h = content_h;

side_x = grid_x + grid_w + gap;
side_y = content_y;
editor_h = 188 * ui_scale;
editor_h > (content_h * 0.52) ? editor_h = content_h * 0.52;
preview_h = content_h - editor_h - gap;
preview_h < (132 * ui_scale) ? (
  preview_h = 132 * ui_scale;
  editor_h = content_h - preview_h - gap;
);

click ? (
  header_ctrl_w = 20 * ui_scale;
  header_val_w = 48 * ui_scale;
  header_ctrl_gap = 6 * ui_scale;
  header_group_y = header_y + 14 * ui_scale;
  transport_box_w = 268 * ui_scale;
  header_status_x = margin + 360 * ui_scale;
  transport_box_x = margin + 450 * ui_scale;
  bars_label_w = 30 * ui_scale;
  poi_label_w = 24 * ui_scale;
  seed_label_w = 28 * ui_scale;

  bars_minus_x = transport_box_x + transport_box_w + 28 * ui_scale;
  bars_value_x = bars_minus_x + header_ctrl_w + header_ctrl_gap;
  bars_plus_x = bars_value_x + header_val_w + header_ctrl_gap;

  poi_minus_x = bars_plus_x + 54 * ui_scale;
  poi_value_x = poi_minus_x + header_ctrl_w + header_ctrl_gap;
  poi_plus_x = poi_value_x + header_val_w + header_ctrl_gap;

  seed_minus_x = poi_plus_x + 54 * ui_scale;
  seed_value_x = seed_minus_x + header_ctrl_w + header_ctrl_gap;
  seed_plus_x = seed_value_x + (header_val_w + 22 * ui_scale) + header_ctrl_gap;

  in_rect(mouse_x, mouse_y, bars_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_total_bars(next_total_bars(total_bars, -1));
  in_rect(mouse_x, mouse_y, bars_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_total_bars(next_total_bars(total_bars, 1));
  in_rect(mouse_x, mouse_y, bars_value_x, header_group_y, header_val_w, 24 * ui_scale) ? (
    header_drag_active = 1;
    header_drag_control = 0;
    header_drag_start_y = mouse_y;
    header_drag_origin = total_bars;
  );
  in_rect(mouse_x, mouse_y, poi_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_poi_count(poi_count - 1);
  in_rect(mouse_x, mouse_y, poi_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_poi_count(poi_count + 1);
  in_rect(mouse_x, mouse_y, poi_value_x, header_group_y, header_val_w, 24 * ui_scale) ? (
    header_drag_active = 1;
    header_drag_control = 1;
    header_drag_start_y = mouse_y;
    header_drag_origin = poi_count;
  );
  in_rect(mouse_x, mouse_y, seed_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_seed_value(seed - 1);
  in_rect(mouse_x, mouse_y, seed_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_seed_value(seed + 1);
  in_rect(mouse_x, mouse_y, seed_value_x, header_group_y, header_val_w + 22 * ui_scale, 24 * ui_scale) ? (
    header_drag_active = 1;
    header_drag_control = 2;
    header_drag_start_y = mouse_y;
    header_drag_origin = seed;
  );

  slider_toggle_w = 122 * ui_scale;
  slider_toggle_h = 26 * ui_scale;
  slider_toggle_x = gfx_w - margin - slider_toggle_w;
  slider_toggle_y = header_y + 15 * ui_scale;
  in_rect(mouse_x, mouse_y, slider_toggle_x, slider_toggle_y, slider_toggle_w, slider_toggle_h) ? host_sliders_visible = 1 - host_sliders_visible;

  panel_w = (gfx_w - margin * 2 - gap * 2) / 3;
  panel_h = strip_h;
  layer_i = 0;
  while (layer_i < NUM_LAYERS) (
    panel_x = margin + layer_i * (panel_w + gap);
    panel_y = strip_y;
    panel_pad = 10 * ui_scale;

    bool_y = panel_y + 34 * ui_scale;
    bool_h = 26 * ui_scale;
    bool_w = (panel_w - panel_pad * 2 - gap * 2) / 3;

    in_rect(mouse_x, mouse_y, panel_x + panel_pad, bool_y, bool_w, bool_h) ? set_layer_enabled(layer_i, 1 - layer_enabled(layer_i));
    in_rect(mouse_x, mouse_y, panel_x + panel_pad + bool_w + gap, bool_y, bool_w, bool_h) ? set_layer_muted(layer_i, 1 - layer_muted(layer_i));
    in_rect(mouse_x, mouse_y, panel_x + panel_pad + (bool_w + gap) * 2, bool_y, bool_w, bool_h) ? set_layer_soloed(layer_i, 1 - layer_soloed(layer_i));

    row_h = 22 * ui_scale;
    ctrl_w = 22 * ui_scale;
    value_w = 62 * ui_scale;
    step_x_minus = panel_x + panel_w - panel_pad - ctrl_w - value_w - ctrl_w - gap * 2;
    row_y = panel_y + 68 * ui_scale;

    in_rect(mouse_x, mouse_y, step_x_minus, row_y, ctrl_w, row_h) ? set_layer_channel(layer_i, layer_channel_display(layer_i) - 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h) ? set_layer_channel(layer_i, layer_channel_display(layer_i) + 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap, row_y, value_w, row_h) ? (
      layer_row_drag_active = 1;
      layer_row_drag_layer = layer_i;
      layer_row_drag_row = 0;
      layer_row_drag_start_y = mouse_y;
      layer_row_drag_origin = layer_channel_display(layer_i);
    );

    row_y += row_h + 6 * ui_scale;
    in_rect(mouse_x, mouse_y, step_x_minus, row_y, ctrl_w, row_h) ? set_layer_density(layer_i, layer_density(layer_i) - 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h) ? set_layer_density(layer_i, layer_density(layer_i) + 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap, row_y, value_w, row_h) ? (
      layer_row_drag_active = 1;
      layer_row_drag_layer = layer_i;
      layer_row_drag_row = 1;
      layer_row_drag_start_y = mouse_y;
      layer_row_drag_origin = layer_density(layer_i);
    );

    row_y += row_h + 6 * ui_scale;
    in_rect(mouse_x, mouse_y, step_x_minus, row_y, ctrl_w, row_h) ? set_layer_variation(layer_i, layer_variation(layer_i) - 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h) ? set_layer_variation(layer_i, layer_variation(layer_i) + 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap, row_y, value_w, row_h) ? (
      layer_row_drag_active = 1;
      layer_row_drag_layer = layer_i;
      layer_row_drag_row = 2;
      layer_row_drag_start_y = mouse_y;
      layer_row_drag_origin = layer_variation(layer_i);
    );

    row_y += row_h + 6 * ui_scale;
    in_rect(mouse_x, mouse_y, step_x_minus, row_y, ctrl_w, row_h) ? set_layer_velocity_scale(layer_i, layer_velocity_scale(layer_i) - 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h) ? set_layer_velocity_scale(layer_i, layer_velocity_scale(layer_i) + 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap, row_y, value_w, row_h) ? (
      layer_row_drag_active = 1;
      layer_row_drag_layer = layer_i;
      layer_row_drag_row = 3;
      layer_row_drag_start_y = mouse_y;
      layer_row_drag_origin = layer_velocity_scale(layer_i);
    );

    layer_i += 1;
  );

  tab_w = (gfx_w - margin * 2 - gap * 4) / 5;
  in_rect(mouse_x, mouse_y, margin, tabs_y, tab_w, tabs_h) ? edit_layer = 0;
  in_rect(mouse_x, mouse_y, margin + tab_w + gap, tabs_y, tab_w, tabs_h) ? edit_layer = 1;
  in_rect(mouse_x, mouse_y, margin + (tab_w + gap) * 2, tabs_y, tab_w, tabs_h) ? edit_layer = 2;
  in_rect(mouse_x, mouse_y, margin + (tab_w + gap) * 3, tabs_y, tab_w, tabs_h) ? preview_mode = 0;
  in_rect(mouse_x, mouse_y, margin + (tab_w + gap) * 4, tabs_y, tab_w, tabs_h) ? preview_mode = 1;

  global_cols = 4;
  global_cell_w = (gfx_w - margin * 2 - gap * (global_cols - 1)) / global_cols;
  global_cell_h = 34 * ui_scale;
  global_row_gap = 10 * ui_scale;
  global_ctrl_w = 18 * ui_scale;
  global_val_w = 60 * ui_scale;
  global_cluster_w = global_ctrl_w + 6 * ui_scale + global_val_w + 6 * ui_scale + global_ctrl_w;
  global_controls_y = globals_y + 40 * ui_scale;
  control_i = 0;
  while (control_i < 20) (
    control_row = floor(control_i / global_cols);
    control_col = control_i % global_cols;
    control_x = margin + control_col * (global_cell_w + gap);
    control_y = global_controls_y + control_row * (global_cell_h + global_row_gap);
    minus_x = control_x + (global_cell_w - global_cluster_w) * 0.5;
    value_x = minus_x + global_ctrl_w + 6 * ui_scale;
    plus_x = value_x + global_val_w + 6 * ui_scale;

    control_step = (control_i == 1 || control_i == 14 || control_i >= 16) ? 1 : 5;
    in_rect(mouse_x, mouse_y, minus_x, control_y + 14 * ui_scale, global_ctrl_w, 16 * ui_scale) ? adjust_global_control(control_i, -control_step);
    in_rect(mouse_x, mouse_y, value_x, control_y + 14 * ui_scale, global_val_w, 16 * ui_scale) ? (
      global_drag_active = 1;
      global_drag_control = control_i;
      global_drag_start_y = mouse_y;
      global_drag_origin = get_global_control_value(control_i);
    );
    in_rect(mouse_x, mouse_y, plus_x, control_y + 14 * ui_scale, global_ctrl_w, 16 * ui_scale) ? adjust_global_control(control_i, control_step);
    control_i += 1;
  );

  cols = 4;
  rows = 3;
  pad_w = (grid_w - gap * (cols - 1)) / cols;
  pad_h = (grid_h - gap * (rows - 1)) / rows;
  pad_i = 0;
  while (pad_i < NUM_PADS) (
    col_i = pad_i % cols;
    row_i = floor(pad_i / cols);
    pad_x = grid_x + col_i * (pad_w + gap);
    pad_y = grid_y + row_i * (pad_h + gap);
    note_hit_x = pad_x + 8 * ui_scale;
    note_hit_y = pad_y + 50 * ui_scale;
    note_hit_w = pad_w - 16 * ui_scale;
    note_hit_h = 24 * ui_scale;
    in_rect(mouse_x, mouse_y, note_hit_x, note_hit_y, note_hit_w, note_hit_h) ? (
      selected_pad = pad_i;
      note_drag_active = 1;
      note_drag_layer = edit_layer;
      note_drag_pad = pad_i;
      note_drag_start_y = mouse_y;
      note_drag_origin = get_pad_note(edit_layer, pad_i);
    ) : in_rect(mouse_x, mouse_y, pad_x, pad_y, pad_w, pad_h) ? (
      selected_pad == pad_i ? queue_ui_audition(edit_layer, pad_i) : selected_pad = pad_i;
    );
    pad_i += 1;
  );

  editor_x = side_x;
  editor_y = side_y;
  editor_w = right_col_w;
  editor_pad = 12 * ui_scale;
  button_gap = 8 * ui_scale;
  btn_w_1 = (editor_w - editor_pad * 2 - button_gap * 3) / 4;
  big_btn_w = (editor_w - editor_pad * 2 - button_gap) / 2;
  big_btn_h = 32 * ui_scale;
  btn_y_2 = editor_y + editor_h - big_btn_h - 12 * ui_scale;
  btn_y_1 = btn_y_2 - 32 * ui_scale - 8 * ui_scale;

  in_rect(mouse_x, mouse_y, editor_x + editor_pad, btn_y_1, btn_w_1, 32 * ui_scale) ? set_pad_note(edit_layer, selected_pad, get_pad_note(edit_layer, selected_pad) - 12);
  in_rect(mouse_x, mouse_y, editor_x + editor_pad + (btn_w_1 + button_gap), btn_y_1, btn_w_1, 32 * ui_scale) ? set_pad_note(edit_layer, selected_pad, get_pad_note(edit_layer, selected_pad) - 1);
  in_rect(mouse_x, mouse_y, editor_x + editor_pad + (btn_w_1 + button_gap) * 2, btn_y_1, btn_w_1, 32 * ui_scale) ? set_pad_note(edit_layer, selected_pad, get_pad_note(edit_layer, selected_pad) + 1);
  in_rect(mouse_x, mouse_y, editor_x + editor_pad + (btn_w_1 + button_gap) * 3, btn_y_1, btn_w_1, 32 * ui_scale) ? set_pad_note(edit_layer, selected_pad, get_pad_note(edit_layer, selected_pad) + 12);
  in_rect(mouse_x, mouse_y, editor_x + editor_pad, btn_y_2, big_btn_w, big_btn_h) ? set_pad_note(edit_layer, selected_pad, default_note(edit_layer, selected_pad));
  in_rect(mouse_x, mouse_y, editor_x + editor_pad + big_btn_w + button_gap, btn_y_2, big_btn_w, big_btn_h) ? queue_ui_audition(edit_layer, selected_pad);
);

mouse_down && note_drag_active ? (
  drag_note_step = floor((note_drag_start_y - mouse_y) / (18 * ui_scale));
  set_pad_note(note_drag_layer, note_drag_pad, note_drag_origin + drag_note_step);
);
!mouse_down ? note_drag_active = 0;

mouse_down && layer_row_drag_active ? (
  drag_row_step = floor((layer_row_drag_start_y - mouse_y) / (18 * ui_scale));
  set_layer_row_value(layer_row_drag_layer, layer_row_drag_row, layer_row_drag_origin + drag_row_step);
);
!mouse_down ? layer_row_drag_active = 0;

mouse_down && header_drag_active ? (
  drag_header_step = floor((header_drag_start_y - mouse_y) / (18 * ui_scale));
  header_drag_control == 0 ? set_total_bars(stepped_total_bars(header_drag_origin, drag_header_step));
  header_drag_control == 1 ? set_poi_count(header_drag_origin + drag_header_step);
  header_drag_control == 2 ? set_seed_value(header_drag_origin + drag_header_step);
);
!mouse_down ? header_drag_active = 0;

mouse_down && global_drag_active ? (
  drag_global_step = floor((global_drag_start_y - mouse_y) / (18 * ui_scale));
  global_drag_control == 4 ? (
    set_global_control_value(global_drag_control, global_drag_origin + drag_global_step);
  ) : (
    set_global_control_value(global_drag_control, global_drag_origin + drag_global_step);
  );
);
!mouse_down ? global_drag_active = 0;

mouse_shift && (mouse_wheel != 0) ? (
  wheel_steps = floor(abs(mouse_wheel) / 60);
  wheel_steps < 1 ? wheel_steps = 1;
  mouse_wheel < 0 ? wheel_steps = -wheel_steps;
  wheel_handled = 0;
  pad_i = 0;
  while ((pad_i < NUM_PADS) && !wheel_handled) (
    col_i = pad_i % cols;
    row_i = floor(pad_i / cols);
    pad_x = grid_x + col_i * (pad_w + gap);
    pad_y = grid_y + row_i * (pad_h + gap);
    note_hit_x = pad_x + 8 * ui_scale;
    note_hit_y = pad_y + 50 * ui_scale;
    note_hit_w = pad_w - 16 * ui_scale;
    note_hit_h = 24 * ui_scale;
    in_rect(mouse_x, mouse_y, note_hit_x, note_hit_y, note_hit_w, note_hit_h) ? (
      selected_pad = pad_i;
      set_pad_note(edit_layer, pad_i, get_pad_note(edit_layer, pad_i) + wheel_steps);
      wheel_handled = 1;
      mouse_wheel = 0;
    );
    pad_i += 1;
  );
);

last_mouse_down = mouse_down;

pad_i = 0;
while (pad_i < NUM_PADS) (
  slot_activity[pad_i] = max(0, slot_activity[pad_i] * 0.90 - 0.01);
  pad_i += 1;
);

layer_i = 0;
while (layer_i < NUM_LAYERS) (
  pad_i = 0;
  while (pad_i < NUM_PADS) (
    layer_activity[layer_pad_index(layer_i, pad_i)] = max(0, layer_activity[layer_pad_index(layer_i, pad_i)] * 0.90 - 0.01);
    pad_i += 1;
  );
  layer_i += 1;
);

gfx_set(0.07, 0.09, 0.11, 1);
gfx_rect(0, 0, gfx_w, gfx_h, 1);

gfx_set(0.11, 0.14, 0.18, 1);
gfx_rect(margin, header_y, gfx_w - margin * 2, header_h, 1);

gfx_setfont(1, "Verdana", floor(19 * ui_scale));
gfx_set(0.95, 0.96, 0.98, 1);
gfx_x = margin + 14 * ui_scale;
gfx_y = header_y + 15 * ui_scale;
gfx_drawstr("CrescendoWerk v1");

gfx_setfont(2, "Verdana", floor(15 * ui_scale));
header_status_x = margin + 360 * ui_scale;
gfx_x = header_status_x;
gfx_y = header_y + 18 * ui_scale;
transport_is_playing ? sprintf(#header_status, "Playing") : sprintf(#header_status, "Stopped");
gfx_drawstr(#header_status);

header_ctrl_w = 20 * ui_scale;
header_val_w = 48 * ui_scale;
header_ctrl_gap = 6 * ui_scale;
header_group_y = header_y + 14 * ui_scale;
transport_box_w = 268 * ui_scale;
transport_box_x = margin + 450 * ui_scale;
bars_label_w = 30 * ui_scale;
poi_label_w = 24 * ui_scale;
seed_label_w = 28 * ui_scale;

gfx_set(0.18, 0.22, 0.28, 1);
gfx_rect(transport_box_x, header_y + 13 * ui_scale, transport_box_w, 28 * ui_scale, 1);
gfx_setfont(2, "Verdana", floor(15 * ui_scale));
gfx_set(0.95, 0.96, 0.98, 1);
gfx_x = transport_box_x + 10 * ui_scale;
gfx_y = header_y + 18 * ui_scale;
sprintf(#header_pos, "Bar %03d  Step %02d  Cycle %03d", current_bar + 1, current_step_in_bar + 1, planned_total_bars);
gfx_drawstr(#header_pos);

bars_minus_x = transport_box_x + transport_box_w + 28 * ui_scale;
bars_value_x = bars_minus_x + header_ctrl_w + header_ctrl_gap;
bars_plus_x = bars_value_x + header_val_w + header_ctrl_gap;

poi_minus_x = bars_plus_x + 54 * ui_scale;
poi_value_x = poi_minus_x + header_ctrl_w + header_ctrl_gap;
poi_plus_x = poi_value_x + header_val_w + header_ctrl_gap;

seed_minus_x = poi_plus_x + 54 * ui_scale;
seed_value_x = seed_minus_x + header_ctrl_w + header_ctrl_gap;
seed_plus_x = seed_value_x + (header_val_w + 22 * ui_scale) + header_ctrl_gap;

gfx_setfont(3, "Verdana", floor(12 * ui_scale));
gfx_set(0.92, 0.94, 0.97, 1);
gfx_x = bars_minus_x - bars_label_w;
gfx_y = header_y + 18 * ui_scale;
gfx_drawstr("Bars");
gfx_x = poi_minus_x - poi_label_w;
gfx_drawstr("POIs");
gfx_x = seed_minus_x - seed_label_w;
gfx_drawstr("Seed");

gfx_set(0.24, 0.27, 0.33, 1);
gfx_rect(bars_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);
gfx_rect(bars_value_x, header_group_y, header_val_w, 24 * ui_scale, 1);
gfx_rect(bars_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);
gfx_rect(poi_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);
gfx_rect(poi_value_x, header_group_y, header_val_w, 24 * ui_scale, 1);
gfx_rect(poi_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);
gfx_rect(seed_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);
gfx_rect(seed_value_x, header_group_y, header_val_w + 22 * ui_scale, 24 * ui_scale, 1);
gfx_rect(seed_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);

gfx_set(1, 1, 1, 1);
gfx_x = bars_minus_x + 6 * ui_scale;
gfx_y = header_group_y + 5 * ui_scale;
gfx_drawstr("-");
gfx_x = bars_value_x + 11 * ui_scale;
sprintf(#bars_ui_txt, "%03d", planned_total_bars);
gfx_drawstr(#bars_ui_txt);
gfx_x = bars_plus_x + 5 * ui_scale;
gfx_drawstr("+");

gfx_x = poi_minus_x + 6 * ui_scale;
gfx_y = header_group_y + 5 * ui_scale;
gfx_drawstr("-");
gfx_x = poi_value_x + 11 * ui_scale;
sprintf(#poi_ui_txt, "%02d", planned_poi_count > 0 ? planned_poi_count : snap_poi_count(poi_count, total_bars, poi_length));
gfx_drawstr(#poi_ui_txt);
gfx_x = poi_plus_x + 5 * ui_scale;
gfx_drawstr("+");

gfx_x = seed_minus_x + 6 * ui_scale;
gfx_y = header_group_y + 5 * ui_scale;
gfx_drawstr("-");
gfx_x = seed_value_x + 9 * ui_scale;
sprintf(#seed_ui_txt, "%06d", floor(seed + 0.5));
gfx_drawstr(#seed_ui_txt);
gfx_x = seed_plus_x + 5 * ui_scale;
gfx_drawstr("+");

slider_toggle_w = 122 * ui_scale;
slider_toggle_h = 26 * ui_scale;
slider_toggle_x = gfx_w - margin - slider_toggle_w;
slider_toggle_y = header_y + 15 * ui_scale;
host_sliders_visible ? gfx_set(0.54, 0.38, 0.15, 1) : gfx_set(0.19, 0.22, 0.28, 1);
gfx_rect(slider_toggle_x, slider_toggle_y, slider_toggle_w, slider_toggle_h, 1);
gfx_setfont(3, "Verdana", floor(12 * ui_scale));
gfx_set(1, 1, 1, 1);
gfx_x = slider_toggle_x + 10 * ui_scale;
gfx_y = slider_toggle_y + 7 * ui_scale;
host_sliders_visible ? gfx_drawstr("Hide Sliders") : gfx_drawstr("Show Sliders");

panel_w = (gfx_w - margin * 2 - gap * 2) / 3;
layer_i = 0;
while (layer_i < NUM_LAYERS) (
  panel_x = margin + layer_i * (panel_w + gap);
  panel_y = strip_y;
  panel_pad = 10 * ui_scale;
  panel_armed = layer_can_emit(layer_i);
  panel_active = transport_is_playing && panel_armed;
  panel_muted = layer_muted(layer_i);
  panel_enabled = layer_enabled(layer_i);
  panel_filtered = any_layer_soloed() && panel_enabled && !panel_muted && !layer_soloed(layer_i);

  panel_active ? (
    gfx_set(0.14, 0.30, 0.27, 1);
  ) :
  panel_armed ? (
    gfx_set(0.17, 0.23, 0.28, 1);
  ) :
  panel_muted ? (
    gfx_set(0.23, 0.16, 0.16, 1);
  ) :
  panel_enabled ? (
    gfx_set(0.17, 0.18, 0.22, 1);
  ) : (
    gfx_set(0.12, 0.13, 0.16, 1);
  );
  gfx_rect(panel_x, panel_y, panel_w, strip_h, 1);

  gfx_setfont(1, "Verdana", floor(18 * ui_scale));
  gfx_set(1, 1, 1, 1);
  gfx_x = panel_x + panel_pad;
  gfx_y = panel_y + 8 * ui_scale;
  layer_full_name(layer_i);
  gfx_drawstr(#layer_full_txt);

  gfx_setfont(3, "Verdana", floor(12 * ui_scale));
  gfx_x = panel_x + panel_w - 118 * ui_scale;
  gfx_y = panel_y + 12 * ui_scale;
  panel_active ? (
    gfx_drawstr("Generating");
  ) :
  panel_filtered ? (
    gfx_drawstr("Solo-filtered");
  ) :
  panel_muted ? (
    gfx_drawstr("Muted");
  ) :
  panel_armed ? (
    gfx_drawstr("Armed");
  ) :
  panel_enabled ? (
    gfx_drawstr("Ready");
  ) : (
    gfx_drawstr("Disabled");
  );

  bool_y = panel_y + 34 * ui_scale;
  bool_h = 26 * ui_scale;
  bool_w = (panel_w - panel_pad * 2 - gap * 2) / 3;

  gfx_set(layer_enabled(layer_i) ? 0.20 : 0.14, layer_enabled(layer_i) ? 0.56 : 0.19, 0.26, 1);
  gfx_rect(panel_x + panel_pad, bool_y, bool_w, bool_h, 1);
  gfx_set(layer_muted(layer_i) ? 0.62 : 0.20, layer_muted(layer_i) ? 0.24 : 0.23, 0.21, 1);
  gfx_rect(panel_x + panel_pad + bool_w + gap, bool_y, bool_w, bool_h, 1);
  gfx_set(layer_soloed(layer_i) ? 0.68 : 0.22, layer_soloed(layer_i) ? 0.50 : 0.23, layer_soloed(layer_i) ? 0.16 : 0.27, 1);
  gfx_rect(panel_x + panel_pad + (bool_w + gap) * 2, bool_y, bool_w, bool_h, 1);

  gfx_setfont(3, "Verdana", floor(12 * ui_scale));
  gfx_set(1, 1, 1, 1);
  gfx_x = panel_x + panel_pad + 10 * ui_scale;
  gfx_y = bool_y + 6 * ui_scale;
  gfx_drawstr("Enable");
  gfx_x = panel_x + panel_pad + bool_w + gap + 14 * ui_scale;
  gfx_drawstr("Mute");
  gfx_x = panel_x + panel_pad + (bool_w + gap) * 2 + 16 * ui_scale;
  gfx_drawstr("Solo");

  row_h = 22 * ui_scale;
  ctrl_w = 22 * ui_scale;
  value_w = 62 * ui_scale;
  step_x_minus = panel_x + panel_w - panel_pad - ctrl_w - value_w - ctrl_w - gap * 2;
  row_y = panel_y + 68 * ui_scale;

  gfx_setfont(2, "Verdana", floor(14 * ui_scale));
  gfx_set(0.92, 0.94, 0.97, 1);
  gfx_x = panel_x + panel_pad;
  gfx_y = row_y + 4 * ui_scale;
  gfx_drawstr("Channel");
  gfx_set(0.24, 0.27, 0.33, 1);
  gfx_rect(step_x_minus, row_y, ctrl_w, row_h, 1);
  gfx_rect(step_x_minus + ctrl_w + gap, row_y, value_w, row_h, 1);
  gfx_rect(step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h, 1);
  gfx_set(1, 1, 1, 1);
  gfx_x = step_x_minus + 7 * ui_scale;
  gfx_y = row_y + 4 * ui_scale;
  gfx_drawstr("-");
  gfx_x = step_x_minus + ctrl_w + gap + 18 * ui_scale;
  sprintf(#val_txt, "%d", layer_channel_display(layer_i));
  gfx_drawstr(#val_txt);
  gfx_x = step_x_minus + ctrl_w + gap + value_w + gap + 6 * ui_scale;
  gfx_drawstr("+");

  row_y += row_h + 6 * ui_scale;
  gfx_x = panel_x + panel_pad;
  gfx_y = row_y + 4 * ui_scale;
  gfx_drawstr("Density");
  gfx_set(0.24, 0.27, 0.33, 1);
  gfx_rect(step_x_minus, row_y, ctrl_w, row_h, 1);
  gfx_rect(step_x_minus + ctrl_w + gap, row_y, value_w, row_h, 1);
  gfx_rect(step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h, 1);
  gfx_set(1, 1, 1, 1);
  gfx_x = step_x_minus + 7 * ui_scale;
  gfx_y = row_y + 4 * ui_scale;
  gfx_drawstr("-");
  gfx_x = step_x_minus + ctrl_w + gap + 14 * ui_scale;
  sprintf(#val_txt, "%d", layer_density(layer_i));
  gfx_drawstr(#val_txt);
  gfx_x = step_x_minus + ctrl_w + gap + value_w + gap + 6 * ui_scale;
  gfx_drawstr("+");

  row_y += row_h + 6 * ui_scale;
  gfx_x = panel_x + panel_pad;
  gfx_y = row_y + 4 * ui_scale;
  gfx_drawstr("Variation");
  gfx_set(0.24, 0.27, 0.33, 1);
  gfx_rect(step_x_minus, row_y, ctrl_w, row_h, 1);
  gfx_rect(step_x_minus + ctrl_w + gap, row_y, value_w, row_h, 1);
  gfx_rect(step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h, 1);
  gfx_set(1, 1, 1, 1);
  gfx_x = step_x_minus + 7 * ui_scale;
  gfx_y = row_y + 4 * ui_scale;
  gfx_drawstr("-");
  gfx_x = step_x_minus + ctrl_w + gap + 14 * ui_scale;
  sprintf(#val_txt, "%d", layer_variation(layer_i));
  gfx_drawstr(#val_txt);
  gfx_x = step_x_minus + ctrl_w + gap + value_w + gap + 6 * ui_scale;
  gfx_drawstr("+");

  row_y += row_h + 6 * ui_scale;
  gfx_x = panel_x + panel_pad;
  gfx_y = row_y + 4 * ui_scale;
  gfx_drawstr("Velocity");
  gfx_set(0.24, 0.27, 0.33, 1);
  gfx_rect(step_x_minus, row_y, ctrl_w, row_h, 1);
  gfx_rect(step_x_minus + ctrl_w + gap, row_y, value_w, row_h, 1);
  gfx_rect(step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h, 1);
  gfx_set(1, 1, 1, 1);
  gfx_x = step_x_minus + 7 * ui_scale;
  gfx_y = row_y + 4 * ui_scale;
  gfx_drawstr("-");
  gfx_x = step_x_minus + ctrl_w + gap + 10 * ui_scale;
  sprintf(#val_txt, "%d%%", layer_velocity_scale(layer_i));
  gfx_drawstr(#val_txt);
  gfx_x = step_x_minus + ctrl_w + gap + value_w + gap + 6 * ui_scale;
  gfx_drawstr("+");

  layer_i += 1;
);

tab_w = (gfx_w - margin * 2 - gap * 4) / 5;

gfx_setfont(3, "Verdana", floor(11 * ui_scale));
gfx_set(0.62, 0.67, 0.74, 1);
gfx_x = margin;
gfx_y = tabs_y - 14 * ui_scale;
gfx_drawstr("Edit Tabs");
gfx_x = margin + (tab_w + gap) * 3;
gfx_drawstr("Preview Tabs");

tab_i = 0;
while (tab_i < 5) (
  tab_x = margin + tab_i * (tab_w + gap);
  tab_active = (tab_i == edit_layer) || ((tab_i == 3) && (preview_mode == 0)) || ((tab_i == 4) && (preview_mode == 1));

  tab_i < 3 ? (
    tab_active ? gfx_set(0.16, 0.43, 0.60, 1) : gfx_set(0.17, 0.20, 0.25, 1);
  ) : (
    tab_active ? gfx_set(0.60, 0.34, 0.13, 1) : gfx_set(0.17, 0.20, 0.25, 1);
  );
  gfx_rect(tab_x, tabs_y, tab_w, tabs_h, 1);

  gfx_setfont(2, "Verdana", floor(14 * ui_scale));
  gfx_set(1, 1, 1, 1);
  gfx_x = tab_x + 10 * ui_scale;
  gfx_y = tabs_y + 10 * ui_scale;
  tab_i == 0 ? gfx_drawstr("Edit Patient");
  tab_i == 1 ? gfx_drawstr("Edit Procession");
  tab_i == 2 ? gfx_drawstr("Edit Weight");
  tab_i == 3 ? gfx_drawstr("Combined");
  tab_i == 4 ? gfx_drawstr("Form");
  tab_i += 1;
);

gfx_set(0.11, 0.14, 0.18, 1);
gfx_rect(margin, globals_y, gfx_w - margin * 2, globals_h, 1);

gfx_setfont(2, "Verdana", floor(15 * ui_scale));
gfx_set(1, 1, 1, 1);
gfx_x = margin + 12 * ui_scale;
gfx_y = globals_y + 10 * ui_scale;
gfx_drawstr("Global Arc Controls");

gfx_setfont(3, "Verdana", floor(11 * ui_scale));
gfx_set(0.74, 0.79, 0.86, 1);
gfx_x = margin + 12 * ui_scale;
gfx_y = globals_y + 28 * ui_scale;
gfx_drawstr("Form, density, long-range lift, and halftime routing.");

global_cols = 4;
global_cell_w = (gfx_w - margin * 2 - gap * (global_cols - 1)) / global_cols;
global_cell_h = 34 * ui_scale;
global_row_gap = 10 * ui_scale;
global_ctrl_w = 18 * ui_scale;
global_val_w = 60 * ui_scale;
global_cluster_w = global_ctrl_w + 6 * ui_scale + global_val_w + 6 * ui_scale + global_ctrl_w;
global_controls_y = globals_y + 40 * ui_scale;
control_i = 0;
while (control_i < 20) (
  control_row = floor(control_i / global_cols);
  control_col = control_i % global_cols;
  control_x = margin + control_col * (global_cell_w + gap);
  control_y = global_controls_y + control_row * (global_cell_h + global_row_gap);
  minus_x = control_x + (global_cell_w - global_cluster_w) * 0.5;
  value_x = minus_x + global_ctrl_w + 6 * ui_scale;
  plus_x = value_x + global_val_w + 6 * ui_scale;

  global_control_label(control_i);
  global_control_value_text(control_i);

  gfx_set(0.14, 0.18, 0.24, 1);
  gfx_rect(control_x, control_y, global_cell_w, global_cell_h, 1);

  gfx_setfont(3, "Verdana", floor(12 * ui_scale));
  gfx_set(0.88, 0.90, 0.94, 1);
  gfx_x = control_x + 8 * ui_scale;
  gfx_y = control_y + 4 * ui_scale;
  gfx_drawstr(#global_label_txt);

  gfx_set(0.24, 0.27, 0.33, 1);
  gfx_rect(minus_x, control_y + 14 * ui_scale, global_ctrl_w, 16 * ui_scale, 1);
  gfx_rect(value_x, control_y + 14 * ui_scale, global_val_w, 16 * ui_scale, 1);
  gfx_rect(plus_x, control_y + 14 * ui_scale, global_ctrl_w, 16 * ui_scale, 1);

  gfx_set(1, 1, 1, 1);
  gfx_x = minus_x + 5 * ui_scale;
  gfx_y = control_y + 16 * ui_scale;
  gfx_drawstr("-");
  gfx_x = value_x + 8 * ui_scale;
  gfx_drawstr(#global_val_txt);
  gfx_x = plus_x + 5 * ui_scale;
  gfx_drawstr("+");
  control_i += 1;
);

cols = 4;
rows = 3;
pad_w = (grid_w - gap * (cols - 1)) / cols;
pad_h = (grid_h - gap * (rows - 1)) / rows;

pad_i = 0;
while (pad_i < NUM_PADS) (
  col_i = pad_i % cols;
  row_i = floor(pad_i / cols);
  pad_x = grid_x + col_i * (pad_w + gap);
  pad_y = grid_y + row_i * (pad_h + gap);

  flash_i = min(1.0, layer_activity[layer_pad_index(edit_layer, pad_i)]);
  selected_pad == pad_i ? (
    gfx_set(0.18 + flash_i * 0.25, 0.33 + flash_i * 0.20, 0.57 + flash_i * 0.16, 1);
  ) : (
    gfx_set(0.14 + flash_i * 0.22, 0.16 + flash_i * 0.18, 0.20 + flash_i * 0.14, 1);
  );
  gfx_rect(pad_x, pad_y, pad_w, pad_h, 1);

  selected_pad == pad_i ? (
    gfx_set(0.98, 0.83, 0.31, 1);
    gfx_rect(pad_x, pad_y, pad_w, 4 * ui_scale, 1);
  );

  gfx_setfont(2, "Verdana", floor(15 * ui_scale));
  gfx_set(1, 1, 1, 1);
  gfx_x = pad_x + 10 * ui_scale;
  gfx_y = pad_y + 10 * ui_scale;
  sprintf(#pad_num_txt, "Pad %d", pad_i + 1);
  gfx_drawstr(#pad_num_txt);

  gfx_setfont(3, "Verdana", floor(12 * ui_scale));
  gfx_x = pad_x + 10 * ui_scale;
  gfx_y = pad_y + 34 * ui_scale;
  role_name(edit_layer, role_for_pad(edit_layer, pad_i));
  gfx_drawstr(#role_txt);

  gfx_setfont(2, "Verdana", floor(14 * ui_scale));
  gfx_x = pad_x + 10 * ui_scale;
  gfx_y = pad_y + 58 * ui_scale;
  sprintf(#pad_note_txt, "Note %d", get_pad_note(edit_layer, pad_i));
  gfx_drawstr(#pad_note_txt);

  gfx_setfont(3, "Verdana", floor(11 * ui_scale));
  gfx_x = pad_x + 10 * ui_scale;
  gfx_y = pad_y + pad_h - 22 * ui_scale;
  selected_pad == pad_i ? gfx_drawstr("Tap again to audition") : gfx_drawstr("Tap to select");

  pad_i += 1;
);

gfx_set(0.11, 0.14, 0.18, 1);
gfx_rect(side_x, side_y, right_col_w, editor_h, 1);

gfx_setfont(1, "Verdana", floor(18 * ui_scale));
gfx_set(1, 1, 1, 1);
gfx_x = side_x + 12 * ui_scale;
gfx_y = side_y + 10 * ui_scale;
layer_full_name(edit_layer);
sprintf(#editor_title, "Pad %d  %s", selected_pad + 1, #layer_full_txt);
gfx_drawstr(#editor_title);

gfx_setfont(2, "Verdana", floor(15 * ui_scale));
gfx_x = side_x + 12 * ui_scale;
gfx_y = side_y + 38 * ui_scale;
role_name(edit_layer, role_for_pad(edit_layer, selected_pad));
gfx_drawstr(#role_txt);

gfx_setfont(1, "Verdana", floor(20 * ui_scale));
gfx_x = side_x + 12 * ui_scale;
gfx_y = side_y + 62 * ui_scale;
sprintf(#editor_note_txt, "Note %d  Ch %d", get_pad_note(edit_layer, selected_pad), layer_channel_display(edit_layer));
gfx_drawstr(#editor_note_txt);

editor_x = side_x;
editor_y = side_y;
editor_w = right_col_w;
editor_pad = 12 * ui_scale;
button_gap = 8 * ui_scale;
btn_h = 32 * ui_scale;
btn_w_1 = (editor_w - editor_pad * 2 - button_gap * 3) / 4;
big_btn_w = (editor_w - editor_pad * 2 - button_gap) / 2;
big_btn_h = 32 * ui_scale;
btn_y_2 = editor_y + editor_h - big_btn_h - 12 * ui_scale;
btn_y_1 = btn_y_2 - btn_h - 8 * ui_scale;
hint_y = max(editor_y + 88 * ui_scale, btn_y_1 - 14 * ui_scale);

gfx_set(0.24, 0.27, 0.33, 1);
gfx_rect(editor_x + editor_pad, btn_y_1, btn_w_1, btn_h, 1);
gfx_rect(editor_x + editor_pad + (btn_w_1 + button_gap), btn_y_1, btn_w_1, btn_h, 1);
gfx_rect(editor_x + editor_pad + (btn_w_1 + button_gap) * 2, btn_y_1, btn_w_1, btn_h, 1);
gfx_rect(editor_x + editor_pad + (btn_w_1 + button_gap) * 3, btn_y_1, btn_w_1, btn_h, 1);
gfx_rect(editor_x + editor_pad, btn_y_2, big_btn_w, big_btn_h, 1);
gfx_rect(editor_x + editor_pad + big_btn_w + button_gap, btn_y_2, big_btn_w, big_btn_h, 1);

gfx_setfont(2, "Verdana", floor(15 * ui_scale));
gfx_set(1, 1, 1, 1);
gfx_x = editor_x + editor_pad + 10 * ui_scale;
gfx_y = btn_y_1 + 8 * ui_scale;
gfx_drawstr("-12");
gfx_x = editor_x + editor_pad + (btn_w_1 + button_gap) + 14 * ui_scale;
gfx_drawstr("-1");
gfx_x = editor_x + editor_pad + (btn_w_1 + button_gap) * 2 + 14 * ui_scale;
gfx_drawstr("+1");
gfx_x = editor_x + editor_pad + (btn_w_1 + button_gap) * 3 + 10 * ui_scale;
gfx_drawstr("+12");
gfx_x = editor_x + editor_pad + 16 * ui_scale;
gfx_y = btn_y_2 + 8 * ui_scale;
gfx_drawstr("Default");
gfx_x = editor_x + editor_pad + big_btn_w + button_gap + 14 * ui_scale;
gfx_drawstr("Audition");

gfx_setfont(3, "Verdana", floor(11 * ui_scale));
gfx_x = side_x + 12 * ui_scale;
gfx_y = hint_y;
gfx_drawstr("Drag note or Shift+wheel.");

preview_y = side_y + editor_h + gap;
preview_w = right_col_w;

gfx_set(0.11, 0.14, 0.18, 1);
gfx_rect(side_x, preview_y, preview_w, preview_h, 1);

gfx_setfont(2, "Verdana", floor(15 * ui_scale));
gfx_set(1, 1, 1, 1);
gfx_x = side_x + 12 * ui_scale;
gfx_y = preview_y + 10 * ui_scale;
preview_mode == 0 ? sprintf(#preview_title, "Combined Preview") : sprintf(#preview_title, "Form Preview");
gfx_drawstr(#preview_title);

gfx_setfont(3, "Verdana", floor(11 * ui_scale));
gfx_x = side_x + 12 * ui_scale;
gfx_y = preview_y + 28 * ui_scale;
preview_mode == 0 ? (
  role_name(edit_layer, role_for_pad(edit_layer, selected_pad));
  sprintf(#preview_sub_txt, "Selected role: %s. Rows show current bar activity by layer.", #role_txt);
) : (
  sprintf(#preview_sub_txt, "Legend maps bar classes. Inner lift shows macro intensity.");
);
gfx_drawstr(#preview_sub_txt);

preview_body_y = preview_y + 52 * ui_scale;
preview_body_h = preview_h - 64 * ui_scale;
preview_body_h < (48 * ui_scale) ? preview_body_h = 48 * ui_scale;

preview_mode == 0 ? (
  label_w = 64 * ui_scale;
  cell_area_x = side_x + label_w + 14 * ui_scale;
  cell_area_w = preview_w - label_w - 24 * ui_scale;
  cell_w = cell_area_w / 16;
  cell_h = min(24 * ui_scale, (preview_body_h - 16 * ui_scale) / 3);
  row_gap = 8 * ui_scale;
  row_y = preview_body_y;
  row_i = 0;
  while (row_i < 3) (
    preview_layer_i = row_i;
    role_i = role_for_pad(preview_layer_i, selected_pad);

    gfx_setfont(3, "Verdana", floor(12 * ui_scale));
    gfx_set(0.88, 0.90, 0.94, 1);
    gfx_x = side_x + 12 * ui_scale;
    gfx_y = row_y + 6 * ui_scale;
    layer_name(preview_layer_i);
    gfx_drawstr(#layer_txt);

    step_i = 0;
    while (step_i < 16) (
      cell_x = cell_area_x + step_i * cell_w;
      hit_i = layer_role_velocity(preview_layer_i, role_i, current_bar, step_i, current_bar, 0);
      hit_i > 0 ? (
        preview_layer_i == LAYER_PATIENT ? gfx_set(0.21, 0.53, 0.82, 1);
        preview_layer_i == LAYER_PROCESSION ? gfx_set(0.69, 0.40, 0.14, 1);
        preview_layer_i == LAYER_WEIGHT ? gfx_set(0.23, 0.57, 0.33, 1);
      ) : (
        gfx_set(0.21, 0.23, 0.28, 1);
      );
      gfx_rect(cell_x + 2, row_y, cell_w - 4, cell_h, 1);

      step_i == current_step_in_bar ? (
        gfx_set(0.96, 0.83, 0.27, 1);
        gfx_rect(cell_x + 2, row_y, cell_w - 4, 4 * ui_scale, 1);
      );

      gfx_setfont(3, "Verdana", floor(10 * ui_scale));
      gfx_set(1, 1, 1, 1);
      gfx_x = cell_x + 6 * ui_scale;
      gfx_y = row_y + 7 * ui_scale;
      sprintf(#step_txt, "%d", step_i + 1);
      gfx_drawstr(#step_txt);

      step_i += 1;
    );

    row_y += cell_h + row_gap;
    row_i += 1;
  );
) : (
  form_x = side_x + 12 * ui_scale;
  form_w = preview_w - 24 * ui_scale;
  legend_gap = 8 * ui_scale;
  legend_h = min(60 * ui_scale, preview_body_h * 0.46);
  form_cell_h = max(26 * ui_scale, preview_body_h - legend_h - legend_gap);
  form_y = preview_body_y;
  legend_y = form_y + form_cell_h + legend_gap;

  gfx_set(0.15, 0.18, 0.23, 1);
  gfx_rect(form_x, form_y, form_w, form_cell_h, 1);

  bar_i = 0;
  while (bar_i < planned_total_bars) (
    class_i = bar_class_value(bar_i);
    macro_i = macro_section_value(bar_i);
    macro_amt = macro_section_intensity(macro_i);
    cell_x = form_x + floor(bar_i * form_w / max(planned_total_bars, 1));
    next_x = form_x + floor((bar_i + 1) * form_w / max(planned_total_bars, 1));
    draw_w = max(1, next_x - cell_x - 1);
    set_bar_class_color(class_i);
    gfx_rect(cell_x, form_y, draw_w, form_cell_h, 1);

    inner_w = max(1, draw_w - 2);
    inner_h = max(3 * ui_scale, floor((form_cell_h - 8 * ui_scale) * macro_amt));
    gfx_set(0.96, 0.97, 0.99, 0.08 + macro_amt * 0.20);
    gfx_rect(cell_x + 1, form_y + form_cell_h - inner_h - 2 * ui_scale, inner_w, inner_h, 1);

    bar_i == current_bar ? (
      gfx_set(0.96, 0.83, 0.27, 1);
      gfx_rect(cell_x, form_y, draw_w, 4 * ui_scale, 1);
    );
    bar_i += 1;
  );

  gfx_set(0.30, 0.34, 0.40, 1);
  gfx_rect(form_x, form_y + form_cell_h, form_w, 1, 1);

  legend_cols = 4;
  legend_item_w = form_w / legend_cols;
  legend_row_h = 16 * ui_scale;
  swatch_w = 12 * ui_scale;
  swatch_h = 10 * ui_scale;
  class_i = 0;
  while (class_i < 8) (
    legend_col_i = class_i % legend_cols;
    legend_row_i = floor(class_i / legend_cols);
    legend_item_x = form_x + legend_col_i * legend_item_w;
    legend_item_y = legend_y + legend_row_i * legend_row_h;
    set_bar_class_color(class_i);
    gfx_rect(legend_item_x, legend_item_y + 2 * ui_scale, swatch_w, swatch_h, 1);
    gfx_setfont(3, "Verdana", floor(10 * ui_scale));
    gfx_set(0.88, 0.90, 0.94, 1);
    gfx_x = legend_item_x + swatch_w + 6 * ui_scale;
    gfx_y = legend_item_y;
    bar_class_legend_name(class_i);
    gfx_drawstr(#class_txt);
    class_i += 1;
  );

  ramp_y = legend_y + legend_row_h * 2 + 6 * ui_scale;
  gfx_setfont(3, "Verdana", floor(10 * ui_scale));
  gfx_set(0.82, 0.85, 0.89, 1);
  gfx_x = form_x;
  gfx_y = ramp_y - 1 * ui_scale;
  gfx_drawstr("Macro Intensity");

  ramp_x = form_x + 88 * ui_scale;
  ramp_w = min(form_w - 112 * ui_scale, 144 * ui_scale);
  ramp_w < (54 * ui_scale) ? ramp_w = 54 * ui_scale;
  ramp_h = 10 * ui_scale;
  ramp_steps = 6;
  ramp_step_w = ramp_w / ramp_steps;
  ramp_i = 0;
  while (ramp_i < ramp_steps) (
    ramp_amt = ramp_i / max(ramp_steps - 1, 1);
    gfx_set(0.96, 0.97, 0.99, 0.10 + ramp_amt * 0.28);
    gfx_rect(ramp_x + ramp_i * ramp_step_w, ramp_y, max(1, ramp_step_w - 1), ramp_h, 1);
    ramp_i += 1;
  );
  gfx_set(0.70, 0.74, 0.79, 1);
  gfx_x = ramp_x + ramp_w + 8 * ui_scale;
  gfx_y = ramp_y - 1 * ui_scale;
  gfx_drawstr("Low  High");
);
