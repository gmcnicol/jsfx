function adjust_global_control(control_i, delta_i)
(
  control_i == 0 ? set_master_note_length(master_note_length + delta_i) :
  control_i == 1 ? set_tempo_reference(tempo_reference + delta_i) :
  control_i == 2 ? set_fill_frequency(fill_frequency + delta_i) :
  control_i == 3 ? set_poi_intensity(poi_intensity + delta_i) :
  control_i == 4 ? set_percussion_amount(percussion_amount + delta_i) :
  control_i == 5 ? set_tom_motion(tom_motion + delta_i) :
  control_i == 6 ? set_cymbal_wash(cymbal_wash + delta_i) :
  control_i == 7 ? set_repetition_bias(repetition_bias + delta_i) :
  control_i == 8 ? set_dynamic_lift(dynamic_lift + delta_i) :
  control_i == 9 ? set_macro_dynamics(macro_dynamics + delta_i) :
  control_i == 10 ? set_velocity_drift(velocity_drift + delta_i) :
  control_i == 11 ? set_density_drift(density_drift + delta_i) :
  control_i == 12 ? set_layer_arc_offset(layer_arc_offset + delta_i) :
  control_i == 13 ? set_late_bloom_bias(late_bloom_bias + delta_i) :
  control_i == 14 ? set_turnaround_zone_length(turnaround_zone_length + delta_i) :
  control_i == 15 ? set_groove_tightness(groove_tightness + delta_i) :
  control_i == 16 ? set_poi_count(poi_count + delta_i) :
  control_i == 17 ? set_poi_halftime(poi_halftime + delta_i) :
  control_i == 18 ? set_main_halftime(main_halftime + delta_i) :
  set_variation_halftime(variation_halftime + delta_i);
);

