gfx_x = bars_plus_x + 5 * ui_scale;
gfx_drawstr("+");

gfx_x = poi_minus_x + 6 * ui_scale;
gfx_y = header_group_y + 5 * ui_scale;
gfx_drawstr("-");
gfx_x = poi_value_x + 11 * ui_scale;
sprintf(#poi_ui_txt, "%02d", planned_poi_bars > 0 ? planned_poi_bars : snap_poi_length(poi_length, total_bars));
