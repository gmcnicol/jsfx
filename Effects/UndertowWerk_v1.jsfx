  control_i == 9 ? set_macro_dynamics(macro_dynamics + delta_i) :
  control_i == 10 ? set_velocity_drift(velocity_drift + delta_i) :
  control_i == 11 ? set_density_drift(density_drift + delta_i) :
  control_i == 12 ? set_layer_arc_offset(layer_arc_offset + delta_i) :
