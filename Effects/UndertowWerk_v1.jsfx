(
  control_i == 0 ? floor(master_note_length + 0.5) :
  control_i == 1 ? floor(tempo_reference + 0.5) :
  control_i == 2 ? floor(fill_frequency + 0.5) :
  control_i == 3 ? floor(poi_intensity + 0.5) :
  control_i == 4 ? floor(percussion_amount + 0.5) :
  control_i == 5 ? floor(tom_motion + 0.5) :
  control_i == 6 ? floor(cymbal_wash + 0.5) :
  control_i == 7 ? floor(repetition_bias + 0.5) :
