function adjust_global_control(control_i, delta_i)
(
  control_i == 0 ? set_master_note_length(master_note_length + delta_i) :
  control_i == 1 ? set_tempo_reference(tempo_reference + delta_i) :
  control_i == 2 ? set_fill_frequency(fill_frequency + delta_i) :
