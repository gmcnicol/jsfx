    while (role_i < NUM_PADS) (
      vel_i = layer_role_velocity(layer_i, role_i, bar_i, step_i, cycle_bar_i, 0);
      vel_i > 0 ? trigger_role(layer_i, role_i, vel_i, rel_offset, bar_i, step_i, cycle_bar_i, 0);
      vel_i = layer_role_velocity(layer_i, role_i, bar_i, step_i, cycle_bar_i, 1);
      vel_i > 0 ? trigger_role(layer_i, role_i, vel_i, rel_offset, bar_i, step_i, cycle_bar_i, 1);
      role_i += 1;
    );
  );
);

function in_rect(mx, my, x, y, w, h)
(
  (mx >= x) && (mx < (x + w)) && (my >= y) && (my < (y + h));
);

function init_persistent_state() local(layer_i, pad_i)
(
  layer_i = 0;
  while (layer_i < NUM_LAYERS) (
    pad_i = 0;
    while (pad_i < NUM_PADS) (
      role_to_pad[layer_pad_index(layer_i, pad_i)] = pad_i;
      pad_i += 1;
    );
    layer_i += 1;
  );

  persistent_magic != 778812 ? (
    selected_pad = 0;
    edit_layer = 0;
    preview_mode = 0;
    host_sliders_visible = 0;
    last_host_sliders_visible = -1;
    layer_i = 0;
    while (layer_i < NUM_LAYERS) (
      pad_i = 0;
      while (pad_i < NUM_PADS) (
        set_pad_note(layer_i, pad_i, default_note(layer_i, pad_i));
        pad_i += 1;
      );
      layer_i += 1;
    );

    persistent_magic = 778812;
  );
);

function reset_runtime_state() local(layer_i, pad_i, i)
(
  i = 0;
  while (i < NUM_PADS) (
    slot_activity[i] = 0;
    i += 1;
  );

  i = 0;
  while (i < (16 * 128)) (
    active_note_count[i] = 0;
    i += 1;
  );

  layer_i = 0;
  while (layer_i < NUM_LAYERS) (
    pad_i = 0;
    while (pad_i < NUM_PADS) (
      layer_activity[layer_pad_index(layer_i, pad_i)] = 0;
      pad_i += 1;
    );
    layer_i += 1;
  );

  queue_head = 0;
  queue_tail = 0;
  ui_audition_pending = 0;
  ui_audition_layer = 0;
  ui_audition_pad = 0;
  last_mouse_down = 0;
  note_drag_active = 0;
  note_drag_layer = 0;
  note_drag_pad = 0;
  note_drag_start_y = 0;
  note_drag_origin = 0;
  layer_row_drag_active = 0;
  layer_row_drag_layer = 0;
  layer_row_drag_row = 0;
  layer_row_drag_start_y = 0;
  layer_row_drag_origin = 0;
  global_drag_active = 0;
  global_drag_control = 0;
  global_drag_start_y = 0;
  global_drag_origin = 0;
  last_host_sliders_visible = -1;
  transport_is_playing = 0;
  current_cycle_step = 0;
  current_bar = 0;
  current_step_in_bar = 0;
  current_substep = 0;
  cycle_steps = 128;
  last_transport_is_playing = 0;
  last_beat_position = 0;
  last_block_beats = 0;
  abs_sample_clock = 0;
  block_abs_start = 0;
  block_abs_end = 0;
  step_samples = 0;
  note_len_samples = 0;
  form_dirty = 1;
  planned_total_bars = 0;
  planned_poi_start = 0;
  planned_poi_bars = 0;
  planned_poi_lead = 0;
  planned_tempo_band = 0;
  planned_turnaround_type = 0;
  planned_turnaround_bar = 0;
  planned_landing_bar = 0;
  planned_landing_mode = 0;
  planned_turnaround_zone_bars = 1;
  planned_recurrence_window = 4;
  planned_effective_tempo = 0;
  planned_false_peak_count = 0;
  planned_false_peak_skew = 0;
);

init_persistent_state();
reset_runtime_state();

@serialize

file_var(0, persistent_magic);
file_var(0, selected_pad);
file_var(0, edit_layer);
file_var(0, preview_mode);
file_var(0, host_sliders_visible);

layer_i = 0;
while (layer_i < NUM_LAYERS) (
  pad_i = 0;
  while (pad_i < NUM_PADS) (
    note_tmp = pad_note[layer_pad_index(layer_i, pad_i)];
    file_var(0, note_tmp);
    pad_note[layer_pad_index(layer_i, pad_i)] = note_tmp;
    pad_i += 1;
  );
  layer_i += 1;
);

@block

while (midirecv(offset, msg1, msg23)) (
  midisend(offset, msg1, msg23);
);

transport_is_playing = play_state & 1;
effective_tempo_now = tempo_reference > 0 ? tempo_reference : max(tempo, 1);
snapped_total_now = snap_total_bars(total_bars);
snapped_poi_now = snapped_total_now >= 8 ? snap_poi_length(poi_length, snapped_total_now) : 0;
expected_turn_zone_now = min(snap_turnaround_zone_length(turnaround_zone_length), max(1, snapped_total_now - quarter_span_for_total(snapped_total_now) * 3 - (snapped_total_now >= 32 ? 2 : 1)));
expected_false_peak_now = snap_false_peak_count(false_peak_count, snapped_total_now);
expected_false_peak_skew_now = clampi(floor(false_peak_skew + 0.5), -5, 5);
form_dirty ||
  (planned_total_bars != snapped_total_now) ||
  (planned_effective_tempo != effective_tempo_now) ||
  (planned_tempo_band != tempo_band_for_bpm(effective_tempo_now)) ||
  (planned_poi_bars != snapped_poi_now) ||
  (planned_turnaround_zone_bars != expected_turn_zone_now) ||
  (planned_false_peak_count != expected_false_peak_now) ||
  (planned_false_peak_skew != expected_false_peak_skew_now) ? plan_form();

cycle_steps = planned_total_bars * 16;
step_samples = srate * 60 / max(tempo, 1) / 4;
note_len_samples = floor(step_samples * master_note_length * 0.01 + 0.5);
note_len_samples < 1 ? note_len_samples = 1;

block_abs_start = abs_sample_clock;
block_abs_end = block_abs_start + samplesblock;

transport_step_abs = floor((beat_position / STEP_BEATS) + 0.000001);
current_cycle_step = transport_step_abs % cycle_steps;
current_cycle_step < 0 ? current_cycle_step += cycle_steps;
current_bar = floor(current_cycle_step / 16);
current_step_in_bar = current_cycle_step % 16;
current_substep = 0;

transport_jump = 0;
!transport_is_playing && last_transport_is_playing ? transport_jump = 1;
transport_is_playing && last_transport_is_playing ? (
  expected_beat_position = last_beat_position + last_block_beats;
  abs(beat_position - expected_beat_position) > (STEP_BEATS * 0.5) ? transport_jump = 1;
  beat_position + 0.000001 < last_beat_position ? transport_jump = 1;
);

transport_jump ? flush_all_note_offs();
flush_due_note_offs();

ui_audition_pending ? (
  audition_role = role_for_pad(ui_audition_layer, ui_audition_pad);
  trigger_role(ui_audition_layer, audition_role, 100, 0, -1, -1, -1, 0);
  ui_audition_pending = 0;
);

transport_is_playing ? (
  block_beats = samplesblock * tempo / 60 / srate;
  block_start_beats = beat_position;
  block_end_beats = beat_position + block_beats;

  step_index = floor((block_start_beats / STEP_BEATS) + 0.000001);
  step_time = step_index * STEP_BEATS;
  step_time < (block_start_beats - 0.000001) ? (
    step_index += 1;
    step_time += STEP_BEATS;
  );

  step_guard = 0;
  while ((step_time < (block_end_beats - 0.000001)) && (step_guard < 512)) (
    cycle_step = step_index % cycle_steps;
    cycle_step < 0 ? cycle_step += cycle_steps;

    cycle_bar_i = floor(cycle_step / 16);
    bar_i = cycle_bar_i;
    step_i = cycle_step % 16;

    rel_offset = floor(((step_time - block_start_beats) * 60 / max(tempo, 1) * srate) + 0.5);
    rel_offset < 0 ? rel_offset = 0;
    rel_offset >= samplesblock ? rel_offset = samplesblock - 1;

    fire_step_for_layer(LAYER_MOTORIK, bar_i, step_i, cycle_bar_i, rel_offset);
    fire_step_for_layer(LAYER_BREAKBEAT, bar_i, step_i, cycle_bar_i, rel_offset);
    fire_step_for_layer(LAYER_PERC, bar_i, step_i, cycle_bar_i, rel_offset);

    step_index += 1;
    step_time += STEP_BEATS;
    step_guard += 1;
  );
  last_block_beats = block_beats;
) : (
  last_block_beats = 0;
);

last_transport_is_playing = transport_is_playing;
last_beat_position = beat_position;
abs_sample_clock = block_abs_end;

@gfx 1500 1100

ui_scale = ui_scale_pct * 0.01;

gfx_clear = 0x101418;
gfx_setfont(1, "Verdana", floor(21 * ui_scale));
gfx_setfont(2, "Verdana", floor(15 * ui_scale));
gfx_setfont(3, "Verdana", floor(12 * ui_scale));

mouse_down = mouse_cap & 1;
click = mouse_down && !last_mouse_down;
mouse_shift = mouse_cap & 8;

host_sliders_visible = floor(host_sliders_visible + 0.5);
host_sliders_visible = clampi(host_sliders_visible, 0, 1);
host_sliders_visible != last_host_sliders_visible ? (
  slider_show(ALL_SLIDER_MASK, host_sliders_visible);
  last_host_sliders_visible = host_sliders_visible;
);

margin = 16 * ui_scale;
gap = 12 * ui_scale;
header_h = 56 * ui_scale;
strip_h = 188 * ui_scale;
tabs_h = 40 * ui_scale;
globals_h = 316 * ui_scale;

top_y = margin;
header_y = top_y;
strip_y = header_y + header_h + gap;
tabs_y = strip_y + strip_h + gap;
globals_y = tabs_y + tabs_h + gap;
content_y = globals_y + globals_h + gap;
content_h = gfx_h - content_y - margin;
content_h < (260 * ui_scale) ? content_h = 260 * ui_scale;

right_col_w = max(320 * ui_scale, (gfx_w - margin * 2) * 0.34);
right_col_w > (gfx_w * 0.48) ? right_col_w = gfx_w * 0.48;
grid_w = gfx_w - margin * 2 - gap - right_col_w;
grid_w < (380 * ui_scale) ? (
  right_col_w = max(280 * ui_scale, gfx_w * 0.30);
  grid_w = gfx_w - margin * 2 - gap - right_col_w;
);

grid_x = margin;
grid_y = content_y;
grid_h = content_h;

side_x = grid_x + grid_w + gap;
side_y = content_y;
editor_h = 188 * ui_scale;
editor_h > (content_h * 0.52) ? editor_h = content_h * 0.52;
preview_h = content_h - editor_h - gap;
preview_h < (132 * ui_scale) ? (
  preview_h = 132 * ui_scale;
  editor_h = content_h - preview_h - gap;
);

click ? (
  header_ctrl_w = 20 * ui_scale;
  header_val_w = 48 * ui_scale;
  header_ctrl_gap = 6 * ui_scale;
  header_group_y = header_y + 14 * ui_scale;
  transport_box_w = 268 * ui_scale;
  header_status_x = margin + 360 * ui_scale;
  transport_box_x = margin + 450 * ui_scale;
  bars_label_w = 30 * ui_scale;
  poi_label_w = 24 * ui_scale;
  seed_label_w = 28 * ui_scale;

  bars_minus_x = transport_box_x + transport_box_w + 28 * ui_scale;
  bars_value_x = bars_minus_x + header_ctrl_w + header_ctrl_gap;
  bars_plus_x = bars_value_x + header_val_w + header_ctrl_gap;

  poi_minus_x = bars_plus_x + 54 * ui_scale;
  poi_value_x = poi_minus_x + header_ctrl_w + header_ctrl_gap;
  poi_plus_x = poi_value_x + header_val_w + header_ctrl_gap;

  seed_minus_x = poi_plus_x + 54 * ui_scale;
  seed_value_x = seed_minus_x + header_ctrl_w + header_ctrl_gap;
  seed_plus_x = seed_value_x + (header_val_w + 22 * ui_scale) + header_ctrl_gap;

  in_rect(mouse_x, mouse_y, bars_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_total_bars(next_total_bars(total_bars, -1));
  in_rect(mouse_x, mouse_y, bars_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_total_bars(next_total_bars(total_bars, 1));
  in_rect(mouse_x, mouse_y, poi_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_poi_length(next_poi_length(poi_length, total_bars, -1));
  in_rect(mouse_x, mouse_y, poi_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_poi_length(next_poi_length(poi_length, total_bars, 1));
  in_rect(mouse_x, mouse_y, seed_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_seed_value(seed - 1);
  in_rect(mouse_x, mouse_y, seed_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale) ? set_seed_value(seed + 1);

  slider_toggle_w = 122 * ui_scale;
  slider_toggle_h = 26 * ui_scale;
  slider_toggle_x = gfx_w - margin - slider_toggle_w;
  slider_toggle_y = header_y + 15 * ui_scale;
  in_rect(mouse_x, mouse_y, slider_toggle_x, slider_toggle_y, slider_toggle_w, slider_toggle_h) ? host_sliders_visible = 1 - host_sliders_visible;

  panel_w = (gfx_w - margin * 2 - gap * 2) / 3;
  panel_h = strip_h;
  layer_i = 0;
  while (layer_i < NUM_LAYERS) (
    panel_x = margin + layer_i * (panel_w + gap);
    panel_y = strip_y;
    panel_pad = 10 * ui_scale;

    bool_y = panel_y + 34 * ui_scale;
    bool_h = 26 * ui_scale;
    bool_w = (panel_w - panel_pad * 2 - gap * 2) / 3;

    in_rect(mouse_x, mouse_y, panel_x + panel_pad, bool_y, bool_w, bool_h) ? set_layer_enabled(layer_i, 1 - layer_enabled(layer_i));
    in_rect(mouse_x, mouse_y, panel_x + panel_pad + bool_w + gap, bool_y, bool_w, bool_h) ? set_layer_muted(layer_i, 1 - layer_muted(layer_i));
    in_rect(mouse_x, mouse_y, panel_x + panel_pad + (bool_w + gap) * 2, bool_y, bool_w, bool_h) ? set_layer_soloed(layer_i, 1 - layer_soloed(layer_i));

    row_h = 22 * ui_scale;
    ctrl_w = 22 * ui_scale;
    value_w = 62 * ui_scale;
    step_x_minus = panel_x + panel_w - panel_pad - ctrl_w - value_w - ctrl_w - gap * 2;
    row_y = panel_y + 68 * ui_scale;

    in_rect(mouse_x, mouse_y, step_x_minus, row_y, ctrl_w, row_h) ? set_layer_channel(layer_i, layer_channel_display(layer_i) - 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h) ? set_layer_channel(layer_i, layer_channel_display(layer_i) + 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap, row_y, value_w, row_h) ? (
      layer_row_drag_active = 1;
      layer_row_drag_layer = layer_i;
      layer_row_drag_row = 0;
      layer_row_drag_start_y = mouse_y;
      layer_row_drag_origin = layer_channel_display(layer_i);
    );

    row_y += row_h + 6 * ui_scale;
    in_rect(mouse_x, mouse_y, step_x_minus, row_y, ctrl_w, row_h) ? set_layer_density(layer_i, layer_density(layer_i) - 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h) ? set_layer_density(layer_i, layer_density(layer_i) + 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap, row_y, value_w, row_h) ? (
      layer_row_drag_active = 1;
      layer_row_drag_layer = layer_i;
      layer_row_drag_row = 1;
      layer_row_drag_start_y = mouse_y;
      layer_row_drag_origin = layer_density(layer_i);
    );

    row_y += row_h + 6 * ui_scale;
    in_rect(mouse_x, mouse_y, step_x_minus, row_y, ctrl_w, row_h) ? set_layer_variation(layer_i, layer_variation(layer_i) - 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h) ? set_layer_variation(layer_i, layer_variation(layer_i) + 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap, row_y, value_w, row_h) ? (
      layer_row_drag_active = 1;
      layer_row_drag_layer = layer_i;
      layer_row_drag_row = 2;
      layer_row_drag_start_y = mouse_y;
      layer_row_drag_origin = layer_variation(layer_i);
    );

    row_y += row_h + 6 * ui_scale;
    in_rect(mouse_x, mouse_y, step_x_minus, row_y, ctrl_w, row_h) ? set_layer_velocity_scale(layer_i, layer_velocity_scale(layer_i) - 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap + value_w + gap, row_y, ctrl_w, row_h) ? set_layer_velocity_scale(layer_i, layer_velocity_scale(layer_i) + 1);
    in_rect(mouse_x, mouse_y, step_x_minus + ctrl_w + gap, row_y, value_w, row_h) ? (
      layer_row_drag_active = 1;
      layer_row_drag_layer = layer_i;
      layer_row_drag_row = 3;
      layer_row_drag_start_y = mouse_y;
      layer_row_drag_origin = layer_velocity_scale(layer_i);
    );

    layer_i += 1;
  );

  tab_w = (gfx_w - margin * 2 - gap * 4) / 5;
  in_rect(mouse_x, mouse_y, margin, tabs_y, tab_w, tabs_h) ? edit_layer = 0;
  in_rect(mouse_x, mouse_y, margin + tab_w + gap, tabs_y, tab_w, tabs_h) ? edit_layer = 1;
  in_rect(mouse_x, mouse_y, margin + (tab_w + gap) * 2, tabs_y, tab_w, tabs_h) ? edit_layer = 2;
  in_rect(mouse_x, mouse_y, margin + (tab_w + gap) * 3, tabs_y, tab_w, tabs_h) ? preview_mode = 0;
  in_rect(mouse_x, mouse_y, margin + (tab_w + gap) * 4, tabs_y, tab_w, tabs_h) ? preview_mode = 1;

  global_cols = 4;
  global_cell_w = (gfx_w - margin * 2 - gap * (global_cols - 1)) / global_cols;
  global_cell_h = 34 * ui_scale;
  global_row_gap = 10 * ui_scale;
  global_ctrl_w = 18 * ui_scale;
  global_val_w = 60 * ui_scale;
  global_cluster_w = global_ctrl_w + 6 * ui_scale + global_val_w + 6 * ui_scale + global_ctrl_w;
  global_controls_y = globals_y + 40 * ui_scale;
  control_i = 0;
  while (control_i < 18) (
    control_row = floor(control_i / global_cols);
    control_col = control_i % global_cols;
    control_x = margin + control_col * (global_cell_w + gap);
    control_y = global_controls_y + control_row * (global_cell_h + global_row_gap);
    minus_x = control_x + (global_cell_w - global_cluster_w) * 0.5;
    value_x = minus_x + global_ctrl_w + 6 * ui_scale;
    plus_x = value_x + global_val_w + 6 * ui_scale;

    control_step = (control_i == 1 || control_i == 14 || control_i == 16 || control_i == 17) ? 1 : 5;
    in_rect(mouse_x, mouse_y, minus_x, control_y + 14 * ui_scale, global_ctrl_w, 16 * ui_scale) ? adjust_global_control(control_i, -control_step);
    in_rect(mouse_x, mouse_y, value_x, control_y + 14 * ui_scale, global_val_w, 16 * ui_scale) ? (
      global_drag_active = 1;
      global_drag_control = control_i;
      global_drag_start_y = mouse_y;
      global_drag_origin = get_global_control_value(control_i);
    );
    in_rect(mouse_x, mouse_y, plus_x, control_y + 14 * ui_scale, global_ctrl_w, 16 * ui_scale) ? adjust_global_control(control_i, control_step);
    control_i += 1;
  );

  cols = 4;
  rows = 3;
  pad_w = (grid_w - gap * (cols - 1)) / cols;
  pad_h = (grid_h - gap * (rows - 1)) / rows;
  pad_i = 0;
  while (pad_i < NUM_PADS) (
    col_i = pad_i % cols;
    row_i = floor(pad_i / cols);
    pad_x = grid_x + col_i * (pad_w + gap);
    pad_y = grid_y + row_i * (pad_h + gap);
    note_hit_x = pad_x + 8 * ui_scale;
    note_hit_y = pad_y + 50 * ui_scale;
    note_hit_w = pad_w - 16 * ui_scale;
    note_hit_h = 24 * ui_scale;
    in_rect(mouse_x, mouse_y, note_hit_x, note_hit_y, note_hit_w, note_hit_h) ? (
      selected_pad = pad_i;
      note_drag_active = 1;
      note_drag_layer = edit_layer;
      note_drag_pad = pad_i;
      note_drag_start_y = mouse_y;
      note_drag_origin = get_pad_note(edit_layer, pad_i);
    ) : in_rect(mouse_x, mouse_y, pad_x, pad_y, pad_w, pad_h) ? (
      selected_pad == pad_i ? queue_ui_audition(edit_layer, pad_i) : selected_pad = pad_i;
    );
    pad_i += 1;
  );

  editor_x = side_x;
  editor_y = side_y;
  editor_w = right_col_w;
  editor_pad = 12 * ui_scale;
  button_gap = 8 * ui_scale;
  btn_w_1 = (editor_w - editor_pad * 2 - button_gap * 3) / 4;
  big_btn_w = (editor_w - editor_pad * 2 - button_gap) / 2;
  big_btn_h = 32 * ui_scale;
  btn_y_2 = editor_y + editor_h - big_btn_h - 12 * ui_scale;
  btn_y_1 = btn_y_2 - 32 * ui_scale - 8 * ui_scale;

  in_rect(mouse_x, mouse_y, editor_x + editor_pad, btn_y_1, btn_w_1, 32 * ui_scale) ? set_pad_note(edit_layer, selected_pad, get_pad_note(edit_layer, selected_pad) - 12);
  in_rect(mouse_x, mouse_y, editor_x + editor_pad + (btn_w_1 + button_gap), btn_y_1, btn_w_1, 32 * ui_scale) ? set_pad_note(edit_layer, selected_pad, get_pad_note(edit_layer, selected_pad) - 1);
  in_rect(mouse_x, mouse_y, editor_x + editor_pad + (btn_w_1 + button_gap) * 2, btn_y_1, btn_w_1, 32 * ui_scale) ? set_pad_note(edit_layer, selected_pad, get_pad_note(edit_layer, selected_pad) + 1);
  in_rect(mouse_x, mouse_y, editor_x + editor_pad + (btn_w_1 + button_gap) * 3, btn_y_1, btn_w_1, 32 * ui_scale) ? set_pad_note(edit_layer, selected_pad, get_pad_note(edit_layer, selected_pad) + 12);
  in_rect(mouse_x, mouse_y, editor_x + editor_pad, btn_y_2, big_btn_w, big_btn_h) ? set_pad_note(edit_layer, selected_pad, default_note(edit_layer, selected_pad));
  in_rect(mouse_x, mouse_y, editor_x + editor_pad + big_btn_w + button_gap, btn_y_2, big_btn_w, big_btn_h) ? queue_ui_audition(edit_layer, selected_pad);
);

mouse_down && note_drag_active ? (
  drag_note_step = floor((note_drag_start_y - mouse_y) / (18 * ui_scale));
  set_pad_note(note_drag_layer, note_drag_pad, note_drag_origin + drag_note_step);
);
!mouse_down ? note_drag_active = 0;

mouse_down && layer_row_drag_active ? (
  drag_row_step = floor((layer_row_drag_start_y - mouse_y) / (18 * ui_scale));
  set_layer_row_value(layer_row_drag_layer, layer_row_drag_row, layer_row_drag_origin + drag_row_step);
);
!mouse_down ? layer_row_drag_active = 0;

mouse_down && global_drag_active ? (
  drag_global_step = floor((global_drag_start_y - mouse_y) / (18 * ui_scale));
  global_drag_control == 4 ? (
    set_global_control_value(global_drag_control, global_drag_origin + drag_global_step);
  ) : (
    set_global_control_value(global_drag_control, global_drag_origin + drag_global_step);
  );
);
!mouse_down ? global_drag_active = 0;

mouse_shift && (mouse_wheel != 0) ? (
  wheel_steps = floor(abs(mouse_wheel) / 60);
  wheel_steps < 1 ? wheel_steps = 1;
  mouse_wheel < 0 ? wheel_steps = -wheel_steps;
  wheel_handled = 0;
  pad_i = 0;
  while ((pad_i < NUM_PADS) && !wheel_handled) (
    col_i = pad_i % cols;
    row_i = floor(pad_i / cols);
    pad_x = grid_x + col_i * (pad_w + gap);
    pad_y = grid_y + row_i * (pad_h + gap);
    note_hit_x = pad_x + 8 * ui_scale;
    note_hit_y = pad_y + 50 * ui_scale;
    note_hit_w = pad_w - 16 * ui_scale;
    note_hit_h = 24 * ui_scale;
    in_rect(mouse_x, mouse_y, note_hit_x, note_hit_y, note_hit_w, note_hit_h) ? (
      selected_pad = pad_i;
      set_pad_note(edit_layer, pad_i, get_pad_note(edit_layer, pad_i) + wheel_steps);
      wheel_handled = 1;
      mouse_wheel = 0;
    );
    pad_i += 1;
  );
);

last_mouse_down = mouse_down;

pad_i = 0;
while (pad_i < NUM_PADS) (
  slot_activity[pad_i] = max(0, slot_activity[pad_i] * 0.90 - 0.01);
  pad_i += 1;
);

layer_i = 0;
while (layer_i < NUM_LAYERS) (
  pad_i = 0;
  while (pad_i < NUM_PADS) (
    layer_activity[layer_pad_index(layer_i, pad_i)] = max(0, layer_activity[layer_pad_index(layer_i, pad_i)] * 0.90 - 0.01);
    pad_i += 1;
  );
  layer_i += 1;
);

gfx_set(0.07, 0.09, 0.11, 1);
gfx_rect(0, 0, gfx_w, gfx_h, 1);

gfx_set(0.11, 0.14, 0.18, 1);
gfx_rect(margin, header_y, gfx_w - margin * 2, header_h, 1);

gfx_setfont(1, "Verdana", floor(19 * ui_scale));
gfx_set(0.95, 0.96, 0.98, 1);
gfx_x = margin + 14 * ui_scale;
gfx_y = header_y + 15 * ui_scale;
gfx_drawstr("UndertowWerk v1");

gfx_setfont(2, "Verdana", floor(15 * ui_scale));
header_status_x = margin + 360 * ui_scale;
gfx_x = header_status_x;
gfx_y = header_y + 18 * ui_scale;
transport_is_playing ? sprintf(#header_status, "Playing") : sprintf(#header_status, "Stopped");
gfx_drawstr(#header_status);

header_ctrl_w = 20 * ui_scale;
header_val_w = 48 * ui_scale;
header_ctrl_gap = 6 * ui_scale;
header_group_y = header_y + 14 * ui_scale;
transport_box_w = 268 * ui_scale;
transport_box_x = margin + 450 * ui_scale;
bars_label_w = 30 * ui_scale;
poi_label_w = 24 * ui_scale;
seed_label_w = 28 * ui_scale;

gfx_set(0.18, 0.22, 0.28, 1);
gfx_rect(transport_box_x, header_y + 13 * ui_scale, transport_box_w, 28 * ui_scale, 1);
gfx_setfont(2, "Verdana", floor(15 * ui_scale));
gfx_set(0.95, 0.96, 0.98, 1);
gfx_x = transport_box_x + 10 * ui_scale;
gfx_y = header_y + 18 * ui_scale;
sprintf(#header_pos, "Bar %03d  Step %02d  Cycle %03d", current_bar + 1, current_step_in_bar + 1, planned_total_bars);
gfx_drawstr(#header_pos);

bars_minus_x = transport_box_x + transport_box_w + 28 * ui_scale;
bars_value_x = bars_minus_x + header_ctrl_w + header_ctrl_gap;
bars_plus_x = bars_value_x + header_val_w + header_ctrl_gap;

poi_minus_x = bars_plus_x + 54 * ui_scale;
poi_value_x = poi_minus_x + header_ctrl_w + header_ctrl_gap;
poi_plus_x = poi_value_x + header_val_w + header_ctrl_gap;

seed_minus_x = poi_plus_x + 54 * ui_scale;
seed_value_x = seed_minus_x + header_ctrl_w + header_ctrl_gap;
seed_plus_x = seed_value_x + (header_val_w + 22 * ui_scale) + header_ctrl_gap;

gfx_setfont(3, "Verdana", floor(12 * ui_scale));
gfx_set(0.92, 0.94, 0.97, 1);
gfx_x = bars_minus_x - bars_label_w;
gfx_y = header_y + 18 * ui_scale;
gfx_drawstr("Bars");
gfx_x = poi_minus_x - poi_label_w;
gfx_drawstr("Imp");
gfx_x = seed_minus_x - seed_label_w;
gfx_drawstr("Seed");

gfx_set(0.24, 0.27, 0.33, 1);
gfx_rect(bars_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);
gfx_rect(bars_value_x, header_group_y, header_val_w, 24 * ui_scale, 1);
gfx_rect(bars_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);
gfx_rect(poi_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);
gfx_rect(poi_value_x, header_group_y, header_val_w, 24 * ui_scale, 1);
gfx_rect(poi_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);
gfx_rect(seed_minus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);
gfx_rect(seed_value_x, header_group_y, header_val_w + 22 * ui_scale, 24 * ui_scale, 1);
gfx_rect(seed_plus_x, header_group_y, header_ctrl_w, 24 * ui_scale, 1);

gfx_set(1, 1, 1, 1);
gfx_x = bars_minus_x + 6 * ui_scale;
gfx_y = header_group_y + 5 * ui_scale;
gfx_drawstr("-");
gfx_x = bars_value_x + 11 * ui_scale;
