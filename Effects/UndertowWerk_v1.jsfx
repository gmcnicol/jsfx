desc:UndertowWerk v1 - Quiet/Loud Post-Rock / Math-Rock MIDI Drum Generator

in_pin:none
out_pin:none

slider1:total_bars=16<8,256,1>Total Bars
slider2:poi_length=4<1,64,1>Impact Length
slider3:ui_scale_pct=118<75,200,1>UI Scale

slider4:seed=1207<0,999999,1>Seed
slider5:master_note_length=88<10,100,1>Master Note Length
slider6:tempo_reference=0<0,170,1>Tempo Reference (0 Host)
slider7:groove_tightness=74<0,100,1>Groove Tightness
slider8:fill_frequency=26<0,100,1>Fill Frequency
slider9:percussion_amount=52<0,100,1>Ghost Note Amount
slider10:tom_motion=54<0,100,1>Tom Bloom
slider11:cymbal_wash=58<0,100,1>Cymbal Restraint
slider12:repetition_bias=74<0,100,1>Repetition Bias
slider13:dynamic_lift=68<0,100,1>Dynamic Lift Amount
slider14:macro_dynamics=64<0,100,1>Macro Dynamics Amount
slider15:velocity_drift=52<0,100,1>Velocity Drift
slider16:density_drift=50<0,100,1>Density Drift
slider17:layer_arc_offset=48<0,100,1>Layer Arc Offset
slider18:late_bloom_bias=58<0,100,1>False Summit Bias
slider19:turnaround_zone_length=2<1,8,1>Afterglow Length
slider20:poi_intensity=70<0,100,1>Impact Intensity
slider21:halftime_bias=34<0,100,1>Halftime Bias
slider22:doubletime_bias=18<0,100,1>Double-Time Bias
slider23:force_cymbal_mode=0<0,4,1{Auto,Closed Hat,Open Hat,Ride,Tom-Led}>Force Clock Mode
slider24:precision_amount=78<0,100,1>Anchor Amount
slider25:riff_amount=66<0,100,1>Nerve Amount
slider26:weight_amount=60<0,100,1>Surge Amount

slider27:prec_enable=1<0,1,1{Off,On}>Anchor Enable
slider28:prec_mute=0<0,1,1{Off,On}>Anchor Mute
slider29:prec_solo=0<0,1,1{Off,On}>Anchor Solo
slider30:prec_channel=1<1,16,1>Anchor Channel
slider31:prec_density=72<0,100,1>Anchor Density
slider32:prec_variation=42<0,100,1>Anchor Variation
slider33:prec_velocity_scale=88<10,120,1>Anchor Velocity Scale

slider34:riff_enable=1<0,1,1{Off,On}>Nerve Enable
slider35:riff_mute=0<0,1,1{Off,On}>Nerve Mute
slider36:riff_solo=0<0,1,1{Off,On}>Nerve Solo
slider37:riff_channel=1<1,16,1>Nerve Channel
slider38:riff_density=58<0,100,1>Nerve Density
slider39:riff_variation=48<0,100,1>Nerve Variation
slider40:riff_velocity_scale=84<10,120,1>Nerve Velocity Scale

slider41:weight_enable=1<0,1,1{Off,On}>Surge Enable
slider42:weight_mute=0<0,1,1{Off,On}>Surge Mute
slider43:weight_solo=0<0,1,1{Off,On}>Surge Solo
slider44:weight_channel=1<1,16,1>Surge Channel
slider45:weight_density=56<0,100,1>Surge Density
slider46:weight_variation=44<0,100,1>Surge Variation
slider47:weight_velocity_scale=86<10,120,1>Surge Velocity Scale
slider48:false_peak_count=1<0,4,1>False Peak Count
slider49:false_peak_skew=0<-5,5,1>False Peak Skew

@init

NUM_LAYERS = 3;
NUM_PADS = 12;
MAX_BARS = 256;
ALL_SLIDER_MASK = 562949953421311;
QUEUE_SIZE = 1024;
STEP_BEATS = 0.25;
MAX_FALSE_PEAKS = 4;

LAYER_PATIENT = 0;
LAYER_PROCESSION = 1;
LAYER_WEIGHT = 2;

LAYER_PRECISION = LAYER_PATIENT;
LAYER_RIFF = LAYER_PROCESSION;

LAYER_MOTORIK = LAYER_PATIENT;
LAYER_BREAKBEAT = LAYER_PROCESSION;
LAYER_PERC = LAYER_WEIGHT;

CLASS_MAIN = 0;
CLASS_VARIATION = 1;
CLASS_PRE_LIFT = 2;
CLASS_FALSE_PEAK = 3;
CLASS_IMPACT_ENTRY = 4;
CLASS_IMPACT_MAIN = 5;
CLASS_IMPACT_VARIATION = 6;
CLASS_AFTERGLOW = 7;
CLASS_TURNAROUND = 8;
CLASS_LANDING = 9;

MACRO_QUIET_A = 0;
MACRO_QUIET_B = 1;
MACRO_IMPACT = 2;
MACRO_AFTERGLOW = 3;
MACRO_TURNAROUND = 4;
MACRO_LANDING = 5;

BAND_A1 = 0;
BAND_A2 = 1;
BAND_B1 = 2;
BAND_B2 = 3;
BAND_C = 4;
BAND_D = 5;
BAND_E = 6;

CLOCK_HAT = 0;
CLOCK_OPEN = 1;
CLOCK_RIDE = 2;
CLOCK_TOM = 3;
CLOCK_SPARSE = 4;

LANDING_KICK_CRASH = 0;
LANDING_LOW_TOM = 1;

ENV_FLAT_ANCHOR = 0;
ENV_SLOW_RISE = 1;
ENV_LATE_BLOOM = 2;
ENV_RISE_HOLD = 3;
ENV_RISE_FALL_RISE = 4;
ENV_CREST_RELEASE = 5;
ENV_WAVE = 6;

pad_note = 0;
role_to_pad = 64;
layer_activity = 128;
slot_activity = 192;
active_note_count = 256;
off_time = 2304;
off_chan = off_time + QUEUE_SIZE;
off_note = off_chan + QUEUE_SIZE;
bar_class = off_note + QUEUE_SIZE;
bar_lead_layer = bar_class + MAX_BARS;
bar_support_layer = bar_lead_layer + MAX_BARS;
bar_cymbal_mode = bar_support_layer + MAX_BARS;
bar_halftime = bar_cymbal_mode + MAX_BARS;
bar_fill_owner = bar_halftime + MAX_BARS;
bar_turn_pickup = bar_fill_owner + MAX_BARS;
bar_macro_section = bar_turn_pickup + MAX_BARS;
bar_false_peak_release = bar_macro_section + MAX_BARS;
bar_afterglow_entry = bar_false_peak_release + MAX_BARS;
layer_envelope_shape = bar_afterglow_entry + MAX_BARS;
false_peak_start = layer_envelope_shape + NUM_LAYERS;
false_peak_span = false_peak_start + MAX_FALSE_PEAKS;

queue_head = 0;
queue_tail = 0;

ui_audition_pending = 0;
ui_audition_layer = 0;
ui_audition_pad = 0;

last_mouse_down = 0;

transport_is_playing = 0;
current_cycle_step = 0;
current_bar = 0;
current_step_in_bar = 0;
cycle_steps = 128;
current_substep = 0;

last_transport_is_playing = 0;
last_beat_position = 0;
last_block_beats = 0;

abs_sample_clock = 0;
block_abs_start = 0;
block_abs_end = 0;
step_samples = 0;
note_len_samples = 0;
form_dirty = 1;
planned_total_bars = 0;
planned_poi_start = 0;
planned_poi_bars = 0;
planned_poi_lead = 0;
planned_tempo_band = 0;
planned_turnaround_type = 0;
planned_turnaround_bar = 0;
planned_landing_bar = 0;
planned_landing_mode = 0;
planned_turnaround_zone_bars = 1;
planned_recurrence_window = 4;
planned_effective_tempo = 0;
planned_false_peak_count = 0;
planned_false_peak_skew = 0;

function clampi(v, lo, hi)
(
  v < lo ? lo : v > hi ? hi : v;
);

function clamp01(v)
(
  v < 0 ? 0 : v > 1 ? 1 : v;
);

function layer_pad_index(layer_i, pad_i)
(
  layer_i * NUM_PADS + pad_i;
);

function active_note_index(chan_i, note_i)
(
  chan_i * 128 + note_i;
);

function layer_name(layer_i)
(
  layer_i == LAYER_PATIENT ? sprintf(#layer_txt, "Anchor");
  layer_i == LAYER_PROCESSION ? sprintf(#layer_txt, "Nerve");
  layer_i == LAYER_WEIGHT ? sprintf(#layer_txt, "Surge");
);

function layer_full_name(layer_i)
(
  layer_i == LAYER_PATIENT ? sprintf(#layer_full_txt, "Anchor");
  layer_i == LAYER_PROCESSION ? sprintf(#layer_full_txt, "Nerve");
  layer_i == LAYER_WEIGHT ? sprintf(#layer_full_txt, "Surge");
);

function role_name(layer_i, role_i)
(
  layer_i == LAYER_WEIGHT ? (
    role_i == 0 ? sprintf(#role_txt, "Kick");
    role_i == 1 ? sprintf(#role_txt, "Snare Support");
    role_i == 2 ? sprintf(#role_txt, "Rim / Side");
    role_i == 3 ? sprintf(#role_txt, "Closed Hat");
    role_i == 4 ? sprintf(#role_txt, "Open Hat");
    role_i == 5 ? sprintf(#role_txt, "Ride");
    role_i == 6 ? sprintf(#role_txt, "Crash");
    role_i == 7 ? sprintf(#role_txt, "High Tom");
    role_i == 8 ? sprintf(#role_txt, "Mid Tom");
    role_i == 9 ? sprintf(#role_txt, "Floor Tom");
    role_i == 10 ? sprintf(#role_txt, "Low Tom");
    role_i == 11 ? sprintf(#role_txt, "Aftershock");
  ) : (
    role_i == 0 ? sprintf(#role_txt, "Kick");
    role_i == 1 ? layer_i == LAYER_PROCESSION ? sprintf(#role_txt, "Ghost Snare") : sprintf(#role_txt, "Snare");
    role_i == 2 ? sprintf(#role_txt, "Rim / Side");
    role_i == 3 ? sprintf(#role_txt, "Closed Hat");
    role_i == 4 ? sprintf(#role_txt, "Open Hat");
    role_i == 5 ? sprintf(#role_txt, "Ride");
    role_i == 6 ? sprintf(#role_txt, "Crash");
    role_i == 7 ? sprintf(#role_txt, "Splash / Wash");
    role_i == 8 ? sprintf(#role_txt, "High Tom");
    role_i == 9 ? sprintf(#role_txt, "Mid Tom");
    role_i == 10 ? sprintf(#role_txt, "Floor Tom");
    role_i == 11 ? sprintf(#role_txt, "Aux Perc");
  );
);

function default_note(layer_i, pad_i)
(
  layer_i == LAYER_WEIGHT ? (
    pad_i == 0 ? 36 :
    pad_i == 1 ? 40 :
    pad_i == 2 ? 37 :
    pad_i == 3 ? 42 :
    pad_i == 4 ? 46 :
    pad_i == 5 ? 51 :
    pad_i == 6 ? 49 :
    pad_i == 7 ? 50 :
    pad_i == 8 ? 47 :
    pad_i == 9 ? 43 :
    pad_i == 10 ? 41 :
    60
  ) : (
    pad_i == 0 ? 36 :
    pad_i == 1 ? 38 :
    pad_i == 2 ? 37 :
    pad_i == 3 ? 42 :
    pad_i == 4 ? 46 :
    pad_i == 5 ? 51 :
    pad_i == 6 ? 49 :
    pad_i == 7 ? 55 :
    pad_i == 8 ? 50 :
    pad_i == 9 ? 47 :
    pad_i == 10 ? 43 :
    39
  );
);

function layer_enabled(layer_i)
(
  layer_i == LAYER_PRECISION ? floor(prec_enable + 0.5) :
  layer_i == LAYER_RIFF ? floor(riff_enable + 0.5) :
  floor(weight_enable + 0.5);
);

function layer_muted(layer_i)
(
  layer_i == LAYER_PRECISION ? floor(prec_mute + 0.5) :
  layer_i == LAYER_RIFF ? floor(riff_mute + 0.5) :
  floor(weight_mute + 0.5);
);

function layer_soloed(layer_i)
(
  layer_i == LAYER_PRECISION ? floor(prec_solo + 0.5) :
  layer_i == LAYER_RIFF ? floor(riff_solo + 0.5) :
  floor(weight_solo + 0.5);
);

function layer_channel_display(layer_i)
(
  layer_i == LAYER_PRECISION ? floor(prec_channel + 0.5) :
  layer_i == LAYER_RIFF ? floor(riff_channel + 0.5) :
  floor(weight_channel + 0.5);
);

function layer_channel_zero(layer_i)
(
  clampi(layer_channel_display(layer_i), 1, 16) - 1;
);

function layer_density(layer_i)
(
  layer_i == LAYER_PRECISION ? floor(prec_density + 0.5) :
  layer_i == LAYER_RIFF ? floor(riff_density + 0.5) :
  floor(weight_density + 0.5);
);

function layer_variation(layer_i)
(
  layer_i == LAYER_PRECISION ? floor(prec_variation + 0.5) :
  layer_i == LAYER_RIFF ? floor(riff_variation + 0.5) :
  floor(weight_variation + 0.5);
);

function layer_velocity_scale(layer_i)
(
  layer_i == LAYER_PRECISION ? floor(prec_velocity_scale + 0.5) :
  layer_i == LAYER_RIFF ? floor(riff_velocity_scale + 0.5) :
  floor(weight_velocity_scale + 0.5);
);

function any_layer_soloed()
(
  layer_soloed(LAYER_MOTORIK) || layer_soloed(LAYER_BREAKBEAT) || layer_soloed(LAYER_PERC);
);

function layer_can_emit(layer_i) local(any_solo)
(
  any_solo = any_layer_soloed();
  layer_enabled(layer_i) && !layer_muted(layer_i) && (!any_solo || layer_soloed(layer_i));
);

function get_pad_note(layer_i, pad_i)
(
  pad_note[layer_pad_index(layer_i, pad_i)];
);

function set_pad_note(layer_i, pad_i, note_val)
(
  pad_note[layer_pad_index(layer_i, pad_i)] = clampi(note_val, 0, 127);
);

function get_pad_for_role(layer_i, role_i)
(
  role_to_pad[layer_pad_index(layer_i, role_i)];
);

function role_for_pad(layer_i, pad_i) local(role_i, found_role)
(
  found_role = 0;
  role_i = 0;
  while ((role_i < NUM_PADS) && (get_pad_for_role(layer_i, role_i) != pad_i)) (
    role_i += 1;
  );
  role_i < NUM_PADS ? found_role = role_i;
  found_role;
);

function set_layer_enabled(layer_i, value_i)
(
  value_i = clampi(value_i, 0, 1);
  layer_i == LAYER_PRECISION ? (prec_enable = value_i; slider27 = value_i;) :
  layer_i == LAYER_RIFF ? (riff_enable = value_i; slider34 = value_i;) :
  (weight_enable = value_i; slider41 = value_i;);
);

function set_layer_muted(layer_i, value_i)
(
  value_i = clampi(value_i, 0, 1);
  layer_i == LAYER_PRECISION ? (prec_mute = value_i; slider28 = value_i;) :
  layer_i == LAYER_RIFF ? (riff_mute = value_i; slider35 = value_i;) :
  (weight_mute = value_i; slider42 = value_i;);
);

function set_layer_soloed(layer_i, value_i)
(
  value_i = clampi(value_i, 0, 1);
  layer_i == LAYER_PRECISION ? (prec_solo = value_i; slider29 = value_i;) :
  layer_i == LAYER_RIFF ? (riff_solo = value_i; slider36 = value_i;) :
  (weight_solo = value_i; slider43 = value_i;);
);

function set_layer_channel(layer_i, value_i)
(
  value_i = clampi(value_i, 1, 16);
  layer_i == LAYER_PRECISION ? (prec_channel = value_i; slider30 = value_i;) :
  layer_i == LAYER_RIFF ? (riff_channel = value_i; slider37 = value_i;) :
  (weight_channel = value_i; slider44 = value_i;);
);

function set_layer_density(layer_i, value_i)
(
  value_i = clampi(value_i, 0, 100);
  layer_i == LAYER_PRECISION ? (prec_density = value_i; slider31 = value_i;) :
  layer_i == LAYER_RIFF ? (riff_density = value_i; slider38 = value_i;) :
  (weight_density = value_i; slider45 = value_i;);
);

function set_layer_variation(layer_i, value_i)
(
  value_i = clampi(value_i, 0, 100);
  layer_i == LAYER_PRECISION ? (prec_variation = value_i; slider32 = value_i;) :
  layer_i == LAYER_RIFF ? (riff_variation = value_i; slider39 = value_i;) :
  (weight_variation = value_i; slider46 = value_i;);
);

function set_layer_velocity_scale(layer_i, value_i)
(
  value_i = clampi(value_i, 10, 120);
  layer_i == LAYER_PRECISION ? (prec_velocity_scale = value_i; slider33 = value_i;) :
  layer_i == LAYER_RIFF ? (riff_velocity_scale = value_i; slider40 = value_i;) :
  (weight_velocity_scale = value_i; slider47 = value_i;);
);

function snap_total_bars(value_i)
(
  value_i < 12 ? 8 :
  value_i < 24 ? 16 :
  value_i < 48 ? 32 :
  value_i < 96 ? 64 :
  value_i < 192 ? 128 :
  256;
);

function next_total_bars(value_i, delta_i)
(
  value_i = snap_total_bars(value_i);
  delta_i < 0 ? (
    value_i <= 8 ? 8 :
    value_i <= 16 ? 8 :
    value_i <= 32 ? 16 :
    value_i <= 64 ? 32 :
    value_i <= 128 ? 64 :
    128;
  ) : (
    value_i >= 256 ? 256 :
    value_i >= 128 ? 256 :
    value_i >= 64 ? 128 :
    value_i >= 32 ? 64 :
    value_i >= 16 ? 32 :
    16;
  );
);

function max_poi_length_for_total(total_i)
(
  total_i >= 64 ? 16 :
  total_i >= 32 ? 8 :
  total_i >= 16 ? 4 :
  total_i >= 8 ? 2 :
  1;
);

function snap_poi_length(value_i, total_i)
(
  total_i = snap_total_bars(total_i);
  value_i = value_i <= 1 ? 1 :
    value_i <= 2 ? 2 :
    value_i <= 4 ? 4 :
    value_i <= 8 ? 8 :
    16;
  value_i > max_poi_length_for_total(total_i) ? value_i = max_poi_length_for_total(total_i);
  value_i < 1 ? value_i = 1;
  value_i;
);

function next_poi_length(value_i, total_i, delta_i)
(
  value_i = snap_poi_length(value_i, total_i);
  delta_i < 0 ? (
    value_i <= 1 ? 1 :
    value_i <= 2 ? 1 :
    value_i <= 4 ? 2 :
    value_i <= 8 ? 4 :
    value_i <= 16 ? 8 :
    value_i <= 32 ? 16 :
    32;
  ) : (
    value_i >= max_poi_length_for_total(total_i) ? max_poi_length_for_total(total_i) :
    value_i >= 16 ? 32 :
    value_i >= 8 ? 16 :
    value_i >= 4 ? 8 :
    value_i >= 2 ? 4 :
    value_i >= 1 ? 2 :
    1;
  );
);

function snap_turnaround_zone_length(value_i)
(
  value_i <= 1 ? 1 :
  value_i <= 2 ? 2 :
  value_i <= 4 ? 4 :
  8;
);

function max_false_peak_count_for_total(total_i)
(
  total_i >= 128 ? 4 :
  total_i >= 64 ? 3 :
  total_i >= 32 ? 2 :
  1;
);

function snap_false_peak_count(value_i, total_i)
(
  clampi(floor(value_i + 0.5), 0, max_false_peak_count_for_total(snap_total_bars(total_i)));
);

function next_turnaround_zone_length(value_i, delta_i)
(
  value_i = snap_turnaround_zone_length(value_i);
  delta_i < 0 ? (
    value_i <= 1 ? 1 :
    value_i <= 2 ? 1 :
    value_i <= 4 ? 2 :
    4;
  ) : (
    value_i >= 8 ? 8 :
    value_i >= 4 ? 8 :
    value_i >= 2 ? 4 :
    2;
  );
);

function set_total_bars(value_i)
(
  value_i = snap_total_bars(value_i);
  total_bars = value_i;
  slider1 = value_i;
  poi_length > max_poi_length_for_total(value_i) ? (
    poi_length = snap_poi_length(poi_length, value_i);
    slider2 = poi_length;
  );
  false_peak_count != snap_false_peak_count(false_peak_count, value_i) ? (
    false_peak_count = snap_false_peak_count(false_peak_count, value_i);
    slider48 = false_peak_count;
  );
  form_dirty = 1;
);

function set_poi_length(value_i)
(
  value_i = snap_poi_length(value_i, total_bars);
  poi_length = value_i;
  slider2 = value_i;
  form_dirty = 1;
);

function set_master_note_length(value_i)
(
  value_i = clampi(value_i, 10, 100);
  master_note_length = value_i;
  slider5 = value_i;
);

function set_seed_value(value_i)
(
  value_i = clampi(value_i, 0, 999999);
  seed = value_i;
  slider4 = value_i;
  form_dirty = 1;
);

function set_tempo_reference(value_i)
(
  value_i = clampi(value_i, 0, 170);
  tempo_reference = value_i;
  slider6 = value_i;
  form_dirty = 1;
);

function set_groove_tightness(value_i)
(
  value_i = clampi(value_i, 0, 100);
  groove_tightness = value_i;
  slider7 = value_i;
);

function set_fill_frequency(value_i)
(
  value_i = clampi(value_i, 0, 100);
  fill_frequency = value_i;
  slider8 = value_i;
  form_dirty = 1;
);

function set_percussion_amount(value_i)
(
  value_i = clampi(value_i, 0, 100);
  percussion_amount = value_i;
  slider9 = value_i;
  form_dirty = 1;
);

function set_tom_motion(value_i)
(
  value_i = clampi(value_i, 0, 100);
  tom_motion = value_i;
  slider10 = value_i;
  form_dirty = 1;
);

function set_cymbal_wash(value_i)
(
  value_i = clampi(value_i, 0, 100);
  cymbal_wash = value_i;
  slider11 = value_i;
  form_dirty = 1;
);

function set_repetition_bias(value_i)
(
  value_i = clampi(value_i, 0, 100);
  repetition_bias = value_i;
  slider12 = value_i;
  form_dirty = 1;
);

function set_dynamic_lift(value_i)
(
  value_i = clampi(value_i, 0, 100);
  dynamic_lift = value_i;
  slider13 = value_i;
  form_dirty = 1;
);

function set_macro_dynamics(value_i)
(
  value_i = clampi(value_i, 0, 100);
  macro_dynamics = value_i;
  slider14 = value_i;
  form_dirty = 1;
);

function set_velocity_drift(value_i)
(
  value_i = clampi(value_i, 0, 100);
  velocity_drift = value_i;
  slider15 = value_i;
  form_dirty = 1;
);

function set_density_drift(value_i)
(
  value_i = clampi(value_i, 0, 100);
  density_drift = value_i;
  slider16 = value_i;
  form_dirty = 1;
);

function set_layer_arc_offset(value_i)
(
  value_i = clampi(value_i, 0, 100);
  layer_arc_offset = value_i;
  slider17 = value_i;
  form_dirty = 1;
);

function set_late_bloom_bias(value_i)
(
  value_i = clampi(value_i, 0, 100);
  late_bloom_bias = value_i;
  slider18 = value_i;
  form_dirty = 1;
);

function set_turnaround_zone_length(value_i)
(
  value_i = snap_turnaround_zone_length(value_i);
  turnaround_zone_length = value_i;
  slider19 = value_i;
  form_dirty = 1;
);

function set_false_peak_count(value_i)
(
  value_i = snap_false_peak_count(value_i, total_bars);
  false_peak_count = value_i;
  slider48 = value_i;
  form_dirty = 1;
);

function set_false_peak_skew(value_i)
(
  value_i = clampi(floor(value_i + 0.5), -5, 5);
  false_peak_skew = value_i;
  slider49 = value_i;
  form_dirty = 1;
);

