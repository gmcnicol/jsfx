  control_i == 16 ? set_false_peak_count(value_i) :
  set_false_peak_skew(value_i);
);

function scaled_velocity(layer_i, base_vel)
(
  clampi(floor(base_vel * layer_velocity_scale(layer_i) * 0.01 + 0.5), 1, 127);
);

function layer_amount(layer_i)
(
  layer_i == LAYER_PRECISION ? precision_amount :
  layer_i == LAYER_RIFF ? riff_amount :
  weight_amount;
);

function frac(x)
(
  x - floor(x);
);

function hash01(a, b, c, d, e) local(v)
(
  v = sin((seed + 1) * 0.071 + a * 12.989 + b * 78.233 + c * 37.719 + d * 19.913 + e * 7.133) * 43758.545;
  frac(v < 0 ? -v : v);
);

function hash_pick(max_count, a, b, c, d, e)
(
  max_count <= 1 ? 0 : floor(hash01(a, b, c, d, e) * max_count);
);

function hash_hit(percent_i, a, b, c, d, e)
(
  hash01(a, b, c, d, e) * 100 < percent_i;
);

function tempo_band_for_bpm(bpm_i)
(
  bpm_i <= 69 ? BAND_A1 :
  bpm_i <= 79 ? BAND_A2 :
  bpm_i <= 89 ? BAND_B1 :
  bpm_i <= 104 ? BAND_B2 :
  bpm_i <= 119 ? BAND_C :
  bpm_i <= 139 ? BAND_D :
  BAND_E;
);

function ms_to_samples(ms_val)
(
  floor(srate * ms_val * 0.001 + 0.5);
);

function bar_class_name(class_i)
(
  class_i == CLASS_MAIN ? sprintf(#class_txt, "main");
  class_i == CLASS_VARIATION ? sprintf(#class_txt, "variation");
  class_i == CLASS_PRE_LIFT ? sprintf(#class_txt, "pre_lift");
  class_i == CLASS_FALSE_PEAK ? sprintf(#class_txt, "false_peak");
  class_i == CLASS_IMPACT_ENTRY ? sprintf(#class_txt, "impact_entry");
  class_i == CLASS_IMPACT_MAIN ? sprintf(#class_txt, "impact_main");
  class_i == CLASS_IMPACT_VARIATION ? sprintf(#class_txt, "impact_var");
  class_i == CLASS_AFTERGLOW ? sprintf(#class_txt, "afterglow");
  class_i == CLASS_TURNAROUND ? sprintf(#class_txt, "turnaround");
  class_i == CLASS_LANDING ? sprintf(#class_txt, "landing");
);

function bar_class_short_name(class_i)
(
  class_i == CLASS_MAIN ? sprintf(#class_short_txt, "q");
  class_i == CLASS_VARIATION ? sprintf(#class_short_txt, "v");
  class_i == CLASS_PRE_LIFT ? sprintf(#class_short_txt, "pl");
  class_i == CLASS_FALSE_PEAK ? sprintf(#class_short_txt, "fp");
  class_i == CLASS_IMPACT_ENTRY ? sprintf(#class_short_txt, "in");
  class_i == CLASS_IMPACT_MAIN ? sprintf(#class_short_txt, "im");
  class_i == CLASS_IMPACT_VARIATION ? sprintf(#class_short_txt, "iv");
  class_i == CLASS_AFTERGLOW ? sprintf(#class_short_txt, "af");
  class_i == CLASS_TURNAROUND ? sprintf(#class_short_txt, "tr");
  class_i == CLASS_LANDING ? sprintf(#class_short_txt, "ld");
);

function bar_class_value(bar_i)
(
  bar_class[clampi(bar_i, 0, MAX_BARS - 1)];
);

function bar_lead_value(bar_i)
(
  bar_lead_layer[clampi(bar_i, 0, MAX_BARS - 1)];
);

function bar_support_value(bar_i)
(
  bar_support_layer[clampi(bar_i, 0, MAX_BARS - 1)];
);

function bar_cymbal_value(bar_i)
(
  bar_cymbal_mode[clampi(bar_i, 0, MAX_BARS - 1)];
);

function bar_halftime_value(bar_i)
(
  bar_halftime[clampi(bar_i, 0, MAX_BARS - 1)];
);

function bar_fill_owner_value(bar_i)
(
  bar_fill_owner[clampi(bar_i, 0, MAX_BARS - 1)];
);

function macro_section_name(section_i)
(
  section_i == MACRO_QUIET_A ? sprintf(#macro_txt, "quiet_a");
  section_i == MACRO_QUIET_B ? sprintf(#macro_txt, "quiet_b");
  section_i == MACRO_IMPACT ? sprintf(#macro_txt, "impact");
  section_i == MACRO_AFTERGLOW ? sprintf(#macro_txt, "afterglow");
  section_i == MACRO_TURNAROUND ? sprintf(#macro_txt, "turnaround");
  section_i == MACRO_LANDING ? sprintf(#macro_txt, "landing");
);

function macro_section_value(bar_i)
(
  bar_macro_section[clampi(bar_i, 0, MAX_BARS - 1)];
);

function bar_false_peak_release_value(bar_i)
(
  bar_false_peak_release[clampi(bar_i, 0, MAX_BARS - 1)];
);

function bar_afterglow_entry_value(bar_i)
(
  bar_afterglow_entry[clampi(bar_i, 0, MAX_BARS - 1)];
);

function recurrence_window_for_bars(total_bars_i)
(
  total_bars_i <= 8 ? 4 :
  total_bars_i <= 16 ? 8 :
  total_bars_i <= 32 ? 16 :
  total_bars_i <= 64 ? 32 :
  total_bars_i <= 128 ? 64 :
  128;
);

function quarter_span_for_total(total_bars_i)
(
  max(2, floor(total_bars_i * 0.25 + 0.5));
);

function is_false_peak_bar(bar_i) local(peak_i)
(
  is_false_peak_bar = 0;
  peak_i = 0;
  while (peak_i < planned_false_peak_count) (
    bar_i >= false_peak_start[peak_i] && bar_i < (false_peak_start[peak_i] + false_peak_span[peak_i]) ? (
      peak_i = MAX_FALSE_PEAKS;
      is_false_peak_bar = 1;
    ) : (
      peak_i += 1;
    );
  );
  is_false_peak_bar;
);

function compute_afterglow_entry_bar(bar_i)
(
  bar_i >= 0 && bar_class_value(bar_i) == CLASS_AFTERGLOW && (bar_i == 0 || bar_class_value(bar_i - 1) != CLASS_AFTERGLOW);
);

function is_afterglow_entry_bar(bar_i)
(
  bar_afterglow_entry_value(bar_i);
);

function compute_false_peak_release_level(bar_i)
(
  bar_i >= 0 && !is_false_peak_bar(bar_i) ? (
    is_false_peak_bar(bar_i - 1) ? 2 :
    is_false_peak_bar(bar_i - 2) ? 1 :
    0;
  ) : 0;
);

function false_peak_release_level(bar_i)
(
  bar_false_peak_release_value(bar_i);
);

function choose_poi_lead(tempo_band_i) local(score_nerve, score_surge)
(
  score_nerve = riff_amount + poi_intensity * 0.22 + (tempo_band_i <= BAND_B1 ? 12 : 4);
  score_surge = weight_amount + tom_motion * 0.36 + poi_intensity * 0.28 + (tempo_band_i >= BAND_B2 ? 10 : 0);
  score_surge >= score_nerve ? LAYER_WEIGHT : LAYER_PROCESSION;
);

function choose_primary_lead(class_i, macro_i, tempo_band_i, bar_i)
(
  false_peak_release_level(bar_i) > 0 ? (
    LAYER_PATIENT;
  ) :
  class_i == CLASS_LANDING ? (
    planned_landing_mode == LANDING_LOW_TOM ? LAYER_WEIGHT : LAYER_PATIENT;
  ) :
  class_i == CLASS_TURNAROUND ? (
    tempo_band_i <= BAND_B1 ? LAYER_PROCESSION : planned_poi_lead;
  ) :
  class_i == CLASS_IMPACT_ENTRY ? (
    LAYER_PROCESSION;
  ) :
  class_i == CLASS_IMPACT_MAIN || class_i == CLASS_IMPACT_VARIATION ? (
    planned_poi_lead;
  ) :
  class_i == CLASS_FALSE_PEAK || class_i == CLASS_PRE_LIFT ? (
    LAYER_PROCESSION;
  ) :
  class_i == CLASS_AFTERGLOW ? (
    LAYER_PATIENT;
  ) :
  macro_i == MACRO_QUIET_B ? (
    hash_hit(32 + riff_amount * 0.30, bar_i, tempo_band_i, 401, 0, 0) ? LAYER_PROCESSION : LAYER_PATIENT;
  ) : (
    LAYER_PATIENT;
  );
);

function choose_support_layer(lead_layer_i, tempo_band_i, macro_i) local(best_layer)
(
  best_layer =
    macro_i == MACRO_IMPACT ? (lead_layer_i == LAYER_WEIGHT ? LAYER_PROCESSION : LAYER_WEIGHT) :
    macro_i == MACRO_QUIET_B ? (lead_layer_i == LAYER_PATIENT ? LAYER_PROCESSION : LAYER_PATIENT) :
    macro_i == MACRO_AFTERGLOW ? LAYER_WEIGHT :
    (tempo_band_i >= BAND_C ? LAYER_PROCESSION : LAYER_WEIGHT);

  best_layer == lead_layer_i ? (
    best_layer = lead_layer_i == LAYER_PATIENT ? LAYER_PROCESSION :
      lead_layer_i == LAYER_PROCESSION ? LAYER_PATIENT :
      LAYER_PROCESSION;
  );
  best_layer;
);

function choose_fill_owner(class_i, tempo_band_i, bar_i)
(
  false_peak_release_level(bar_i) > 0 ? (
    -1;
  ) :
  class_i == CLASS_TURNAROUND ? (
    tom_motion + weight_amount > riff_amount + 6 ? LAYER_WEIGHT : LAYER_PROCESSION;
  ) :
  class_i == CLASS_PRE_LIFT || class_i == CLASS_FALSE_PEAK ? (
    LAYER_PROCESSION;
  ) :
  class_i == CLASS_IMPACT_VARIATION ? (
    planned_poi_lead;
  ) :
  -1;
);

function choose_cymbal_mode(class_i, lead_layer_i, tempo_band_i, bar_i) local(restraint_i, mode_i)
(
  restraint_i = cymbal_wash;
  force_cymbal_mode == 1 ? mode_i = CLOCK_HAT :
  force_cymbal_mode == 2 ? mode_i = CLOCK_OPEN :
  force_cymbal_mode == 3 ? mode_i = CLOCK_RIDE :
  force_cymbal_mode == 4 ? mode_i = CLOCK_TOM :
  false_peak_release_level(bar_i) > 0 ? (
    mode_i = restraint_i > 52 ? CLOCK_HAT : CLOCK_SPARSE;
  ) :
  (
    class_i == CLASS_LANDING ? (
      mode_i = planned_landing_mode == LANDING_LOW_TOM ? CLOCK_TOM : CLOCK_RIDE;
    ) :
    class_i == CLASS_TURNAROUND ? (
      mode_i = planned_landing_mode == LANDING_LOW_TOM ? CLOCK_TOM : (restraint_i > 58 ? CLOCK_HAT : CLOCK_OPEN);
    ) :
    class_i == CLASS_IMPACT_ENTRY ? (
      mode_i = CLOCK_RIDE;
    ) :
    class_i == CLASS_IMPACT_MAIN || class_i == CLASS_IMPACT_VARIATION ? (
      mode_i = CLOCK_RIDE;
    ) :
    class_i == CLASS_FALSE_PEAK || class_i == CLASS_PRE_LIFT ? (
      mode_i = restraint_i > 66 ? CLOCK_HAT : CLOCK_OPEN;
    ) :
    class_i == CLASS_AFTERGLOW ? (
      mode_i = CLOCK_SPARSE;
    ) : (
      tempo_band_i <= BAND_A2 ? (restraint_i > 54 ? CLOCK_HAT : CLOCK_SPARSE) :
      tempo_band_i <= BAND_B2 ? (restraint_i > 64 ? CLOCK_HAT : CLOCK_OPEN) :
      (lead_layer_i == LAYER_PROCESSION ? CLOCK_OPEN : CLOCK_HAT);
    );
  );
  mode_i;
);

function choose_halftime(class_i, lead_layer_i, tempo_band_i, bar_i) local(prob_i)
(
  class_i == CLASS_AFTERGLOW ? 1 : (
    false_peak_release_level(bar_i) > 0 ? 1 : (
    prob_i = halftime_bias;
    class_i == CLASS_MAIN ? prob_i += 8;
    class_i == CLASS_FALSE_PEAK ? prob_i += 10;
    class_i == CLASS_IMPACT_ENTRY ? prob_i -= 20;
    class_i == CLASS_IMPACT_MAIN || class_i == CLASS_IMPACT_VARIATION ? prob_i -= 28;
    lead_layer_i == LAYER_WEIGHT ? prob_i += 10;
    lead_layer_i == LAYER_PROCESSION ? prob_i -= 6;
    tempo_band_i >= BAND_D ? prob_i -= 16;
    doubletime_bias > 55 ? prob_i -= 10;
    hash_hit(clampi(prob_i, 0, 100), bar_i, 73, lead_layer_i, tempo_band_i, 0);
    )
  );
);

function choose_loop_pickup() local(score_i)
(
  score_i = 0;
  bar_lead_layer[0] == LAYER_PATIENT ? score_i += 1;
  bar_cymbal_mode[0] == CLOCK_HAT ? score_i += 1;
  planned_tempo_band <= BAND_B2 ? score_i += 1;
  score_i >= 2 ? 1 : 0;
);

function choose_envelope_shape(layer_i, total_bars_i) local(shape_i)
(
  layer_i == LAYER_PATIENT ? (
    shape_i = total_bars_i >= 64 && dynamic_lift > 62 ? ENV_RISE_HOLD : ENV_FLAT_ANCHOR;
  ) :
  layer_i == LAYER_PROCESSION ? (
    shape_i = late_bloom_bias > 55 ? ENV_RISE_FALL_RISE : ENV_SLOW_RISE;
  ) : (
    shape_i = total_bars_i >= 32 ? ENV_LATE_BLOOM : ENV_SLOW_RISE;
  );
  shape_i;
);

function macro_section_for_bar(bar_i) local(quarter_i)
(
  quarter_i = quarter_span_for_total(planned_total_bars);
  bar_i < quarter_i ? MACRO_QUIET_A :
  bar_i < (quarter_i * 2) ? MACRO_QUIET_B :
  bar_i < (quarter_i * 3) ? MACRO_IMPACT :
  MACRO_AFTERGLOW;
);

function extended_poi_class_for_bar(bar_i)
(
  -1;
);

function plan_form() local(bar_i, macro_i, class_i, is_long_form, quarter_i, afterglow_max_i, quiet_b_start_i, impact_quarter_start_i, impact_quarter_end_i, quarter_four_start_i, false_peak_len_i, false_peak_start_i, afterglow_end_i, false_peak_window_start_i, false_peak_window_end_i, false_peak_window_i, peak_i, peak_count_i, peak_segment_start_i, peak_segment_end_i, peak_segment_room_i, peak_room_i, peak_bias_i, peak_pos_i, peak_skew_norm_i, peak_gap_i, peak_spacing_i, peak_guard_i, peak_required_i, peak_min_start_i, peak_max_start_i, peak_remaining_i)
(
  planned_total_bars = snap_total_bars(total_bars);
  planned_effective_tempo = tempo_reference > 0 ? tempo_reference : max(tempo, 1);
  planned_tempo_band = tempo_band_for_bpm(planned_effective_tempo);
  planned_recurrence_window = recurrence_window_for_bars(planned_total_bars);
  is_long_form = planned_total_bars >= 32;
  quarter_i = quarter_span_for_total(planned_total_bars);
  quiet_b_start_i = quarter_i;
  impact_quarter_start_i = quarter_i * 2;
  impact_quarter_end_i = min(planned_total_bars - 1, impact_quarter_start_i + quarter_i - 1);
  quarter_four_start_i = min(planned_total_bars - 1, quarter_i * 3);

  planned_poi_bars = snap_poi_length(poi_length, planned_total_bars);
  planned_poi_bars > quarter_i ? planned_poi_bars = quarter_i;
  planned_poi_start = max(impact_quarter_start_i, quarter_four_start_i - planned_poi_bars);

  afterglow_max_i = max(1, planned_total_bars - quarter_four_start_i - (is_long_form ? 2 : 1));
  planned_turnaround_zone_bars = snap_turnaround_zone_length(turnaround_zone_length);
  planned_turnaround_zone_bars > afterglow_max_i ? planned_turnaround_zone_bars = afterglow_max_i;
  planned_turnaround_zone_bars < 1 ? planned_turnaround_zone_bars = 1;
  afterglow_end_i = min(planned_total_bars - 1, quarter_four_start_i + planned_turnaround_zone_bars - 1);

  is_long_form ? (
    planned_turnaround_bar = planned_total_bars - 2;
    planned_landing_bar = planned_total_bars - 1;
  ) : (
    planned_turnaround_bar = planned_total_bars - 1;
    planned_landing_bar = -1;
  );

  planned_landing_mode = (planned_tempo_band <= BAND_B1 || hash_hit(46, planned_total_bars, planned_tempo_band, 89, 0, 0)) ? LANDING_LOW_TOM : LANDING_KICK_CRASH;
  planned_poi_lead = choose_poi_lead(planned_tempo_band);

  false_peak_len_i = planned_total_bars >= 32 && hash_hit(late_bloom_bias * 0.60, planned_total_bars, seed, 444, 0, 0) ? 2 : 1;
  peak_gap_i = planned_total_bars >= 64 ? 3 : planned_total_bars >= 32 ? 2 : 1;
  peak_spacing_i = false_peak_len_i + peak_gap_i;
  peak_guard_i = max(2, floor(quarter_i * 0.25));
  planned_false_peak_count = snap_false_peak_count(false_peak_count, planned_total_bars);
  false_peak_window_start_i = max(1, quiet_b_start_i - max(2, floor(quarter_i * 0.5)));
  false_peak_window_end_i = planned_poi_start - false_peak_len_i - peak_guard_i;
  false_peak_window_i = false_peak_window_end_i - false_peak_window_start_i + 1;
  peak_count_i = planned_false_peak_count;
  peak_count_i > 0 && false_peak_window_i > 0 ? (
    peak_required_i = 1 + max(0, peak_count_i - 1) * peak_spacing_i;
    while (peak_count_i > 0 && peak_required_i > false_peak_window_i) (
      peak_count_i -= 1;
      peak_required_i = 1 + max(0, peak_count_i - 1) * peak_spacing_i;
    );
  ) : (
    peak_count_i = 0;
  );
  planned_false_peak_count = peak_count_i;
  planned_false_peak_skew = clampi(floor(false_peak_skew + 0.5), -5, 5);
  peak_skew_norm_i = planned_false_peak_skew * 0.06;

  layer_envelope_shape[LAYER_PATIENT] = choose_envelope_shape(LAYER_PATIENT, planned_total_bars);
  layer_envelope_shape[LAYER_PROCESSION] = choose_envelope_shape(LAYER_PROCESSION, planned_total_bars);
  layer_envelope_shape[LAYER_WEIGHT] = choose_envelope_shape(LAYER_WEIGHT, planned_total_bars);

  peak_i = 0;
  while (peak_i < MAX_FALSE_PEAKS) (
    false_peak_start[peak_i] = -1;
    false_peak_span[peak_i] = 0;
    peak_i += 1;
  );

  peak_i = 0;
  while (peak_i < planned_false_peak_count) (
    peak_segment_start_i = false_peak_window_start_i + floor(peak_i * max(1, false_peak_window_i) / planned_false_peak_count);
    peak_segment_end_i = false_peak_window_start_i + floor((peak_i + 1) * max(1, false_peak_window_i) / planned_false_peak_count) - 1;
    peak_segment_end_i > false_peak_window_end_i ? peak_segment_end_i = false_peak_window_end_i;
    peak_min_start_i = peak_i > 0 ? false_peak_start[peak_i - 1] + peak_spacing_i : false_peak_window_start_i;
    peak_segment_start_i < peak_min_start_i ? peak_segment_start_i = peak_min_start_i;
    peak_remaining_i = planned_false_peak_count - peak_i - 1;
    peak_max_start_i = false_peak_window_end_i - peak_remaining_i * peak_spacing_i;
    peak_segment_end_i > peak_max_start_i ? peak_segment_end_i = peak_max_start_i;
    peak_segment_end_i < peak_segment_start_i ? peak_segment_end_i = peak_segment_start_i;
    peak_room_i = max(0, peak_segment_end_i - peak_segment_start_i);
    peak_bias_i = clamp01(0.50 + peak_skew_norm_i + (hash01(452, planned_total_bars, peak_i, seed, 0) - 0.5) * 0.18);
    peak_pos_i = floor(peak_room_i * peak_bias_i + 0.5);
    peak_pos_i > peak_room_i ? peak_pos_i = peak_room_i;
    false_peak_start[peak_i] = peak_segment_start_i + peak_pos_i;
    false_peak_span[peak_i] = false_peak_len_i;
    peak_i += 1;
  );

  bar_i = 0;
  while (bar_i < MAX_BARS) (
    bar_class[bar_i] = CLASS_MAIN;
    bar_lead_layer[bar_i] = LAYER_PATIENT;
    bar_support_layer[bar_i] = LAYER_PROCESSION;
    bar_cymbal_mode[bar_i] = CLOCK_HAT;
    bar_halftime[bar_i] = 0;
    bar_fill_owner[bar_i] = -1;
    bar_turn_pickup[bar_i] = 0;
    bar_macro_section[bar_i] = MACRO_QUIET_A;
    bar_false_peak_release[bar_i] = 0;
    bar_afterglow_entry[bar_i] = 0;
    bar_i += 1;
  );

  bar_i = 0;
  while (bar_i < planned_total_bars) (
    bar_false_peak_release[bar_i] = compute_false_peak_release_level(bar_i);
    bar_i += 1;
  );

  bar_i = 0;
  while (bar_i < planned_total_bars) (
    macro_i =
      is_long_form && bar_i == planned_landing_bar ? MACRO_LANDING :
      bar_i == planned_turnaround_bar ? MACRO_TURNAROUND :
      macro_section_for_bar(bar_i);
    bar_macro_section[bar_i] = macro_i;

    class_i =
      is_long_form && bar_i == planned_landing_bar ? CLASS_LANDING :
      bar_i == planned_turnaround_bar ? CLASS_TURNAROUND :
      bar_i >= planned_poi_start && bar_i < (planned_poi_start + planned_poi_bars) ? (
        bar_i == planned_poi_start ? CLASS_IMPACT_ENTRY :
        hash_hit(min(88, 18 + poi_intensity * 0.55 + layer_variation(LAYER_WEIGHT) * 0.18), bar_i, planned_total_bars, 446, 0, 0) ? CLASS_IMPACT_VARIATION :
        CLASS_IMPACT_MAIN
      ) :
      bar_i >= quarter_four_start_i && bar_i <= afterglow_end_i ? CLASS_AFTERGLOW :
      is_false_peak_bar(bar_i) ? CLASS_FALSE_PEAK :
      bar_i == (planned_poi_start - 1) && bar_i >= quiet_b_start_i ? CLASS_PRE_LIFT :
      macro_i == MACRO_QUIET_A ? (
        hash_hit(max(6, (100 - repetition_bias) * 0.06), bar_i, planned_total_bars, 447, 0, 0) ? CLASS_VARIATION : CLASS_MAIN
      ) :
      macro_i == MACRO_QUIET_B ? (
        hash_hit(max(12, (100 - repetition_bias) * 0.16 + riff_amount * 0.12), bar_i, planned_total_bars, 448, 0, 0) ? CLASS_VARIATION : CLASS_MAIN
      ) :
      macro_i == MACRO_AFTERGLOW ? (
        hash_hit(18 + riff_amount * 0.10, bar_i, planned_total_bars, 449, 0, 0) ? CLASS_VARIATION : CLASS_MAIN
      ) :
      CLASS_MAIN;

    bar_class[bar_i] = class_i;
    bar_lead_layer[bar_i] = choose_primary_lead(class_i, macro_i, planned_tempo_band, bar_i);
    bar_support_layer[bar_i] = choose_support_layer(bar_lead_layer[bar_i], planned_tempo_band, macro_i);
    bar_halftime[bar_i] = choose_halftime(class_i, bar_lead_layer[bar_i], planned_tempo_band, bar_i);
    bar_cymbal_mode[bar_i] = choose_cymbal_mode(class_i, bar_lead_layer[bar_i], planned_tempo_band, bar_i);

    bar_fill_owner[bar_i] = choose_fill_owner(class_i, planned_tempo_band, bar_i);
    class_i == CLASS_FALSE_PEAK && hash_hit(fill_frequency * 0.32, bar_i, 450, seed, 0, 0) ? bar_fill_owner[bar_i] = LAYER_PROCESSION;
    class_i == CLASS_IMPACT_VARIATION && hash_hit(poi_intensity * 0.44, bar_i, 451, planned_poi_lead, 0, 0) ? bar_fill_owner[bar_i] = planned_poi_lead;

    (class_i == CLASS_TURNAROUND || class_i == CLASS_LANDING) ? bar_turn_pickup[bar_i] = choose_loop_pickup();
    bar_i += 1;
  );

  bar_i = 0;
  while (bar_i < planned_total_bars) (
    bar_afterglow_entry[bar_i] = compute_afterglow_entry_bar(bar_i);
    bar_i += 1;
  );

  planned_turnaround_type = choose_fill_owner(CLASS_TURNAROUND, planned_tempo_band, planned_turnaround_bar);
  form_dirty = 0;
);

function role_timing_ms(layer_i, role_i, bar_i, step_i, cycle_bar_i, sub_i) local(base_ms, lag_ms, class_i, tight_amt)
(
  base_ms = planned_tempo_band >= BAND_D ? 4 :
    planned_tempo_band >= BAND_B2 ? 6 :
    planned_tempo_band >= BAND_A2 ? 8 :
    10;
  tight_amt = clampi(groove_tightness, 0, 100);
  lag_ms = base_ms * (100 - tight_amt) * 0.008;
  cycle_bar_i >= 0 ? class_i = bar_class_value(cycle_bar_i) : class_i = CLASS_MAIN;

  layer_i == LAYER_PATIENT ? lag_ms *= 0.40;
  layer_i == LAYER_PROCESSION ? lag_ms *= 0.82;
  layer_i == LAYER_WEIGHT ? lag_ms *= 1.08;

  role_i == 0 ? lag_ms *= 0.55;
  role_i == 1 ? lag_ms *= 0.70;
  role_i >= 7 && role_i <= 10 ? lag_ms *= 1.18;

  class_i == CLASS_TURNAROUND && step_i >= 12 ? lag_ms *= 0.62;
  (class_i == CLASS_IMPACT_ENTRY || class_i == CLASS_IMPACT_MAIN) && layer_i == bar_lead_value(cycle_bar_i) ? lag_ms *= 0.80;
  sub_i ? lag_ms += base_ms * 0.15;

  max(0, lag_ms);
);

function queue_note_off(chan_i, note_i, abs_time_i) local(next_tail)
(
  queue_note_off = 0;
  next_tail = queue_tail + 1;
  next_tail >= QUEUE_SIZE ? next_tail = 0;
  next_tail != queue_head ? (
    off_time[queue_tail] = abs_time_i;
    off_chan[queue_tail] = chan_i;
    off_note[queue_tail] = note_i;
    queue_tail = next_tail;
    queue_note_off = 1;
  );
);

function flush_all_note_offs() local(i, repeat_count, note_i, chan_i, guard, repeat_guard)
(
  guard = 0;
  while ((queue_head != queue_tail) && (guard < QUEUE_SIZE)) (
    queue_head += 1;
    queue_head >= QUEUE_SIZE ? queue_head = 0;
    guard += 1;
  );
  queue_head = 0;
  queue_tail = 0;

  i = 0;
  while (i < (16 * 128)) (
    repeat_count = active_note_count[i];
    note_i = i % 128;
    chan_i = floor(i / 128);
    repeat_guard = 0;
    while ((repeat_count > 0) && (repeat_guard < 64)) (
      midisend(0, 128 | chan_i, note_i);
      repeat_count -= 1;
      repeat_guard += 1;
    );
    active_note_count[i] = 0;
    i += 1;
  );
);

function flush_due_note_offs() local(rel_spl, chan_i, note_i, active_idx, guard)
(
  guard = 0;
  while (
    (queue_head != queue_tail) &&
    (off_time[queue_head] < block_abs_end) &&
    (guard < QUEUE_SIZE)
  ) (
    rel_spl = off_time[queue_head] - block_abs_start;
    rel_spl < 0 ? rel_spl = 0;
    rel_spl >= samplesblock ? rel_spl = samplesblock - 1;

    chan_i = off_chan[queue_head];
    note_i = off_note[queue_head];
    midisend(rel_spl, 128 | chan_i, note_i);

    active_idx = active_note_index(chan_i, note_i);
    active_note_count[active_idx] > 0 ? active_note_count[active_idx] -= 1;

    queue_head += 1;
    queue_head >= QUEUE_SIZE ? queue_head = 0;
    guard += 1;
  );
);

function trigger_role(layer_i, role_i, base_vel, rel_offset, bar_i, step_i, cycle_bar_i, sub_i) local(pad_i, note_i, chan_i, vel_i, note_off_at, active_idx, hit_offset, timing_spl, sub_offset)
(
  base_vel > 0 ? (
    pad_i = get_pad_for_role(layer_i, role_i);
    note_i = get_pad_note(layer_i, pad_i);
    chan_i = layer_channel_zero(layer_i);
    vel_i = scaled_velocity(layer_i, base_vel);
    timing_spl = ms_to_samples(role_timing_ms(layer_i, role_i, bar_i, step_i, cycle_bar_i, sub_i));
    sub_offset = sub_i ? floor(step_samples * 0.5 + 0.5) : 0;
    hit_offset = rel_offset + sub_offset + timing_spl;
    hit_offset < 0 ? hit_offset = 0;
    hit_offset >= samplesblock ? hit_offset = samplesblock - 1;
    note_off_at = block_abs_start + hit_offset + note_len_samples;

    queue_note_off(chan_i, note_i, note_off_at) ? (
      midisend(hit_offset, 144 | chan_i, note_i | (vel_i * 256));
      layer_activity[layer_pad_index(layer_i, pad_i)] = min(1.4, layer_activity[layer_pad_index(layer_i, pad_i)] + 0.65);
      slot_activity[pad_i] = min(1.6, slot_activity[pad_i] + 0.55);
      active_idx = active_note_index(chan_i, note_i);
      active_note_count[active_idx] += 1;
    );
  );
);

function queue_ui_audition(layer_i, pad_i)
(
  ui_audition_pending = 1;
  ui_audition_layer = layer_i;
  ui_audition_pad = pad_i;
);

function is_downbeat_step(step_i)
(
  (step_i % 4) == 0;
);

function is_eighth_step(step_i)
(
  (step_i % 2) == 0;
);

function is_backbeat_step(step_i, halftime_i)
(
  halftime_i ? (step_i == 8) : ((step_i == 4) || (step_i == 12));
);

function patient_motif_step(motif_i, step_i)
(
  motif_i == 0 ? ((step_i == 0) || (step_i == 8)) :
  motif_i == 1 ? ((step_i == 0) || (step_i == 7) || (step_i == 8)) :
  motif_i == 2 ? ((step_i == 0) || (step_i == 6) || (step_i == 8) || (step_i == 10)) :
  ((step_i == 0) || (step_i == 8) || (step_i == 11) || (step_i == 14));
);

function procession_motif_step(motif_i, step_i)
(
  motif_i == 0 ? ((step_i == 4) || (step_i == 12)) :
  motif_i == 1 ? ((step_i == 0) || (step_i == 4) || (step_i == 8) || (step_i == 12)) :
  motif_i == 2 ? ((step_i == 2) || (step_i == 6) || (step_i == 10) || (step_i == 14)) :
  ((step_i == 0) || (step_i == 3) || (step_i == 8) || (step_i == 11) || (step_i == 15));
);

function weight_motif_step(motif_i, step_i)
(
  motif_i == 0 ? ((step_i == 0) || (step_i == 8)) :
  motif_i == 1 ? ((step_i == 0) || (step_i == 4) || (step_i == 8) || (step_i == 12)) :
  motif_i == 2 ? ((step_i == 2) || (step_i == 6) || (step_i == 10) || (step_i == 14)) :
  ((step_i == 0) || (step_i == 3) || (step_i == 8) || (step_i == 11) || (step_i == 15));
);

function shifted_progress(layer_i, bar_i) local(x, arc_amt)
(
  x = planned_total_bars <= 1 ? 0 : bar_i / max(planned_total_bars - 1, 1);
  arc_amt = (layer_arc_offset - 50) * 0.0035;
  layer_i == LAYER_PATIENT ? x -= arc_amt :
  layer_i == LAYER_WEIGHT ? x += arc_amt;
  clamp01(x);
);

function envelope_value(shape_i, x) local(y)
(
  shape_i == ENV_FLAT_ANCHOR ? (0.62 + x * 0.10) :
  shape_i == ENV_SLOW_RISE ? (0.30 + x * x * 0.56) :
  shape_i == ENV_LATE_BLOOM ? (
    y = clamp01((x - (0.18 + late_bloom_bias * 0.0015)) / max(0.18, 0.82 - late_bloom_bias * 0.0015));
    0.18 + y * y * 0.78;
  ) :
  shape_i == ENV_RISE_HOLD ? (
    x < 0.55 ? (0.30 + x * 0.92) : (0.80 + (x - 0.55) * 0.12);
  ) :
  shape_i == ENV_RISE_FALL_RISE ? (
    x < 0.45 ? (0.28 + x * 0.88) :
    x < 0.72 ? (0.68 - (x - 0.45) * 0.42) :
    (0.56 + (x - 0.72) * 0.72);
  ) :
  shape_i == ENV_CREST_RELEASE ? (
    x < 0.78 ? (0.24 + x * 0.84) : (0.90 - (x - 0.78) * 1.05);
  ) :
  (0.54 + sin(x * 6.28318) * 0.14 + x * 0.10);
);

function layer_macro_energy(layer_i, bar_i) local(x, base_i, macro_amt, release_i)
(
  x = shifted_progress(layer_i, bar_i);
  base_i = envelope_value(layer_envelope_shape[layer_i], x);
  planned_total_bars <= 32 ? base_i = 0.60 + (base_i - 0.60) * 0.35;
  macro_amt = planned_total_bars <= 32 ? (0.30 + macro_dynamics * 0.004) : (0.58 + macro_dynamics * 0.003);
  base_i = 0.60 + (base_i - 0.60) * macro_amt;
  base_i += (dynamic_lift - 50) * 0.0016;
  release_i = false_peak_release_level(bar_i);
  release_i > 0 ? (
    layer_i == LAYER_PATIENT ? base_i -= release_i * 0.05 :
    layer_i == LAYER_PROCESSION ? base_i -= release_i * 0.14 :
    base_i -= release_i * 0.18;
  );
  clamp01(base_i);
);

function macro_density_bias(macro_i)
(
  macro_i == MACRO_QUIET_A ? -0.14 :
  macro_i == MACRO_QUIET_B ? -0.04 :
  macro_i == MACRO_IMPACT ? 0.16 :
  macro_i == MACRO_AFTERGLOW ? -0.10 :
  macro_i == MACRO_TURNAROUND ? 0.05 :
  -0.12;
);

function tension_backbeat_velocity(macro_i, class_i, energy_i) local(base_i)
(
  base_i =
    macro_i == MACRO_QUIET_A ? 56 :
    macro_i == MACRO_QUIET_B ? 68 :
    macro_i == MACRO_IMPACT ? 86 :
    macro_i == MACRO_AFTERGLOW ? 60 :
    macro_i == MACRO_TURNAROUND ? 76 :
    58;
  class_i == CLASS_FALSE_PEAK ? base_i += 8;
  class_i == CLASS_PRE_LIFT ? base_i += 6;
  class_i == CLASS_IMPACT_ENTRY ? base_i += 12;
  class_i == CLASS_IMPACT_VARIATION ? base_i += 6;
  class_i == CLASS_TURNAROUND ? base_i += 10;
  class_i == CLASS_LANDING ? base_i -= 8;
  clampi(floor(base_i + energy_i * 10 + 0.5), 1, 127);
);

function tension_backbeat_probability(macro_i, class_i, lead_i, support_i) local(prob_i)
(
  prob_i =
    macro_i == MACRO_QUIET_A ? 38 :
    macro_i == MACRO_QUIET_B ? 62 :
    macro_i == MACRO_IMPACT ? 72 :
    macro_i == MACRO_AFTERGLOW ? 34 :
    macro_i == MACRO_TURNAROUND ? 60 :
    30;
  class_i == CLASS_FALSE_PEAK ? prob_i += 12;
  class_i == CLASS_PRE_LIFT ? prob_i += 8;
  class_i == CLASS_IMPACT_ENTRY ? prob_i += 18;
  class_i == CLASS_IMPACT_VARIATION ? prob_i += 8;
  class_i == CLASS_TURNAROUND ? prob_i += 12;
  lead_i == LAYER_PROCESSION ? prob_i += 8;
  support_i == LAYER_PROCESSION ? prob_i += 5;
  planned_total_bars <= 16 ? (
    prob_i -= 12;
    macro_i == MACRO_QUIET_A ? prob_i -= 8;
    macro_i == MACRO_QUIET_B ? prob_i -= 4;
    class_i == CLASS_IMPACT_ENTRY ? prob_i += 6;
  );
  clampi(prob_i, 0, 100);
);

function patient_backbeat_velocity(macro_i, class_i, energy_i) local(base_i)
(
  base_i =
    macro_i == MACRO_QUIET_A ? 98 :
    macro_i == MACRO_QUIET_B ? 102 :
    macro_i == MACRO_IMPACT ? 112 :
    macro_i == MACRO_AFTERGLOW ? 96 :
    macro_i == MACRO_TURNAROUND ? 106 :
    94;
  class_i == CLASS_FALSE_PEAK ? base_i += 4;
  class_i == CLASS_PRE_LIFT ? base_i += 4;
  class_i == CLASS_IMPACT_ENTRY ? base_i += 8;
  class_i == CLASS_IMPACT_VARIATION ? base_i += 4;
  class_i == CLASS_TURNAROUND ? base_i += 4;
  class_i == CLASS_LANDING ? base_i -= 6;
  clampi(floor(base_i + energy_i * 9 + 0.5), 1, 127);
);

function patient_rim_backbeat_velocity(macro_i, class_i, energy_i) local(base_i)
(
  base_i =
    macro_i == MACRO_QUIET_A ? 60 :
    macro_i == MACRO_QUIET_B ? 68 :
    macro_i == MACRO_IMPACT ? 78 :
    macro_i == MACRO_AFTERGLOW ? 58 :
    macro_i == MACRO_TURNAROUND ? 72 :
    56;
  class_i == CLASS_FALSE_PEAK ? base_i += 6;
  class_i == CLASS_IMPACT_ENTRY ? base_i += 4;
  class_i == CLASS_TURNAROUND ? base_i += 4;
  class_i == CLASS_LANDING ? base_i -= 4;
  clampi(floor(base_i + energy_i * 8 + 0.5), 1, 127);
);

function patient_role_velocity(role_i, bar_i, step_i, cycle_bar_i, sub_i) local(density_i, variation_i, class_i, macro_i, lead_i, support_i, clock_i, halftime_i, fill_owner_i, major_fill_i, simplify_i, energy_i, motif_i, prob_i, vel_i, accent_i, anchor_vel_i, rim_anchor_vel_i, afterglow_entry_i, release_i, clock_active_i)
(
  density_i = layer_density(LAYER_PATIENT);
  variation_i = layer_variation(LAYER_PATIENT);
  class_i = bar_class_value(cycle_bar_i);
  macro_i = macro_section_value(cycle_bar_i);
  lead_i = bar_lead_value(cycle_bar_i);
  support_i = bar_support_value(cycle_bar_i);
  clock_i = bar_cymbal_value(cycle_bar_i);
  halftime_i = bar_halftime_value(cycle_bar_i);
  fill_owner_i = bar_fill_owner_value(cycle_bar_i);
  major_fill_i = (fill_owner_i == LAYER_PATIENT) && ((class_i == CLASS_IMPACT_VARIATION) || (class_i == CLASS_TURNAROUND));
  simplify_i = (fill_owner_i >= 0) && (fill_owner_i != LAYER_PATIENT) && ((class_i == CLASS_FALSE_PEAK) || (class_i == CLASS_IMPACT_VARIATION) || (class_i == CLASS_TURNAROUND));
  energy_i = layer_macro_energy(LAYER_PATIENT, cycle_bar_i) + macro_density_bias(macro_i) * 0.35;
  motif_i = hash_pick(4, floor(cycle_bar_i / max(4, planned_recurrence_window)), variation_i, class_i, 201, 0);
  prob_i = density_i * 0.45 + precision_amount * 0.35 + repetition_bias * 0.20 + energy_i * 25;
  anchor_vel_i = patient_backbeat_velocity(macro_i, class_i, energy_i);
  rim_anchor_vel_i = patient_rim_backbeat_velocity(macro_i, class_i, energy_i);
  afterglow_entry_i = is_afterglow_entry_bar(cycle_bar_i);
